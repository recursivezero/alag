---
import "../styles/global.css";
const page = Astro && Astro.props && Astro.props.page ? Astro.props.page : "";
const authPages = new Set(["dashboard", "users"]);
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Recursive Auth</title>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <link rel="icon" type="image/png" href="/icon2.png" sizes="1024X1024" />
  </head>
  <body>
    <nav class="navbar">
      <div class="nav-brand">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M12 2L4 7v5c0 4.55 3.4 8.74 8 9.93C16.6 20.74 20 16.55 20 12V7L12 2z"
            fill="currentColor"
            style="color: var(--purple);"></path>
          <path
            d="M9 12l2 2 4-4"
            stroke="white"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        <span>Recursive<span class="accent">Auth</span></span>
      </div>
      {
        authPages.has(page) ? (
          <ul class="nav-links auth-links">
            <li>
              <a href="/">Back to Home</a>
            </li>
            <li>
              <a href="/dashboard" class={page === "dashboard" ? "active" : ""}>
                Dashboard
              </a>
            </li>
            <li>
              <a href="/users" class={page === "users" ? "active" : ""}>
                User
              </a>
            </li>
          </ul>
        ) : (
          <ul class="nav-links">
            <li>
              <a href="/" class={page === "home" ? "active" : ""}>
                Home
              </a>
            </li>
            <li>
              <a href="/login" class={page === "login" ? "active" : ""}>
                Login
              </a>
            </li>
            <li>
              <a href="/register" class={page === "register" ? "active" : ""}>
                Register
              </a>
            </li>
            <li>
              <a href="/about" class={page === "about" ? "active" : ""}>
                About
              </a>
            </li>
          </ul>
        )
      }
    </nav>
    <main class="page-container">
      <slot />
    </main>
  </body>
</html>

<style>
  :global(body) {
    display: flex;
    flex-direction: column;
  }
</style>
