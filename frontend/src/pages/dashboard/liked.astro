---
import UserDashboardLayout from "../../layouts/UserDashboardLayout.astro";
import Feed        from "../../components/user/Feed.astro";
import FeedFilters from "../../components/user/FeedFilters.astro";
import UploadModal from "../../components/user/UploadModal.astro";

import { fetchCurrentUserOrGuest } from "../../services/userService";
import { fetchFeedPosts }           from "../../services/postService";

const cookieHeader  = Astro.request.headers.get("cookie") || "";
const currentUser   = await fetchCurrentUserOrGuest({ cookieHeader });
const posts         = currentUser.id
  ? await fetchFeedPosts({ cookieHeader, userId: currentUser.id })
  : [];
---

<UserDashboardLayout title="Dashboard | RecursiveAuth" user={currentUser}>

  <div class="page-grid mx-auto w-full max-w-[1400px]" style="padding: 28px 28px 40px 28px;">

    <!-- ══════════════ LEFT / MAIN FEED ══════════════ -->
    <section class="feed-col min-w-0">
      <!-- Hero greeting -->
      <div class="mb-6">
        <h1 class="mt-1.5 text-[32px] font-black tracking-[-0.05em] text-[color:var(--dashboard-text)] lg:text-[36px]">
          Liked Posts
        </h1>
        <p class="mt-2 max-w-xl text-[14px] leading-6 text-[color:var(--dashboard-muted)]">
          Discover fresh image posts, Like what inspires you, and stay
          connected with the people and moments you follow.
        </p>
      </div>

      <!-- Category filters -->
      <div class="mb-5">
        <FeedFilters current="all" />
      </div>

      <!-- Posts feed -->
      <Feed posts={posts} />
    </section>

    <!-- ══════════════ RIGHT SIDEBAR ══════════════ -->
  </div>

  <UploadModal />
</UserDashboardLayout>

<style>
  /* ── 2-column layout ── */
  .page-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    /* inline style handles padding — beats Tailwind preflight */
  }

  @media (min-width: 1280px) {
    .page-grid {
      grid-template-columns: minmax(0, 1fr) 308px;
      gap: 2rem;
    }
  }

  /* ── Profile card glass ── */
  .profile-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    box-shadow: var(--dashboard-shadow);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  /* ── Divider ── */
  .section-divider {
    height: 1px;
    background: var(--dashboard-border);
    margin: 0 1.25rem;
  }

  /* ── Stat chips ── */
  .stat-chip {
    background: var(--dashboard-surface);
    border: 1px solid var(--dashboard-border);
  }

  /* ── Tag chips ── */
  .tag-chip {
    border-color: var(--dashboard-border);
    background: var(--dashboard-surface);
  }
  .tag-chip:hover {
    border-color: rgba(124,58,237,0.25);
    background: var(--dashboard-accent-soft);
    color: var(--dashboard-accent);
  }

  /* ── Section heading ── */
  .section-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: var(--dashboard-muted);
  }
</style>