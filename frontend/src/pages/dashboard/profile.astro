---
import UserDashboardLayout from "../../layouts/UserDashboardLayout.astro";
import UploadModal from "../../components/user/UploadModal.astro";
import EditProfileModal from "../../components/user/EditProfileModal.astro";
import { fetchCurrentUserOrGuest } from "../../services/userService";
import { fetchMyPosts } from "../../services/postService";

const cookieHeader = Astro.request.headers.get("cookie") || "";
const currentUser = await fetchCurrentUserOrGuest({ cookieHeader });

const buildAvatarFallback = (name: string) => {
  const initials =
    (name || "User")
      .trim()
      .split(/\s+/)
      .slice(0, 2)
      .map((part) => part[0] || "")
      .join("")
      .toUpperCase() || "U";

  const svg = `
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 120" role="img" aria-label="Profile avatar fallback">
      <defs>
        <linearGradient id="avatar-bg" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#8b5cf6" />
          <stop offset="100%" stop-color="#d946ef" />
        </linearGradient>
      </defs>
      <circle cx="60" cy="60" r="60" fill="url(#avatar-bg)" />
      <circle cx="60" cy="48" r="22" fill="rgba(255,255,255,0.92)" />
      <path d="M26 103c6.8-19 23.2-30 34-30s27.2 11 34 30" fill="rgba(255,255,255,0.92)" />
      <text x="60" y="68" text-anchor="middle" font-size="30" font-family="Arial, sans-serif" font-weight="700" fill="#5b21b6">${initials}</text>
    </svg>
  `;

  return `data:image/svg+xml;charset=UTF-8,${encodeURIComponent(svg)}`;
};

const profileAvatarFallback = buildAvatarFallback(
  currentUser.fullName || currentUser.name || "User",
);

const profileUsername =
  currentUser.username ||
  (currentUser.fullName || currentUser.name || "")
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, ".")
    .replace(/^\.+|\.+$/g, "") ||
  "Not set";

const myPosts = currentUser.id ? await fetchMyPosts({ cookieHeader }) : [];

const formatUploadDate = (dateValue: string) => {
  return new Intl.DateTimeFormat("en", {
    month: "short",
    day: "numeric",
    year: "numeric",
  }).format(new Date(dateValue));
};
---

<UserDashboardLayout title="Profile | RecursiveAuth" user={currentUser}>
  <main class="mx-auto w-full max-w-4xl px-4 py-6 lg:px-8">
    <div
      class="profile-card-container rounded-[36px] border border-[color:var(--dashboard-border)] bg-[color:var(--dashboard-surface)] p-6 shadow-[var(--dashboard-shadow)] lg:p-8"
    >
      <div
        class="profile-hero flex flex-col gap-5 rounded-[28px] border border-[color:var(--dashboard-border)] bg-[color:var(--dashboard-surface-strong)] p-6 lg:flex-row lg:items-center lg:justify-between"
      >
        <div>
          <p
            class="text-sm font-semibold uppercase tracking-[0.18em] text-[color:var(--dashboard-accent)]"
          >
            Account
          </p>
          <h1
            data-dashboard-profile-full-name
            class="mt-2 text-3xl font-semibold tracking-tight text-[color:var(--dashboard-text)]"
          >
            {currentUser.fullName || currentUser.name}
          </h1>
          <p
            data-dashboard-profile-username
            class="mt-2 text-base font-medium text-[color:var(--dashboard-muted)]"
          >
            @{profileUsername}
          </p>
        </div>
        <div class="flex flex-col items-end gap-4 sm:flex-row sm:items-center">
          <button
            type="button"
            data-edit-profile-trigger
            class="edit-profile-btn inline-flex items-center gap-2 rounded-xl bg-violet-600 px-4 py-2.5 text-sm font-semibold text-white shadow-[0_6px_20px_rgba(139,92,246,0.35)] transition-colors duration-200 hover:bg-violet-500 active:bg-violet-700"
          >
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"
              ></path>
              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"
              ></path>
            </svg>
            Edit Profile
          </button>
          <div data-dashboard-profile-avatar class="shrink-0">
            <img
              src={currentUser.picture || profileAvatarFallback}
              alt="Profile avatar"
              class="h-24 w-24 rounded-full object-cover ring-1 ring-black/10 dark:ring-white/10"
            />
          </div>
        </div>
      </div>

      <div
        class="profile-account-card mt-6 grid gap-4 rounded-[28px] border border-[color:var(--dashboard-border)] bg-[color:var(--dashboard-surface-strong)] p-6"
      >
        <dl class="grid gap-4 md:grid-cols-2">
          <div>
            <dt class="text-sm text-[color:var(--dashboard-muted)]">
              Full Name
            </dt>
            <dd
              data-dashboard-profile-name
              class="mt-1 text-base font-medium text-[color:var(--dashboard-text)]"
            >
              {currentUser.fullName || currentUser.name}
            </dd>
          </div>
          <div>
            <dt class="text-sm text-[color:var(--dashboard-muted)]">
              Username
            </dt>
            <dd
              data-dashboard-profile-username
              class="mt-1 text-base font-medium text-[color:var(--dashboard-text)]"
            >
              {profileUsername}
            </dd>
          </div>
          <div>
            <dt class="text-sm text-[color:var(--dashboard-muted)]">
              Email Address
            </dt>
            <dd
              data-dashboard-profile-email
              class="mt-1 text-base font-medium text-[color:var(--dashboard-text)]"
            >
              {currentUser.email}
            </dd>
          </div>
          <div>
            <dt class="text-sm text-[color:var(--dashboard-muted)]">
              Phone Number
            </dt>
            <dd
              data-dashboard-profile-phone
              class="mt-1 text-base font-medium text-[color:var(--dashboard-text)]"
            >
              {currentUser.phoneNumber || "Not set"}
            </dd>
          </div>
          <div class="md:col-span-2">
            <dt class="text-sm text-[color:var(--dashboard-muted)]">Bio</dt>
            <dd
              data-dashboard-profile-bio
              class="mt-1 text-base font-medium leading-7 text-[color:var(--dashboard-text)]"
            >
              {currentUser.bio || "Not set"}
            </dd>
          </div>
        </dl>
      </div>

      <section
        class="my-posts-section mt-6 rounded-[28px] border border-[color:var(--dashboard-border)] bg-[color:var(--dashboard-surface-strong)] p-6"
      >
        <div class="flex items-center justify-between gap-4">
          <div class="post-image-card">
            <p
              class="text-sm font-semibold uppercase tracking-[0.18em] text-[color:var(--dashboard-accent)]"
            >
              Uploads
            </p>
            <h2
              class="mt-2 text-2xl font-semibold tracking-tight text-[color:var(--dashboard-text)]"
            >
              My Posts
            </h2>
          </div>
          <div
            class="items-part rounded-full border border-[color:var(--dashboard-border)] px-3 py-1 text-xs font-medium text-[color:var(--dashboard-muted)]"
          >
            {myPosts.length} items
          </div>
        </div>

        {
          myPosts.length ? (
            <div class="mt-5 grid gap-4">
              {myPosts.map((post) => (
                <article class="flex flex-col gap-4 rounded-[24px] border border-[color:var(--dashboard-border)] bg-[color:var(--dashboard-surface)] p-4 sm:flex-row sm:items-start">
                  {/* <a class="post-image" href={`/posts/${post.slug}`} class="shrink-0 overflow-hidden rounded-[18px] border border-[color:var(--dashboard-border)] sm:w-36">
                    
                  </a> */}

                  <img
                    src={post.imageUrl}
                    alt={post.altText || post.caption}
                    class="img h-32 w-full object-cover sm:h-28 sm:w-36"
                  />

                  <div class="post-item-discription min-w-0 flex-1">
                    <div class="flex flex-wrap items-center gap-2">
                      <a
                        href={`/posts/${post.slug}`}
                        class="truncate text-lg font-semibold text-[color:var(--dashboard-text)] transition hover:text-[color:var(--dashboard-accent)]"
                      >
                        {post.title}
                      </a>
                      <span class="rounded-full border border-[color:var(--dashboard-border)] px-2.5 py-1 text-[11px] font-medium uppercase tracking-[0.14em] text-[color:var(--dashboard-muted)]">
                        {post.feedType === "personal" ? "Personal" : "Public"}
                      </span>
                    </div>

                    <p class="mt-2 line-clamp-2 text-sm leading-6 text-[color:var(--dashboard-muted)]">
                      {post.caption}
                    </p>

                    <div class="mt-4 flex flex-wrap items-center gap-3 text-xs text-[color:var(--dashboard-muted)]">
                      <span>{formatUploadDate(post.createdAt)}</span>
                      {post.location ? <span>• {post.location}</span> : null}
                      {post.category ? <span>• {post.category}</span> : null}
                    </div>
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <div class="mt-5 rounded-[24px] border border-dashed border-[color:var(--dashboard-border)] px-5 py-10 text-center text-sm text-[color:var(--dashboard-muted)]">
              Your personal uploads will appear here after you choose Personal
              Feed in the upload modal.
            </div>
          )
        }
      </section>
    </div>
  </main>
  <UploadModal />
  <EditProfileModal />
</UserDashboardLayout>

<style>
  .profile-card-container {
    padding: 20px;
  }
  .profile-hero {
    padding: 20px;
  }
  .profile-account-card {
    margin-top: 30px;
    padding: 20px;
    margin-bottom: 30px;
  }
  .my-posts-section {
    padding: 20px;
  }
  .post-image-card {
    margin-bottom: 20px;
  }
  .items-part {
    height: 35px;
    width: 60px;
    text-align: center;
    display: flex;
    justify-content: center;
    padding-top: 7px;
  }
  .post-item-discription {
    padding: 10px;
  }
  .post-image {
    padding: 10px;
  }

  /* post image increase decrease */
  .img {
    border-radius: 20px;
    height: 100%;
    width: 30vh;
  }
  .edit-profile-btn {
    padding: 10px;
    margin-right: 24px;
  }
</style>
