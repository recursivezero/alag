---
import UserDashboardLayout from "../../layouts/UserDashboardLayout.astro";
import Sidebar from "../../components/user/Sidebar.astro";
import Topbar from "../../components/user/Topbar.astro";
import UploadModal from "../../components/user/UploadModal.astro";
import { fetchCurrentUserOrGuest } from "../../services/userService";

const cookieHeader = Astro.request.headers.get("cookie") || "";
const currentUser = await fetchCurrentUserOrGuest({ cookieHeader });
---

<UserDashboardLayout title="Settings | RecursiveAuth">
  <div class="dashboard-shell">
    <Sidebar currentPath={Astro.url.pathname} user={currentUser} />
    <div class="min-h-screen lg:pl-72">
      <Topbar user={currentUser} />
      <main class="mx-auto w-full max-w-4xl px-4 py-6 lg:px-8">
        <div class="rounded-[36px] border border-[color:var(--dashboard-border)] bg-[color:var(--dashboard-surface)] p-6 shadow-[var(--dashboard-shadow)] lg:p-8">
          <h1 class="text-4xl font-semibold tracking-tight text-[color:var(--dashboard-text)]">Settings</h1>
          <div class="mt-6 grid gap-4 rounded-[28px] border border-[color:var(--dashboard-border)] bg-[color:var(--dashboard-surface-strong)] p-6">
            <p class="text-sm text-[color:var(--dashboard-muted)]">Theme, notifications, and account preferences can be wired into your existing backend flows here.</p>
            <div class="grid gap-3 md:grid-cols-2">
              <div class="rounded-[22px] border border-[color:var(--dashboard-border)] bg-[color:var(--dashboard-surface)] p-4">
                <p class="font-medium text-[color:var(--dashboard-text)]">Notifications</p>
                <p class="mt-1 text-sm text-[color:var(--dashboard-muted)]">Notification preferences placeholder.</p>
              </div>
              <div class="rounded-[22px] border border-[color:var(--dashboard-border)] bg-[color:var(--dashboard-surface)] p-4">
                <p class="font-medium text-[color:var(--dashboard-text)]">Security</p>
                <p class="mt-1 text-sm text-[color:var(--dashboard-muted)]">Session and verification settings placeholder.</p>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>
  <UploadModal />
</UserDashboardLayout>