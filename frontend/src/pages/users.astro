---
import MainLayout from "../layouts/MainLayout.astro";
---

<style>
  .users-shell {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .users-card {
    width: min(100%, 1180px);
    border: 1px solid var(--border);
    border-radius: 28px;
    background: linear-gradient(
      180deg,
      rgba(17, 17, 28, 0.97),
      rgba(11, 11, 20, 0.93)
    );
    box-shadow: 0 28px 70px rgba(0, 0, 0, 0.42);
    padding: clamp(1.2rem, 2vw, 2rem);
  }

  .users-head {
    margin-bottom: 1.2rem;
  }

  .eyebrow {
    color: var(--purple-light);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.75rem;
    margin-bottom: 0.35rem;
  }

  .users-head h1,
  .users-head h2,
  .users-head p {
    margin: 0;
  }

  .users-head h1 {
    font-size: clamp(1.7rem, 3vw, 2.4rem);
    letter-spacing: -0.04em;
  }

  .users-copy {
    margin-top: 0.45rem;
    color: var(--muted);
    line-height: 1.6;
    max-width: 70ch;
  }

  .add-user-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) minmax(0, 1fr) auto;
    gap: 0.9rem;
    align-items: end;
  }

  .field-block label {
    display: block;
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.4rem;
  }

  .field-block input {
    width: 100%;
    padding: 0.9rem 1rem;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: var(--input-bg);
    color: var(--text);
    outline: none;
    transition:
      border-color var(--ease),
      box-shadow var(--ease),
      transform var(--ease);
  }

  .field-block .password-wrap {
    position: relative;
  }

  .field-block .password-wrap input {
    padding-right: 2.7rem;
  }

  .password-toggle {
    position: absolute;
    right: 0.9rem;
    top: 50%;
    transform: translateY(-50%);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.4rem;
    height: 1.4rem;
    border: none;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    padding: 0;
  }

  .password-toggle:hover {
    color: var(--text);
  }

  .password-toggle svg {
    width: 1rem;
    height: 1rem;
  }

  .field-block input:focus {
    border-color: rgba(124, 92, 252, 0.55);
    box-shadow: 0 0 0 3px var(--purple-glow);
  }

  .input-wrap {
    position: relative;
    width: 100%;
  }

  .input-wrap input {
    width: 100%;
    padding-right: 2.7rem;
  }

  .input-icon {
    position: absolute;
    right: 0.9rem;
    top: 50%;
    transform: translateY(-50%);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.2rem;
    height: 1.2rem;
    color: var(--muted);
    pointer-events: none;
  }

  .input-icon svg {
    width: 1rem;
    height: 1rem;
  }

  .btn {
    background: linear-gradient(135deg, var(--purple), #6f86ff);
    color: white;
    border: none;
    padding: 0.92rem 1.3rem;
    border-radius: 14px;
    cursor: pointer;
    font-weight: 700;
    min-width: 112px;
    box-shadow: 0 16px 30px rgba(124, 92, 252, 0.26);
  }

  .summary-row {
    margin-top: 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .table-wrap {
    margin-top: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 26px;
    overflow: auto;
    background: linear-gradient(
      180deg,
      rgba(10, 12, 24, 0.9),
      rgba(12, 14, 28, 0.96)
    );
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
  }

  :global(.th-inner) {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }

  :global(.th-hash) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 9px;
    background: linear-gradient(
      180deg,
      rgba(124, 92, 252, 0.38),
      rgba(124, 92, 252, 0.14)
    );
    border: 1px solid rgba(180, 160, 255, 0.16);
    color: #efe9ff;
    font-size: 0.9rem;
    font-weight: 700;
  }

  :global(.th-icon) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 9px;
    background: linear-gradient(
      180deg,
      rgba(124, 92, 252, 0.38),
      rgba(124, 92, 252, 0.14)
    );
    border: 1px solid rgba(180, 160, 255, 0.16);
    color: #efe9ff;
    flex: 0 0 auto;
  }

  :global(.th-icon svg) {
    width: 1rem;
    height: 1rem;
  }

  :global(.th-label) {
    color: var(--text);
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    text-transform: none;
  }

  :global(.status-pill) {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.38rem 0.85rem 0.38rem 0.5rem;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  :global(.pill-icon) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.35rem;
    height: 1.35rem;
    border-radius: 999px;
  }

  :global(.pill-icon svg) {
    width: 0.82rem;
    height: 0.82rem;
  }

  :global(.status-pill.verified) {
    background: rgba(46, 204, 113, 0.12);
    color: #4cd987;
    border: 1px solid rgba(46, 204, 113, 0.22);
  }

  :global(.status-pill.verified .pill-icon) {
    background: rgba(46, 204, 113, 0.2);
  }

  :global(.status-pill.pending) {
    background: rgba(255, 173, 51, 0.1);
    color: #ffad33;
    border: 1px solid rgba(255, 173, 51, 0.2);
  }

  :global(.status-pill.pending .pill-icon) {
    background: rgba(255, 173, 51, 0.18);
  }

  :global(.users-empty) {
    padding: 1.5rem;
    color: var(--muted);
  }

  :global(.users-table) {
    width: 100%;
    border-collapse: collapse;
    min-width: 700px;
    table-layout: fixed;
  }

  :global(.users-table th),
  :global(.users-table td) {
    padding: 1rem 1.2rem;
    text-align: left;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--text);
    vertical-align: middle;
    white-space: nowrap;
  }

  :global(.users-table tbody tr:last-child td) {
    border-bottom: none;
  }

  :global(.users-table th) {
    background: rgba(124, 92, 252, 0.07);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  :global(.users-table th:nth-child(1)),
  :global(.users-table td:nth-child(1)) {
    width: 80px;
    text-align: center;
  }

  :global(.users-table th:nth-child(2)),
  :global(.users-table td:nth-child(2)) {
    width: 20%;
  }

  :global(.users-table th:nth-child(3)),
  :global(.users-table td:nth-child(3)) {
    width: 35%;
  }

  :global(.users-table th:nth-child(4)),
  :global(.users-table td:nth-child(4)) {
    width: 160px;
  }

  :global(.users-table th:nth-child(5)),
  :global(.users-table td:nth-child(5)) {
    width: 160px;
  }

  :global(.users-table tbody tr:hover) {
    background: rgba(124, 92, 252, 0.06);
  }

  .users-total strong {
    color: var(--text);
  }

  @media (max-width: 900px) {
    .add-user-grid {
      grid-template-columns: 1fr;
    }

    .summary-row {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 560px) {
    .users-card {
      border-radius: 22px;
      padding: 1.1rem;
    }
  }

  .table-scroll-hint {
    margin-top: 0.7rem;
    color: var(--muted);
    font-size: 0.8rem;
  }
</style>

<MainLayout page="users">
  <section class="users-shell">
    <div class="users-card">
      <div class="users-head">
        <p class="eyebrow">User Management</p>
        <h1>Add User</h1>
        <p class="users-copy">
          Create a user directly in the database and review the full list below.
          Manage users, review account details, and monitor verification status — all in one responsive dashboard.

        </p>
      </div>

      <div class="add-user-grid">
        <div class="field-block">
          <label for="name">Full Name</label>
          <div class="input-wrap">
            <input id="name" placeholder="Name" />
            <span class="input-icon">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M20 21a8 8 0 0 0-16 0"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
            </span>
          </div>
        </div>
        <div class="field-block">
          <label for="email">Email Address</label>
          <div class="input-wrap">
            <input id="email" placeholder="Email" />
            <span class="input-icon">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="3" y="5" width="18" height="14" rx="2"></rect>
                <path d="m3 7 9 6 9-6"></path>
              </svg>
            </span>
          </div>
        </div>
        <div class="field-block">
          <label for="password">Password</label>
          <div class="password-wrap">
            <input id="password" placeholder="Password" type="password" />
            <button
              id="togglePassword"
              class="password-toggle"
              type="button"
              aria-label="Show password"
            >
              <svg
                id="passwordIcon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
            </button>
          </div>
        </div>
        <button id="addBtn" class="btn">Add User</button>
      </div>

      <div class="summary-row">
        <div class="users-total">
          Total Users: <strong id="totalUsers">0</strong>
        </div>
        <div id="usersMessage"></div>
      </div>

      <div id="users" class="table-wrap"></div>
      <div class="table-scroll-hint">
        Scroll horizontally if needed to view all columns.
      </div>
    </div>
  </section>

  <script>
    const API_BASE = "http://localhost:5001/api";
    const token = localStorage.getItem("token");

    if (!token) {
      window.location.href = "/login";
    }

    async function fetchUsers() {
      try {
        const headers = token
          ? { Authorization: `Bearer ${token}` }
          : undefined;
        const res = await fetch(`${API_BASE}/users`, { headers });
        if (!res.ok) return console.error("Failed to load users");
        const data = await res.json();
        const usersEl = document.getElementById("users");
        const totalUsersEl = document.getElementById("totalUsers");
        if (!usersEl) return;

        const users = data?.users || [];
        if (totalUsersEl) totalUsersEl.textContent = String(users.length);

        if (!users.length) {
          usersEl.innerHTML =
            '<div class="users-empty">No users found in the database.</div>';
          return;
        }

        const table = document.createElement("table");
        table.className = "users-table";
        table.innerHTML = `
          <thead>
            <tr>
              <th>
                <span class="th-inner">
                  <span class="th-hash">#</span>
                </span>
              </th>
              <th>
                <span class="th-inner">
                  <span class="th-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M20 21a8 8 0 0 0-16 0"></path>
                      <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                  </span>
                  <span class="th-label">Full Name</span>
                </span>
              </th>
              <th>
                <span class="th-inner">
                  <span class="th-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="3" y="5" width="18" height="14" rx="2"></rect>
                      <path d="m3 7 9 6 9-6"></path>
                    </svg>
                  </span>
                  <span class="th-label">Email</span>
                </span>
              </th>
              <th>
                <span class="th-inner">
                  <span class="th-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="3" y="4" width="18" height="18" rx="2"></rect>
                      <path d="M8 2v4"></path>
                      <path d="M16 2v4"></path>
                      <path d="M3 10h18"></path>
                    </svg>
                  </span>
                  <span class="th-label">Date Joined</span>
                </span>
              </th>
              <th>
                <span class="th-inner">
                  <span class="th-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 2l7 4v6c0 5-3.5 9.7-7 10-3.5-.3-7-5-7-10V6l7-4z"></path>
                      <path d="M9 12l2 2 4-4"></path>
                    </svg>
                  </span>
                  <span class="th-label">Status</span>
                </span>
              </th>
            </tr>
          </thead>
          <tbody></tbody>
        `;

        const tbody = table.querySelector("tbody");
        users.forEach((u, idx) => {
          const tr = document.createElement("tr");
          const date = u.createdAt
            ? new Date(u.createdAt).toLocaleDateString()
            : "-";
          const statusClass = u.is_verified ? "verified" : "pending";
          tr.innerHTML = `
            <td style="text-align:center;">${idx + 1}</td>
            <td>${u.name}</td>
            <td>${u.email}</td>
            <td>${date}</td>
            <td>
              <span class="status-pill ${statusClass}">
                <span class="pill-icon">
                  ${
                    u.is_verified
                      ? `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M20 6L9 17l-5-5"></path>
                        </svg>`
                      : `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <circle cx="12" cy="12" r="9"></circle>
                          <path d="M12 8v4l2 2"></path>
                        </svg>`
                  }
                </span>
                <span>${u.is_verified ? "Verified" : "Pending"}</span>
              </span>
            </td>
          `;
          tbody.appendChild(tr);
        });

        usersEl.innerHTML = "";
        usersEl.appendChild(table);
      } catch (err) {
        console.error(err);
      }
    }

    async function addUser() {
      const nameEl = document.getElementById("name") as HTMLInputElement | null;
      const emailEl = document.getElementById(
        "email",
      ) as HTMLInputElement | null;
      const passwordEl = document.getElementById(
        "password",
      ) as HTMLInputElement | null;
      if (!nameEl || !emailEl || !passwordEl)
        return alert("All fields required");

      const name = nameEl.value.trim();
      const email = emailEl.value.trim();
      const password = passwordEl.value;
      if (!name || !email || !password) return alert("All fields required");

      try {
        const res = await fetch(`${API_BASE}/users`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${token}`,
          },
          body: JSON.stringify({ name, email, password }),
        });
        const data = await res.json();
        if (!res.ok) return alert(data.message || "Create failed");
        nameEl.value = "";
        emailEl.value = "";
        passwordEl.value = "";
        alert("OTP sent to email. Verify it to add the user to the list.");
        window.location.href = `/verify-otp?email=${encodeURIComponent(email)}`;
      } catch (err) {
        console.error(err);
      }
    }

    const togglePassword = document.getElementById("togglePassword");
    const passwordInput = document.getElementById("password");
    const passwordIcon = document.getElementById("passwordIcon");
    if (togglePassword && passwordInput instanceof HTMLInputElement) {
      togglePassword.addEventListener("click", () => {
        const visible = passwordInput.type === "text";
        passwordInput.type = visible ? "password" : "text";
        if (passwordIcon) {
          passwordIcon.innerHTML = visible
            ? '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle>'
            : '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line>';
        }
        togglePassword.setAttribute(
          "aria-label",
          visible ? "Show password" : "Hide password",
        );
      });
    }
    document.getElementById("addBtn")?.addEventListener("click", addUser);
    fetchUsers();
  </script>
</MainLayout>
