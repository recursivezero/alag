---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import AdminShell from "../../../components/admin/AdminShell.astro";
import UserFilters from "../../../components/admin/UserFilters.astro";
import UsersTable from "../../../components/admin/UsersTable.astro";
---

<style is:global>
  .toast-region {
    position: fixed;
    top: 20px;
    right: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: 360px;
    z-index: 99999;
    pointer-events: none;
  }

  .admin-toast {
    pointer-events: auto;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    border-radius: 12px;
    background: #1e2235;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
    opacity: 0;
    transform: translateX(50px);
    transition:
      opacity 300ms ease,
      transform 300ms ease;
    position: relative;
  }

  .admin-toast[data-state="open"] {
    opacity: 1;
    transform: translateX(0);
  }

  .admin-toast[data-state="closing"] {
    opacity: 0;
    transform: translateX(50px);
  }

  .admin-toast__icon {
    flex: 0 0 auto;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .admin-toast--success-enable .admin-toast__icon {
    background: rgba(34, 197, 94, 0.15);
    color: #22c55e;
    border: 1.5px solid rgba(34, 197, 94, 0.35);
  }

  .admin-toast--success-disable .admin-toast__icon {
    background: rgba(249, 115, 22, 0.15);
    color: #f97316;
    border: 1.5px solid rgba(249, 115, 22, 0.35);
  }

  .admin-toast--destructive .admin-toast__icon {
    background: rgba(239, 68, 68, 0.15);
    color: #ef4444;
    border: 1.5px solid rgba(239, 68, 68, 0.35);
  }

  .admin-toast__content {
    flex: 1;
    min-width: 0;
  }

  .admin-toast__title {
    margin: 0;
    font-size: 14px;
    font-weight: 600;
    color: #f1f5f9;
    line-height: 1.3;
  }

  .admin-toast__description {
    margin: 3px 0 0;
    font-size: 13px;
    color: rgba(148, 163, 184, 0.85);
    line-height: 1.45;
  }

  .admin-toast__close {
    flex: 0 0 auto;
    width: 26px;
    height: 26px;
    border: none;
    background: transparent;
    color: rgba(148, 163, 184, 0.6);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    transition:
      color 150ms ease,
      background 150ms ease;
    padding: 0;
    align-self: flex-start;
    margin-top: 1px;
  }

  .admin-toast__close:hover {
    color: #f1f5f9;
    background: rgba(255, 255, 255, 0.1);
  }

  @media (max-width: 640px) {
    .toast-region {
      width: calc(100vw - 32px);
      right: 16px;
      top: 16px;
    }
  }
</style>

<AdminLayout title="Users | RecursiveAuth">
  <AdminShell
    active="users"
    title="Users"
    eyebrow="User Management"
    description="View and manage all registered users. You can enable, disable, or delete users based on their status."
    searchPlaceholder="Search users..."
    searchId="topSearch"
    showAddUserAction={true}
  >
    <div class="mt-4 space-y-4">
      <UserFilters totalId="totalUsers" />

      <div
        id="deleteConfirmCard"
        class="hidden rounded-[10px] border border-rose-400/18 bg-[linear-gradient(180deg,rgba(56,14,23,0.8),rgba(18,9,18,0.86))] p-4 shadow-[0_18px_44px_rgba(0,0,0,0.24)]"
      >
        <div
          class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between"
        >
          <div>
            <p
              class="text-[11px] font-semibold uppercase tracking-[0.24em] text-rose-200/90"
            >
              Delete Confirmation
            </p>
            <h2
              class="mt-1 text-lg font-semibold tracking-[-0.03em] text-white"
            >
              Are you sure you want to permanently delete this user?
            </h2>
            <p
              id="deleteConfirmMeta"
              class="mt-2 text-sm leading-6 text-slate-300/76"
            >
              This action cannot be undone.
            </p>
          </div>

          <div class="flex flex-wrap items-center gap-2">
            <button
              id="cancelDelete"
              type="button"
              class="inline-flex h-11 items-center justify-center rounded-2xl border border-white/10 bg-white/5 px-4 text-sm font-semibold text-slate-100 transition hover:border-violet-400/30 hover:bg-violet-500/10"
            >
              Cancel
            </button>
            <button
              id="confirmDelete"
              type="button"
              class="inline-flex h-11 items-center justify-center rounded-2xl border border-rose-400/35 bg-[linear-gradient(135deg,rgba(92,16,30,0.92),rgba(45,7,18,0.92))] px-4 text-sm font-semibold text-rose-100 shadow-[0_0_24px_rgba(244,63,94,0.16)] transition hover:-translate-y-0.5 hover:shadow-[0_0_32px_rgba(244,63,94,0.28)]"
            >
              Delete Permanently
            </button>
          </div>
        </div>
      </div>

      <UsersTable variant="users" />
    </div>

    <div id="toastRegion" class="toast-region"></div>
  </AdminShell>
</AdminLayout>

<script>
  type AdminUser = {
    id: number;
    fullName: string;
    email: string;
    createdAt: string;
    isDisabled: boolean;
  };

  const apiBase = (() => {
    const configured = import.meta.env.PUBLIC_API_BASE_URL?.trim();
    if (configured) return configured.replace(/\/$/, "");
    return `${window.location.protocol}//${window.location.hostname}:5001/api`;
  })();

  const pageSize = 5;

  const state: {
    users: AdminUser[];
    search: string;
    status: "all" | "enabled" | "disabled";
    page: number;
    loading: boolean;
    deletedCount: number;
    pendingDelete: AdminUser | null;
  } = {
    users: [],
    search: "",
    status: "all",
    page: 1,
    loading: true,
    deletedCount: 0,
    pendingDelete: null,
  };

  const redirectToLogin = () => {
    window.location.href = "/admin";
  };

  const escapeHtml = (value: string) =>
    value
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/\"/g, "&quot;")
      .replace(/'/g, "&#39;");

  const formatDate = (value: string) =>
    new Intl.DateTimeFormat("en-US", {
      month: "short",
      day: "numeric",
      year: "numeric",
    }).format(new Date(value));

  const setText = (id: string, value: string | number) => {
    const el = document.getElementById(id);
    if (el) el.textContent = String(value);
  };

  type ToastVariant = "success-enable" | "success-disable" | "destructive";

  const toastIcons: Record<ToastVariant, string> = {
    "success-enable": `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>`,
    "success-disable": `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M15 9l-6 6"/><path d="M9 9l6 6"/></svg>`,
    destructive: `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M8 6V4h8v2"/><path d="M6 6l1 14h10l1-14"/><path d="M10 11v5"/><path d="M14 11v5"/></svg>`,
  };

  const showToast = (options: {
    title: string;
    description?: string;
    variant?: ToastVariant;
  }) => {
    const region = document.getElementById("toastRegion");
    if (!region) return;

    const variant = options.variant ?? "success-enable";

    while (region.childElementCount >= 3) {
      region.lastElementChild?.remove();
    }

    const toast = document.createElement("div");
    toast.className = `admin-toast admin-toast--${variant}`;
    toast.setAttribute("role", "status");
    toast.setAttribute("aria-live", "polite");
    toast.setAttribute("aria-atomic", "true");

    const iconEl = document.createElement("div");
    iconEl.className = "admin-toast__icon";
    iconEl.innerHTML = toastIcons[variant];

    const contentEl = document.createElement("div");
    contentEl.className = "admin-toast__content";

    const titleEl = document.createElement("p");
    titleEl.className = "admin-toast__title";
    titleEl.textContent = options.title;
    contentEl.appendChild(titleEl);

    if (options.description) {
      const descEl = document.createElement("p");
      descEl.className = "admin-toast__description";
      descEl.textContent = options.description;
      contentEl.appendChild(descEl);
    }

    const closeBtn = document.createElement("button");
    closeBtn.type = "button";
    closeBtn.className = "admin-toast__close";
    closeBtn.setAttribute("aria-label", "Dismiss");
    closeBtn.innerHTML = `<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="M6 6l12 12"/></svg>`;

    closeBtn.addEventListener("click", () => {
      toast.dataset.state = "closing";
      setTimeout(() => toast.remove(), 300);
    });

    toast.append(iconEl, contentEl, closeBtn);
    region.prepend(toast);

    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        toast.dataset.state = "open";
      });
    });
  };

  const getFilteredUsers = () => {
    const search = state.search.trim().toLowerCase();
    return state.users.filter((user) => {
      const matchesStatus =
        state.status === "all" ||
        (state.status === "enabled" && !user.isDisabled) ||
        (state.status === "disabled" && user.isDisabled);
      const matchesSearch =
        !search ||
        user.fullName.toLowerCase().includes(search) ||
        user.email.toLowerCase().includes(search);
      return matchesStatus && matchesSearch;
    });
  };

  const syncSearchInputs = (value: string) => {
    ["topSearch", "searchInput"].forEach((id) => {
      const el = document.getElementById(id) as HTMLInputElement | null;
      if (el && el.value !== value) el.value = value;
    });
  };

  const renderStats = () => {
    const total = state.users.length;
    const active = state.users.filter((u) => !u.isDisabled).length;
    const disabled = state.users.filter((u) => u.isDisabled).length;
    setText("statTotalUsers", total);
    setText("statActiveUsers", active);
    setText("statDisabledUsers", disabled);
    setText("statDeletedUsers", state.deletedCount);
    setText("totalUsers", total);
  };

  const renderDeleteConfirm = () => {
    const card = document.getElementById("deleteConfirmCard");
    const meta = document.getElementById("deleteConfirmMeta");
    const pending = state.pendingDelete;
    if (!card || !meta) return;
    if (!pending) {
      card.classList.add("hidden");
      meta.textContent = "This action cannot be undone.";
      return;
    }
    card.classList.remove("hidden");
    meta.textContent = `${pending.fullName} (${pending.email}) will be removed permanently.`;
  };

  const renderPagination = (count: number) => {
    const pagination = document.getElementById("pagination");
    if (!pagination) return;

    const totalPages = Math.max(1, Math.ceil(Math.max(1, count) / pageSize));
    if (state.page > totalPages) state.page = totalPages;
    if (count === 0) state.page = 1;

    const createButton = (
      label: string,
      page: number,
      disabled = false,
      active = false,
    ) => {
      const isLight = document.documentElement.dataset.adminTheme === "light";
      const activeCls =
        "border-violet-400/40 bg-violet-500/20 text-white shadow-[0_0_20px_rgba(124,92,252,0.24)]";
      const inactiveCls = isLight
        ? "border-[#e6eef8]/30 bg-white text-[#0f172a] hover:border-violet-400/30 hover:bg-violet-500/10"
        : "border-white/10 bg-white/5 text-slate-200 hover:border-violet-400/30 hover:bg-violet-500/10";
      const disabledCls = disabled ? "cursor-not-allowed opacity-40" : "";
      return `<button type="button" data-page="${page}" ${disabled ? "disabled" : ""} class="inline-flex h-10 min-w-10 items-center justify-center rounded-xl border text-[13px] font-semibold transition ${active ? activeCls : inactiveCls} ${disabledCls}">${label}</button>`;
    };

    const pages = Array.from({ length: totalPages }, (_, i) => {
      const p = i + 1;
      return createButton(String(p), p, false, p === state.page);
    }).join("");

    const prevIcon = `<svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"></path></svg>`;
    const nextIcon = `<svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 6 6 6-6 6"></path></svg>`;

    pagination.innerHTML = `
      ${createButton(prevIcon, Math.max(1, state.page - 1), state.page <= 1)}
      ${pages}
      ${createButton(nextIcon, Math.min(totalPages, state.page + 1), state.page >= totalPages)}
    `;

    pagination
      .querySelectorAll<HTMLButtonElement>("[data-page]")
      .forEach((btn) => {
        btn.addEventListener("click", () => {
          if (btn.disabled) return;
          state.page = Number(btn.dataset.page || "1");
          renderUsers();
        });
      });
  };

  const renderUsers = () => {
    const body = document.getElementById("usersTableBody");
    const meta = document.getElementById("tableMeta");
    if (!body || !meta) return;

    renderStats();
    renderDeleteConfirm();

    const filteredUsers = getFilteredUsers();
    const total = filteredUsers.length;
    const totalPages = Math.max(1, Math.ceil(Math.max(1, total) / pageSize));
    if (state.page > totalPages) state.page = totalPages;

    const start = (state.page - 1) * pageSize;
    const visibleUsers = filteredUsers.slice(start, start + pageSize);

    if (state.loading) {
      body.innerHTML = `<tr><td colspan="6" class="px-4 py-14 text-center text-[13px] text-slate-400">Loading users...</td></tr>`;
      meta.textContent = "Showing 0 users";
      renderPagination(0);
      return;
    }

    if (!visibleUsers.length) {
      body.innerHTML = `<tr><td colspan="6" class="px-4 py-14 text-center text-[13px] text-slate-400">No users found.</td></tr>`;
      meta.textContent = "Showing 0 of 0 users";
      renderPagination(total);
      return;
    }

    body.innerHTML = visibleUsers
      .map((user, index) => {
        const enabled = !user.isDisabled;
        const statusBadge = enabled
          ? `<span class="inline-flex items-center gap-2 rounded-[5px] border border-green-400/25 bg-green-400/25 px-3 py-1 text-[12px] font-semibold text-green-500 shadow-[0_0_16px_rgba(16,185,129,0.15)]">
              <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"></path></svg>
              Enabled
            </span>`
          : `<span class="inline-flex items-center gap-2 rounded-[5px] border border-rose-400/25 bg-rose-500/12 px-3 py-1 text-[12px] font-semibold text-red-500 shadow-[0_0_16px_rgba(244,63,94,0.15)]">
              <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"></circle><path d="M12 8v5"></path><path d="M12 16h.01"></path></svg>
              Disabled
            </span>`;

        const primaryAction = enabled
          ? `<button type="button" class="inline-flex h-9 items-center justify-center gap-2 rounded-[5px] border border-orange-400/25 bg-orange-500/12 px-3 text-[12px] font-semibold text-orange-500 transition hover:-translate-y-0.5 hover:border-orange-500 hover:bg-orange-400/25 hover:shadow-[0_0_18px_rgba(251,146,60,0.16)]" data-action="disable" data-id="${user.id}"><i class="fa-solid fa-circle-xmark" aria-hidden="true"></i><span>Disable</span></button>`
          : `<button type="button" class="inline-flex h-9 items-center justify-center gap-2 rounded-[5px] border border-green-400/25 bg-green-400/25 px-3 text-[12px] font-semibold text-green-500 transition hover:-translate-y-0.5 hover:border-emerald-300/55 hover:bg-emerald-400/24 hover:shadow-[0_0_18px_rgba(34,197,94,0.18)]" data-action="enable" data-id="${user.id}"><i class="fa-solid fa-circle-check" aria-hidden="true"></i><span>Enable</span></button>`;

        return `
          <tr>
            <td class="px-4 py-4 text-[14px] text-slate-300/85">${start + index + 1}</td>
            <td class="px-4 py-4 text-[14px] font-medium text-white">${escapeHtml(user.fullName)}</td>
            <td class="px-4 py-4 text-[14px] text-slate-200/88">${escapeHtml(user.email)}</td>
            <td class="px-4 py-4 text-[14px] text-slate-300/85">${formatDate(user.createdAt)}</td>
            <td class="px-4 py-4">${statusBadge}</td>
            <td class="px-4 py-4 text-center align-middle">
              <div class="inline-flex items-center gap-2 whitespace-nowrap">
                ${primaryAction}
                <button type="button" class="inline-flex h-9 items-center justify-center gap-2 rounded-[5px] border border-red-500/40 bg-red-500/10 px-3 text-[12px] font-semibold text-red-500 transition hover:-translate-y-0.5 hover:border-red-400/60 hover:bg-red-500/220 hover:shadow-[0_0_18px_rgba(244,63,94,0.16)]" data-action="delete" data-id="${user.id}"><i class="fa-solid fa-trash-can" aria-hidden="true"></i><span>Delete</span></button>
              </div>
            </td>
          </tr>
        `;
      })
      .join("");

    meta.textContent = `Showing ${start + 1} to ${Math.min(total, start + visibleUsers.length)} of ${total} users`;
    renderPagination(total);
  };

  const setPanelOpen = (open: boolean) => {
    const modal = document.getElementById("addUserModal");
    const card = document.getElementById("addUserCard");
    if (!modal) return;
    modal.classList.toggle("opacity-100", open);
    modal.classList.toggle("pointer-events-auto", open);
    modal.classList.toggle("opacity-0", !open);
    modal.classList.toggle("pointer-events-none", !open);
    modal.setAttribute("aria-hidden", String(!open));
    if (card) {
      card.classList.toggle("scale-100", open);
      card.classList.toggle("opacity-100", open);
      card.classList.toggle("scale-95", !open);
      card.classList.toggle("opacity-0", !open);
    }
  };

  const openPanel = () => setPanelOpen(true);
  const closePanel = () => {
    const messageEl = document.getElementById("formMessage");
    if (messageEl) {
      messageEl.textContent = "";
      messageEl.className = "min-h-5 text-[13px] text-slate-300";
    }
    setPanelOpen(false);
  };

  const submitAddUser = async (event: SubmitEvent) => {
    event.preventDefault();
    const fullNameEl = document.getElementById(
      "fullName",
    ) as HTMLInputElement | null;
    const emailEl = document.getElementById("email") as HTMLInputElement | null;
    const passwordEl = document.getElementById(
      "password",
    ) as HTMLInputElement | null;
    const verificationMethodEl = document.querySelector(
      'input[name="verificationMethod"]:checked',
    ) as HTMLInputElement | null;
    const messageEl = document.getElementById("formMessage");
    const submitBtn = document.getElementById(
      "submitAdd",
    ) as HTMLButtonElement | null;

    if (
      !fullNameEl ||
      !emailEl ||
      !passwordEl ||
      !verificationMethodEl ||
      !messageEl ||
      !submitBtn
    )
      return;

    const fullName = fullNameEl.value.trim();
    const email = emailEl.value.trim();
    const password = passwordEl.value;

    if (!fullName || !email || !password) {
      messageEl.textContent = "All fields are required.";
      messageEl.className = "min-h-5 text-[13px] text-rose-300";
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = "Adding...";

    try {
      const res = await fetch(`${apiBase}/admin/users`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        credentials: "include",
        body: JSON.stringify({
          fullName,
          email,
          password,
          verificationMethod: verificationMethodEl.value,
        }),
      });

      const data = await res.json();
      if (res.status === 401) {
        redirectToLogin();
        return;
      }
      if (!res.ok) {
        messageEl.textContent = data?.message || "Unable to create user.";
        messageEl.className = "min-h-5 text-[13px] text-rose-300";
        return;
      }

      if (data?.user) state.users.unshift(data.user as AdminUser);
      state.page = 1;
      fullNameEl.value = "";
      emailEl.value = "";
      passwordEl.value = "";
      verificationMethodEl.checked = true;
      messageEl.textContent = "";
      showToast({
        title:
          data?.verificationMethod === "otp"
            ? "OTP sent to the user's email"
            : "User created successfully",
        description:
          data?.verificationMethod === "otp"
            ? "The user can complete verification from their inbox."
            : "The new user has been added to the workspace.",
        variant: "success-enable",
      });
      closePanel();
      renderUsers();
    } catch {
      messageEl.textContent = "Unable to create user.";
      messageEl.className = "min-h-5 text-[13px] text-rose-300";
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "Add User";
    }
  };

  const updateUserStatus = async (id: number, action: "enable" | "disable") => {
    try {
      const res = await fetch(`${apiBase}/admin/users/${id}/${action}`, {
        method: "PATCH",
        credentials: "include",
      });
      const data = await res.json();
      if (res.status === 401) {
        redirectToLogin();
        return;
      }
      if (!res.ok) {
        showToast({
          title: data?.message || `Unable to ${action} user.`,
          variant: "destructive",
        });
        return;
      }
      state.users = state.users.map((u) =>
        u.id === id ? { ...u, isDisabled: action === "disable" } : u,
      );
      renderUsers();
      showToast(
        action === "disable"
          ? {
              title: "User disabled successfully",
              description: "The user account has been disabled.",
              variant: "success-disable",
            }
          : {
              title: "User enabled successfully",
              description: "The user account is now active.",
              variant: "success-enable",
            },
      );
    } catch {
      redirectToLogin();
    }
  };

  const deleteUser = async () => {
    if (!state.pendingDelete) return;
    const user = state.pendingDelete;
    try {
      const res = await fetch(`${apiBase}/admin/users/${user.id}`, {
        method: "DELETE",
        credentials: "include",
      });
      const data = await res.json();
      if (res.status === 401) {
        redirectToLogin();
        return;
      }
      if (!res.ok) {
        showToast({
          title: data?.message || "Unable to delete user.",
          variant: "destructive",
        });
        return;
      }
      state.users = state.users.filter((e) => e.id !== user.id);
      state.deletedCount = Number(data.deletedUsers || state.deletedCount + 1);
      state.pendingDelete = null;
      showToast({
        title: "User deleted successfully",
        description: "The user has been permanently removed.",
        variant: "destructive",
      });
      renderUsers();
    } catch {
      redirectToLogin();
    }
  };

  const handleTableAction = async (target: EventTarget | null) => {
    if (!(target instanceof Element)) return;
    const button = target.closest<HTMLButtonElement>("button[data-action]");
    if (!button) return;
    const action = button.dataset.action as
      | "enable"
      | "disable"
      | "delete"
      | undefined;
    const id = Number(button.dataset.id || "0");
    if (!action || !Number.isInteger(id) || id <= 0) return;
    const selected = state.users.find((u) => u.id === id) || null;
    if (action === "delete") {
      state.pendingDelete = selected;
      renderDeleteConfirm();
      return;
    }
    if (!selected) return;
    await updateUserStatus(id, action);
  };

  const updateSearch = (value: string) => {
    state.search = value;
    syncSearchInputs(value);
    state.page = 1;
    renderUsers();
  };

  const loadUsers = async () => {
    state.loading = true;
    renderUsers();
    try {
      const res = await fetch(`${apiBase}/admin/users`, {
        credentials: "include",
      });
      if (res.status === 401) {
        redirectToLogin();
        return;
      }
      const data = await res.json();
      state.users = (data.users || []) as AdminUser[];
      state.deletedCount = Number(data.deletedUsers || 0);
      state.loading = false;
      state.page = 1;
      renderUsers();
    } catch {
      redirectToLogin();
    }
  };

  document.getElementById("searchInput")?.addEventListener("input", (e) => {
    updateSearch((e.target as HTMLInputElement).value);
  });
  document.getElementById("statusFilter")?.addEventListener("change", (e) => {
    state.status = (e.target as HTMLSelectElement).value as
      | "all"
      | "enabled"
      | "disabled";
    state.page = 1;
    renderUsers();
  });
  document.getElementById("addUserBtn")?.addEventListener("click", openPanel);
  document
    .getElementById("closeAddUserModal")
    ?.addEventListener("click", closePanel);
  document.getElementById("cancelAdd")?.addEventListener("click", closePanel);
  document
    .getElementById("addUserBackdrop")
    ?.addEventListener("click", closePanel);
  document
    .getElementById("addUserForm")
    ?.addEventListener("submit", submitAddUser);
  document.getElementById("usersTableBody")?.addEventListener("click", (e) => {
    handleTableAction(e.target);
  });
  document.getElementById("cancelDelete")?.addEventListener("click", () => {
    state.pendingDelete = null;
    renderDeleteConfirm();
  });
  document
    .getElementById("confirmDelete")
    ?.addEventListener("click", deleteUser);

  loadUsers();
</script>
