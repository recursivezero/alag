---
import AdminLayout from "../../../../layouts/AdminLayout.astro";
import AdminShell from "../../../../components/admin/AdminShell.astro";
---

<AdminLayout title="Add User | RecursiveAuth">
  <AdminShell
    active="add-user"
    title="Add User"
    eyebrow="User Management"
    description="Create a new user by filling in the details below."
    showSearch={false}
    showNotifications={false}
    showThemeToggle={true}
    showAddUserAction={false}
  >
    <div
      class="add-user-page mx-auto flex min-h-[calc(100vh-220px)] max-w-[760px] items-start justify-center px-4 pb-10 pt-6 sm:px-6 lg:pt-8"
    >
      <section
        class="add-user-card w-full max-w-[440px] rounded-[28px] border border-white/10 bg-[linear-gradient(180deg,rgba(10,14,30,0.98),rgba(6,10,22,0.98))] p-7 shadow-[0_32px_80px_rgba(0,0,0,0.55)] sm:p-8"
      >
        <div class="mb-6">
          <p
            class="add-user-eyebrow text-[11px] font-semibold uppercase tracking-[0.28em] text-violet-300/90"
          >
            User Management
          </p>
          <h2
            class="add-user-title mt-1 text-[2rem] font-extrabold tracking-[-0.05em] text-white"
          >
            Add User
          </h2>
          <p
            class="add-user-subtitle mt-1.5 text-[13px] leading-6 text-slate-400/85"
          >
            Create a new user by filling in the details below.
          </p>
        </div>

        <form id="addUserForm" class="flex flex-col gap-5">
          <div class="space-y-2">
            <label
              class="add-user-label block text-[12px] font-bold uppercase tracking-[0.06em] text-white"
            >
              Full Name
            </label>
            <div class="relative">
              <input
                id="fullName"
                name="fullName"
                type="text"
                placeholder="Name"
                autocomplete="name"
                required
                class="add-user-input h-[52px] w-full rounded-[14px] border border-white/12 bg-white/4 px-4 pr-11 text-[14px] text-white placeholder:text-slate-500 outline-none transition focus:border-violet-400/55 focus:bg-white/6 focus:shadow-[0_0_0_1px_rgba(129,92,255,0.18),0_0_24px_rgba(124,92,255,0.12)]"
              />
              <span
                class="add-user-icon pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-slate-500"
              >
                <svg
                  viewBox="0 0 24 24"
                  class="h-5 w-5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                >
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                  <circle cx="12" cy="7" r="4"></circle>
                </svg>
              </span>
            </div>
          </div>

          <div class="space-y-2">
            <label
              class="add-user-label block text-[12px] font-bold uppercase tracking-[0.06em] text-white"
            >
              Email Address
            </label>
            <div class="relative">
              <input
                id="email"
                name="email"
                type="email"
                placeholder="Email"
                autocomplete="email"
                required
                class="add-user-input h-[52px] w-full rounded-[14px] border border-white/12 bg-white/4 px-4 pr-11 text-[14px] text-white placeholder:text-slate-500 outline-none transition focus:border-violet-400/55 focus:bg-white/6 focus:shadow-[0_0_0_1px_rgba(129,92,255,0.18),0_0_24px_rgba(124,92,255,0.12)]"
              />
              <span
                class="add-user-icon pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-slate-500"
              >
                <svg
                  viewBox="0 0 24 24"
                  class="h-5 w-5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                >
                  <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                </svg>
              </span>
            </div>
            <p
              id="emailStatus"
              class="add-user-status min-h-5 text-[12px] leading-5 text-slate-400"
            >
            </p>
          </div>

          <div class="space-y-2">
            <label
              class="add-user-label block text-[12px] font-bold uppercase tracking-[0.06em] text-white"
            >
              Phone Number (Optional)
            </label>
            <div class="relative">
              <input
                id="phoneNumber"
                name="phoneNumber"
                type="tel"
                placeholder="Phone Number"
                autocomplete="tel"
                inputmode="tel"
                class="add-user-input h-[52px] w-full rounded-[14px] border border-white/12 bg-white/4 px-4 pr-11 text-[14px] text-white placeholder:text-slate-500 outline-none transition focus:border-violet-400/55 focus:bg-white/6 focus:shadow-[0_0_0_1px_rgba(129,92,255,0.18),0_0_24px_rgba(124,92,255,0.12)]"
              />
              <span
                class="add-user-icon pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-slate-500"
              >
                <svg
                  viewBox="0 0 24 24"
                  class="h-5 w-5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path
                    d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.4 19.4 0 0 1-6-6A19.8 19.8 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.89.34 1.76.66 2.59a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.49-1.18a2 2 0 0 1 2.11-.45c.83.32 1.7.54 2.59.66A2 2 0 0 1 22 16.92Z"
                  ></path>
                </svg>
              </span>
            </div>
          </div>

          <div class="space-y-2">
            <label
              class="add-user-label block text-[12px] font-bold uppercase tracking-[0.06em] text-white"
            >
              Password
            </label>
            <div class="relative">
              <input
                id="password"
                name="password"
                type="password"
                placeholder="Password"
                autocomplete="new-password"
                required
                class="add-user-input h-[52px] w-full rounded-[14px] border border-white/12 bg-white/4 px-4 pr-11 text-[14px] text-white placeholder:text-slate-500 outline-none transition focus:border-violet-400/55 focus:bg-white/6 focus:shadow-[0_0_0_1px_rgba(129,92,255,0.18),0_0_24px_rgba(124,92,255,0.12)]"
              />
              <button
                type="button"
                id="togglePassword"
                class="add-user-icon absolute right-4 top-1/2 -translate-y-1/2 text-slate-500 transition hover:text-slate-300"
                aria-label="Toggle password visibility"
              >
                <svg
                  viewBox="0 0 24 24"
                  class="h-5 w-5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                >
                  <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path>
                  <circle cx="12" cy="12" r="3"></circle>
                </svg>
              </button>
            </div>
          </div>

          <div class="space-y-3">
            <label
              class="add-user-label block text-[12px] font-bold uppercase tracking-[0.06em] text-white"
            >
              Verification Method
            </label>
            <div class="flex flex-col gap-4">
              <label class="group flex cursor-pointer items-start gap-3">
                <span
                  class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center"
                >
                  <input
                    id="verificationOtp"
                    type="radio"
                    name="verificationMethod"
                    value="otp"
                    checked
                    class="peer sr-only"
                  />
                  <span
                    class="flex h-5 w-5 items-center justify-center rounded-full border border-white/40 bg-transparent transition peer-checked:border-white peer-checked:bg-violet-500 peer-checked:shadow-[0_0_0_1px_rgba(255,255,255,0.9)]"
                  >
                    <span
                      class="h-2.5 w-2.5 rounded-full bg-white opacity-0 transition peer-checked:opacity-100"
                    ></span>
                  </span>
                </span>
                <span
                  class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-violet-300/20 bg-[radial-gradient(circle_at_top,rgba(168,139,255,0.22),rgba(30,20,70,0.92))] shadow-[0_0_18px_rgba(124,92,252,0.16)]"
                >
                  <span
                    class="flex h-10 w-10 items-center justify-center rounded-full border border-white/6 bg-[linear-gradient(180deg,rgba(20,24,48,0.9),rgba(13,16,34,0.96))]"
                  >
                    <svg
                      viewBox="0 0 24 24"
                      class="h-6 w-6 text-white"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.9"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"
                      ></path>
                    </svg>
                  </span>
                </span>
                <span class="min-w-0 pt-0.5">
                  <span
                    class="add-user-verification-title block text-left text-[16px] font-semibold leading-[1.15] tracking-[-0.02em] text-white"
                  >
                    Verify by OTP
                  </span>
                  <span
                    class="add-user-verification-desc mt-1 block text-left text-[13px] leading-[1.45] text-slate-400/90"
                  >
                    We’ll send an OTP to your email
                  </span>
                </span>
              </label>

              <label class="group flex cursor-pointer items-start gap-3">
                <span
                  class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center"
                >
                  <input
                    id="verificationDirect"
                    type="radio"
                    name="verificationMethod"
                    value="direct"
                    class="peer sr-only"
                  />
                  <span
                    class="flex h-5 w-5 items-center justify-center rounded-full border border-white/40 bg-transparent transition peer-checked:border-white peer-checked:bg-violet-500 peer-checked:shadow-[0_0_0_1px_rgba(255,255,255,0.9)]"
                  >
                    <span
                      class="h-2.5 w-2.5 rounded-full bg-white opacity-0 transition peer-checked:opacity-100"
                    ></span>
                  </span>
                </span>
                <span
                  class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-violet-300/20 bg-[radial-gradient(circle_at_top,rgba(168,139,255,0.22),rgba(30,20,70,0.92))] shadow-[0_0_18px_rgba(124,92,252,0.16)]"
                >
                  <span
                    class="flex h-10 w-10 items-center justify-center rounded-full border border-white/6 bg-[linear-gradient(180deg,rgba(20,24,48,0.9),rgba(13,16,34,0.96))]"
                  >
                    <svg
                      viewBox="0 0 24 24"
                      class="h-6 w-6 text-white"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.9"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"
                      ></path>
                      <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                  </span>
                </span>
                <span class="min-w-0 pt-0.5">
                  <span
                    class="add-user-verification-title block text-left text-[16px] font-semibold leading-[1.15] tracking-[-0.02em] text-white"
                  >
                    Direct add
                  </span>
                  <span
                    class="add-user-verification-desc mt-1 block text-left text-[13px] leading-[1.45] text-slate-400/90"
                  >
                    Add user directly without verification
                  </span>
                </span>
              </label>
            </div>
          </div>

          <p
            id="formMessage"
            class="add-user-message min-h-5 text-[13px] text-slate-300"
          >
          </p>

          <div
            class="flex flex-col-reverse gap-3 pt-1 sm:flex-row sm:items-center sm:justify-between"
          >
            <a
              href="/admin/users"
              class="add-user-cancel inline-flex h-11 items-center justify-center rounded-[14px] border border-white/12 bg-white/5 px-5 text-[13px] font-semibold text-slate-200 transition hover:border-white/20 hover:bg-white/8"
            >
              Cancel
            </a>
            <button
              id="submitAdd"
              type="submit"
              class="add-user-submit inline-flex h-11 flex-1 items-center justify-center rounded-[14px] border border-violet-400/25 bg-[linear-gradient(135deg,rgba(124,92,252,0.96),rgba(99,79,237,0.94))] px-5 text-[13px] font-bold text-white shadow-[0_0_28px_rgba(124,92,252,0.3)] transition hover:-translate-y-0.5 hover:shadow-[0_0_36px_rgba(124,92,252,0.42)]"
            >
              Add User
            </button>
          </div>
        </form>
      </section>
    </div>
  </AdminShell>
</AdminLayout>

<script>
  const apiBase = (() => {
    const configured = import.meta.env.PUBLIC_API_BASE_URL?.trim();
    if (configured) return configured.replace(/\/$/, "");
    return `${window.location.protocol}//${window.location.hostname}:5001/api`;
  })();

  const form = document.getElementById("addUserForm") as HTMLFormElement | null;
  const emailInput = document.getElementById(
    "email",
  ) as HTMLInputElement | null;
  const passwordInput = document.getElementById(
    "password",
  ) as HTMLInputElement | null;
  const togglePassword = document.getElementById("togglePassword");
  const emailStatusEl = document.getElementById("emailStatus");
  const messageEl = document.getElementById("formMessage");
  const submitBtn = document.getElementById(
    "submitAdd",
  ) as HTMLButtonElement | null;

  let emailCheckRequestId = 0;
  let lastCheckedEmail = "";
  let emailCheckState: "idle" | "checking" | "taken" | "available" | "error" =
    "idle";

  const isCompleteEmail = (value: string) =>
    /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);

  const setMessage = (
    message: string,
    tone: "default" | "success" | "error" = "default",
  ) => {
    if (!messageEl) return;
    messageEl.textContent = message;
    messageEl.className =
      tone === "success"
        ? "min-h-5 text-[13px] text-emerald-300"
        : tone === "error"
          ? "min-h-5 text-[13px] text-rose-300"
          : "min-h-5 text-[13px] text-slate-300";
  };

  const setEmailStatus = (
    message = "",
    tone: "default" | "success" | "error" | "info" = "default",
  ) => {
    if (!emailStatusEl) return;
    emailStatusEl.textContent = message;
    emailStatusEl.className = message
      ? tone === "success"
        ? "add-user-status min-h-5 text-[12px] leading-5 text-emerald-500"
        : tone === "error"
          ? "add-user-status min-h-5 text-[12px] leading-5 text-rose-500"
          : tone === "info"
            ? "add-user-status min-h-5 text-[12px] leading-5 text-violet-500"
            : "add-user-status min-h-5 text-[12px] leading-5 text-slate-400"
      : "add-user-status min-h-5 text-[12px] leading-5 text-slate-400";
  };

  const checkEmailAvailability = async () => {
    if (!emailInput) return;

    const email = emailInput.value.trim();
    if (!email) {
      emailCheckState = "idle";
      lastCheckedEmail = "";
      setEmailStatus();
      return emailCheckState;
    }

    if (!isCompleteEmail(email)) {
      emailCheckState = "idle";
      lastCheckedEmail = email;
      setEmailStatus();
      return emailCheckState;
    }

    const requestId = ++emailCheckRequestId;
    emailCheckState = "checking";
    lastCheckedEmail = email;
    setEmailStatus("Checking email availability…", "info");

    try {
      const response = await fetch(
        `${apiBase}/check-email?email=${encodeURIComponent(email)}`,
        {
          method: "GET",
          credentials: "include",
        },
      );
      const data = await response.json().catch(() => ({}));

      if (requestId !== emailCheckRequestId) return;

      if (!response.ok) {
        emailCheckState = "error";
        setEmailStatus(
          data?.message || "Could not verify email right now.",
          "error",
        );
        return emailCheckState;
      }

      if (data?.exists) {
        emailCheckState = "taken";
        setEmailStatus("Email already registered", "error");
        return emailCheckState;
      }

      emailCheckState = "available";
      setEmailStatus();
      return emailCheckState;
    } catch (error) {
      if (requestId !== emailCheckRequestId) return;
      console.error(error);
      emailCheckState = "error";
      setEmailStatus("Could not verify email right now.", "error");
      return emailCheckState;
    }

    return emailCheckState;
  };

  emailInput?.addEventListener("blur", () => {
    void checkEmailAvailability();
  });

  emailInput?.addEventListener("input", () => {
    const currentEmail = emailInput.value.trim();
    if (currentEmail !== lastCheckedEmail) {
      emailCheckState = "idle";
      setEmailStatus();
    }
  });

  togglePassword?.addEventListener("click", () => {
    if (!passwordInput) return;
    passwordInput.type =
      passwordInput.type === "password" ? "text" : "password";
  });

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!form || !submitBtn) return;

    const formData = new FormData(form);
    const fullName = String(formData.get("fullName") || "").trim();
    const email = String(formData.get("email") || "").trim();
    const phoneNumber = String(formData.get("phoneNumber") || "").trim();
    const password = String(formData.get("password") || "");
    const verificationMethod = String(
      formData.get("verificationMethod") || "direct",
    );

    if (!fullName || !email || !password) {
      setMessage("Please fill in all fields.", "error");
      return;
    }

    if (emailCheckState === "taken") {
      setEmailStatus("Email already registered", "error");
      return;
    }

    if (emailCheckState !== "available") {
      const checkedState = await checkEmailAvailability();
      if (checkedState === "taken") return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = "Creating...";
    setMessage("Submitting user creation request...");

    try {
      const response = await fetch(`${apiBase}/admin/users`, {
        method: "POST",
        credentials: "include",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          fullName,
          email,
          phoneNumber: phoneNumber || undefined,
          password,
          verificationMethod,
        }),
      });

      const data = await response.json().catch(() => ({}));

      if (!response.ok) {
        throw new Error(data?.message || "Unable to create user.");
      }

      if (data?.verificationMethod === "otp") {
        setMessage(
          data?.message || "OTP sent to email for verification.",
          "success",
        );
        return;
      }

      setMessage(data?.message || "User created successfully.", "success");
      window.setTimeout(() => {
        window.location.href = "/admin/users";
      }, 900);
    } catch (error) {
      setMessage(
        error instanceof Error ? error.message : "Unable to create user.",
        "error",
      );
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "Add User";
    }
  });
</script>

<style>
  :global(html[data-admin-theme="light"]) .add-user-page {
    min-height: calc(100vh - 220px);
    padding-top: 24px;
  }

  :global(html[data-admin-theme="light"]) .add-user-card {
    background: linear-gradient(180deg, #ffffff, #f8fafc) !important;
    border-color: rgba(148, 163, 184, 0.18) !important;
    box-shadow: 0 16px 48px rgba(15, 23, 42, 0.08) !important;
  }

  :global(html[data-admin-theme="light"]) .add-user-title,
  :global(html[data-admin-theme="light"]) .add-user-label {
    color: #0f172a !important;
  }

  :global(html[data-admin-theme="light"]) .add-user-title {
    font-weight: 900 !important;
    letter-spacing: -0.07em !important;
  }

  :global(html[data-admin-theme="light"]) .add-user-subtitle {
    font-weight: 500 !important;
    color: #475569 !important;
  }

  :global(html[data-admin-theme="light"]) .add-user-label {
    font-weight: 800 !important;
    letter-spacing: 0.18em !important;
    color: #334155 !important;
  }

  :global(html[data-admin-theme="light"]) .add-user-verification-title {
    color: #0f172a !important;
  }

  :global(html[data-admin-theme="light"]) .add-user-verification-desc {
    color: #475569 !important;
  }

  :global(html[data-admin-theme="light"]) .add-user-eyebrow {
    color: rgba(99, 102, 241, 0.72) !important;
    font-weight: 700 !important;
  }

  :global(html[data-admin-theme="light"]) .add-user-subtitle,
  :global(html[data-admin-theme="light"]) .add-user-message {
    color: #64748b !important;
  }

  :global(html[data-admin-theme="light"]) .add-user-input {
    background: #ffffff !important;
    border-color: rgba(203, 213, 225, 0.9) !important;
    color: #0f172a !important;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04) !important;
  }

  :global(html[data-admin-theme="light"]) .add-user-input::placeholder {
    color: rgba(100, 116, 139, 0.72) !important;
  }

  :global(html[data-admin-theme="light"]) .add-user-input:focus {
    border-color: rgba(124, 92, 252, 0.38) !important;
    box-shadow: 0 0 0 4px rgba(124, 92, 252, 0.09) !important;
  }

  :global(html[data-admin-theme="light"]) .add-user-icon {
    color: #64748b !important;
  }

  :global(html[data-admin-theme="light"]) .verification-option {
    background: #ffffff !important;
    border-color: rgba(203, 213, 225, 0.9) !important;
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04) !important;
  }

  :global(html[data-admin-theme="light"]) .verification-option:hover {
    background: #ffffff !important;
    border-color: rgba(167, 139, 250, 0.55) !important;
  }

  :global(html[data-admin-theme="light"])
    .verification-option:has(input:checked),
  :global(html[data-admin-theme="light"])
    .verification-option-active:has(input:checked) {
    background: linear-gradient(
      180deg,
      rgba(124, 92, 252, 0.08),
      rgba(124, 92, 252, 0.04)
    ) !important;
    border-color: rgba(167, 139, 250, 0.6) !important;
  }

  :global(html[data-admin-theme="light"]) .verification-option input {
    accent-color: #7c5cfc;
  }

  :global(html[data-admin-theme="light"])
    input[name="verificationMethod"]
    + span {
    border-color: rgba(203, 213, 225, 0.9) !important;
    background: rgba(255, 255, 255, 0.96) !important;
  }

  :global(html[data-admin-theme="light"])
    input[name="verificationMethod"]:checked
    + span {
    border-color: rgba(124, 92, 252, 0.78) !important;
    background: rgba(124, 92, 252, 0.16) !important;
    box-shadow: 0 0 0 1px rgba(124, 92, 252, 0.16) !important;
  }

  :global(html[data-admin-theme="light"]) .add-user-status {
    color: #64748b !important;
  }

  :global(html[data-admin-theme="light"]) .add-user-status.text-rose-500,
  :global(html[data-admin-theme="light"])
    .add-user-status[class*="text-rose-"] {
    color: #ef4444 !important;
  }

  :global(html[data-admin-theme="light"])
    .add-user-status[class*="text-emerald-"] {
