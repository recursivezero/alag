---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout page="home">
  <section class="hero-shell">
    <div class="hero-copy">
      <div class="hero-badge">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
          <circle cx="12" cy="12" r="6"></circle>
        </svg>
        Secure · Fast · Simple
      </div>

      <h1>Authentication<br /><span>Made Simple</span></h1>

      <p>
        Recursive Auth gives you email-based OTP verification - clean,
        secure, and ready in minutes.
        
      </p>

      <div class="hero-actions">
        <a href="/register" class="btn-hero solid">
          Get Started
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
          >
        </a>
        <a href="/login" class="btn-hero outline">Sign In</a>
      </div>

      <div class="features">
        <div class="feature">
          <div class="feature-icon">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect x="3" y="11" width="18" height="11" rx="2"></rect><path
                d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg
            >
          </div>
          <h3>Secure</h3>
          <p>
            Industry-standard encryption keeps your data protected at all times.
          </p>
        </div>

        <div class="feature">
          <div class="feature-icon">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"
              ></polygon></svg
            >
          </div>
          <h3>Fast</h3>
          <p>
            OTP verification happens quickly so users can move through the flow.
          </p>
        </div>

        <div class="feature">
          <div class="feature-icon">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><circle cx="12" cy="12" r="10"></circle><path d="M12 8v4l3 3"
              ></path></svg
            >
          </div>
          <h3>Simple</h3>
          <p>
            Easy navigation from Home to Login, Register, About, and Dashboard.
          </p>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .hero-shell {
    width: min(100%, 1200px);
    margin: 0 auto;
    padding: 3rem 0 4rem;
    min-height: calc(100vh - 6rem);
    display: grid;
    place-items: center;
  }

  .hero-copy {
    width: 100%;
    max-width: 760px;
    text-align: center;
  }

  .hero-copy h1 {
    font-size: clamp(2.8rem, 7vw, 4.7rem);
    font-weight: 700;
    letter-spacing: -0.06em;
    line-height: 0.95;
    margin-bottom: 1rem;
  }

  .hero-copy h1 span {
    color: var(--purple-light);
  }

  .hero-copy p {
    max-width: 540px;
    margin: 0 auto;
    color: var(--muted);
    line-height: 1.7;
    font-size: 1rem;
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 0.85rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(124, 92, 252, 0.1);
    border: 1px solid rgba(124, 92, 252, 0.22);
    border-radius: 999px;
    padding: 0.32rem 0.85rem;
    font-size: 0.78rem;
    color: var(--purple-light);
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .btn-hero {
    padding: 0.9rem 1.6rem;
    border-radius: 14px;
    font-family: "Outfit", sans-serif;
    font-size: 0.92rem;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    transition: all var(--ease);
  }

  .btn-hero.solid {
    background: var(--purple);
    border: none;
    color: #fff;
    box-shadow: 0 4px 22px rgba(124, 92, 252, 0.38);
  }

  .btn-hero.solid:hover {
    background: var(--purple-light);
  }

  .btn-hero.outline {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text);
  }

  .btn-hero.outline:hover {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.14);
  }

  .features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.85rem;
    margin-top: 3.5rem;
    width: 100%;
  }

  .feature {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 15px;
    padding: 1.2rem;
    text-align: left;
    min-height: 160px;
  }

  .feature-icon {
    width: 34px;
    height: 34px;
    background: var(--purple-glow);
    border-radius: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.7rem;
    color: var(--purple-light);
  }

  .feature-icon svg {
    width: 17px;
    height: 17px;
  }

  .feature h3 {
    font-size: 0.88rem;
    font-weight: 600;
    margin-bottom: 0.3rem;
  }

  .feature p {
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 1400px) {
    .hero-shell {
      padding-inline: 1rem;
    }
  }

  @media (max-width: 900px) {
    .features {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .hero-copy {
      text-align: left;
    }

    .hero-actions {
      justify-content: flex-start;
    }

    .hero-copy h1 {
      font-size: clamp(2.4rem, 14vw, 4rem);
    }
  }
</style>
