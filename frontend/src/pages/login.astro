---
import MainLayout from "../layouts/MainLayout.astro";
import LoginForm from "../components/LoginForm.astro";
---

<MainLayout page="login" title="Home Page">
  <div class="card">
    <h2 class="card-title">Welcome back</h2>
    <p class="card-sub">Sign in to continue your practice.</p>
    <LoginForm />
    <div class="card-footer">
      New here? <a href="/register">Create free account</a>
      <div>
        <a href="/" class="back-link">
          <svg
            width="13"
            height="13"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M19 12H5M12 5l-7 7 7 7"></path></svg
          >
          Back to home
        </a>
      </div>
    </div>
  </div>
</MainLayout>
