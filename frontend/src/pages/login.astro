---
import MainLayout from "../layouts/MainLayout.astro";
import PublicLoginForm from "../components/auth/PublicLoginForm.astro";
---

<MainLayout page="login" title="Home Page">
  <div class="login-page-shell">
    <div class="login-hero">
      <h2 class="login-title">Login</h2>
      <div class="login-divider" aria-hidden="true"></div>
    </div>
    <div class="card login-card">
      <PublicLoginForm />
      <div class="card-footer">
        <div class="footer-row footer-row-top">
          <span class="footer-muted">New here?</span>
          <a href="/register">Create free account</a>
        </div>
        <div class="footer-row footer-row-bottom">
          <a href="/" class="back-link">
            <svg
              width="13"
              height="13"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              focusable="false"><path d="M19 12H5M12 5l-7 7 7 7"></path></svg
            >
            Back to home
          </a>
          <span class="footer-separator" aria-hidden="true">|</span>
          <a href="/admin" class="admin-foot-link">Admin Panel</a>
        </div>
      </div>
    </div>
  </div>

  <style>
    .login-page-shell {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
      gap: 1.45rem;
    }

    .login-hero {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      width: 100%;
      margin-top: -0.35rem;
    }

    .login-title {
      font-size: 2.55rem;
      line-height: 1;
      font-weight: 700;
      letter-spacing: -0.05em;
      color: var(--text);
      text-align: center;
    }

    .login-divider {
      position: relative;
      width: min(260px, 100%);
      height: 2px;
      margin-top: 0.95rem;
      border-radius: 999px;
      background: linear-gradient(
        90deg,
        rgba(124, 92, 252, 0),
        rgba(124, 92, 252, 0.9),
        rgba(189, 157, 255, 0.9),
        rgba(124, 92, 252, 0)
      );
      box-shadow: 0 0 18px rgba(124, 92, 252, 0.42);
    }

    .login-divider::after {
      content: "";
      position: absolute;
      left: 50%;
      top: 50%;
      width: 9px;
      height: 9px;
      transform: translate(-50%, -50%);
      border-radius: 999px;
      background: var(--purple-light);
      box-shadow: 0 0 16px rgba(157, 130, 253, 0.95);
    }

    .login-subtitle {
      margin-top: 1rem;
      font-size: 0.96rem;
      line-height: 1.5;
      color: var(--muted);
      text-align: center;
    }

    .login-card {
      margin-top: 0;
    }

    :global(#loginBtn) {
      appearance: none;
      -webkit-appearance: none;
      display: flex !important;
      align-items: center;
      justify-content: center;
      width: 100% !important;
      min-height: 55px;
      padding: 0 1rem !important;
      margin-top: 1rem;
      border: 1px solid rgba(124, 92, 252, 0.24) !important;
      border-radius: 15px !important;
      background: linear-gradient(
        90deg,
        #6f49ff 0%,
        #7c5cfc 52%,
        #6b47ff 100%
      ) !important;
      color: #fff !important;
      font-size: 0.96rem;
      font-weight: 600;
      line-height: 1;
      letter-spacing: -0.01em;
      text-align: center;
      box-shadow:
        0 10px 26px rgba(124, 92, 252, 0.28),
        inset 0 1px 0 rgba(255, 255, 255, 0.09) !important;
      cursor: pointer;
      transition:
        transform 0.18s ease,
        box-shadow 0.18s ease,
        filter 0.18s ease;
    }

    :global(#loginBtn:hover:not(:disabled)) {
      transform: translateY(-1px);
      filter: brightness(1.03);
      box-shadow:
        0 14px 30px rgba(124, 92, 252, 0.34),
        0 0 22px rgba(124, 92, 252, 0.18),
        inset 0 1px 0 rgba(255, 255, 255, 0.09) !important;
    }

    :global(#loginBtn:active:not(:disabled)) {
      transform: translateY(0);
    }

    :global(#loginBtn:focus-visible) {
      outline: none;
      box-shadow:
        0 0 0 3px rgba(124, 92, 252, 0.28),
        0 10px 26px rgba(124, 92, 252, 0.28),
        inset 0 1px 0 rgba(255, 255, 255, 0.09) !important;
    }

    :global(#googleLoginBtn) {
      width: 100%;
      margin-bottom: 1.5rem;
      padding: 0 !important;
      background: transparent !important;
      border: none !important;
      display: block !important;
    }

    :global(#googleLoginBtn > div) {
      width: 100% !important;
      min-height: 45px;
    }

    :global(#googleLoginBtn [role="button"]) {
      width: 100% !important;
      height: 40px !important;
      /* min-height: 40px !important; */
      max-width: none !important;
      padding: 0 1rem !important;
      box-sizing: border-box !important;
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      gap: 0.6rem !important;
      border: 1px solid rgba(255, 255, 255, 0.14) !important;
      border-radius: 15px !important;
      background: #fff !important;
      color: #121225 !important;
      box-shadow: 0 1px 0 rgba(255, 255, 255, 0.75) inset !important;
      overflow: hidden !important;
    }

    :global(#googleLoginBtn [role="button"] > div) {
      border: 0 !important;
      box-shadow: none !important;
    }

    :global(#googleLoginBtn [role="button"] > div:nth-child(2)) {
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      gap: 0.6rem !important;
      width: auto !important;
      height: auto !important;
      padding: 0 !important;
    }

    :global(#googleLoginBtn [role="button"] svg) {
      width: 18px !important;
      height: 18px !important;
      flex-shrink: 0;
    }

    :global(#googleLoginBtn),
    :global(#googleLoginBtn > div) {
      overflow: hidden;
      border-radius: 15px !important;
    }

    .card-footer {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.6rem;
    }

    .footer-row {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      text-align: center;
      gap: 0.35rem;
    }

    .footer-row-top {
      gap: 0.35rem;
    }

    .footer-row-bottom {
      gap: 0.55rem;
    }

    .footer-muted {
      color: var(--text);
    }

    .back-link {
      margin-top: 0;
    }

    .footer-separator {
      color: rgba(238, 237, 248, 0.28);
    }

    @media (max-width: 768px) {
      .card-footer {
        gap: 0.7rem;
      }

      .footer-row-bottom {
        gap: 0.45rem;
      }
    }
  </style>
</MainLayout>
