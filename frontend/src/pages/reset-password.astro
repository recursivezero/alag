---
import MainLayout from "../layouts/MainLayout.astro";
---

<style>
  :root {
    --bg: #06101f;
    --card: rgba(13, 22, 39, 0.78);
    --card-border: rgba(255, 255, 255, 0.08);
    --text: #f4f7ff;
    --muted: #9ca9c7;
    --line: rgba(255, 255, 255, 0.08);
    --accent-start: #7c5cfc;
    --accent-end: #8f5cff;
    --accent-glow: rgba(124, 92, 252, 0.24);
  }

  .page {
    min-height: calc(100vh - 72px);
    display: grid;
    place-items: center;
    padding: 2rem 1.25rem 3rem;
    background:
      radial-gradient(
        circle at top left,
        rgba(124, 92, 252, 0.24),
        transparent 28%
      ),
      radial-gradient(
        circle at bottom right,
        rgba(79, 214, 255, 0.1),
        transparent 26%
      ),
      linear-gradient(180deg, #06101f 0%, #050b15 64%, #02060d 100%);
  }

  .card {
    width: min(100%, 560px);
    border: 1px solid var(--card-border);
    border-radius: 24px;
    background: var(--card);
    backdrop-filter: blur(14px);
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.48);
    padding: clamp(1.6rem, 4vw, 3rem);
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 58px;
    height: 58px;
    margin-bottom: 1rem;
    border-radius: 18px;
    background: rgba(124, 92, 252, 0.16);
    color: #bba9ff;
    box-shadow: 0 0 0 10px rgba(124, 92, 252, 0.05);
  }

  .eyebrow {
    color: #d8deff;
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 0.45rem;
  }

  h1 {
    margin: 0;
    color: var(--text);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.04;
  }

  p {
    margin: 0.9rem auto 0;
    max-width: 30rem;
    color: var(--muted);
    line-height: 1.65;
    font-size: 1rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    margin-top: 1.35rem;
    border: none;
    border-radius: 14px;
    padding: 0.98rem 1.35rem;
    min-width: 170px;
    font-weight: 700;
    color: #fff;
    cursor: pointer;
    background: linear-gradient(90deg, var(--accent-start), var(--accent-end));
    box-shadow: 0 16px 32px var(--accent-glow);
    text-decoration: none;
    transition:
      transform 0.18s ease,
      filter 0.18s ease;
  }

  .button:hover {
    transform: translateY(-1px);
    filter: brightness(1.05);
  }

  .note {
    margin-top: 1rem;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.5;
  }
</style>

<MainLayout page="login" title="Reset Password">
  <div class="page">
    <section class="card" aria-labelledby="legacy-reset-heading">
      <div class="badge" aria-hidden="true">
        <svg
          viewBox="0 0 24 24"
          width="28"
          height="28"
          fill="none"
          stroke="currentColor"
          stroke-width="1.9"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path
            d="M12 2a5 5 0 0 0-5 5v3H6a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-7a2 2 0 0 0-2-2h-1V7a5 5 0 0 0-5-5Z"
          ></path>
          <path d="M9 10V7a3 3 0 0 1 6 0v3"></path>
        </svg>
      </div>
      <div class="eyebrow">Recursive Auth</div>
      <h1 id="legacy-reset-heading">Open your magic link</h1>
      <p>
        This route is kept for compatibility. Use the password reset link from
        your email to open the secure reset page.
      </p>
      <a href="/forgot-password" class="button">
        Request a reset link
        <svg
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h13"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
      <div class="note">
        If you already have a magic link, open the email button instead of this
        page.
      </div>
    </section>
  </div>
</MainLayout>
