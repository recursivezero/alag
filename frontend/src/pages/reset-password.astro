---
import MainLayout from "../layouts/MainLayout.astro";
---

<style>
  :root {
    --bg: #071026;
    --panel: rgba(15, 27, 42, 0.72);
    --muted: #9aa6bf;
    --line: rgba(255, 255, 255, 0.06);
    --accent-start: #7c5cfc;
    --accent-end: #8e5ef8;
  }

  .page {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 2rem;
    background:
      radial-gradient(
        circle at top left,
        rgba(124, 92, 252, 0.22),
        transparent 28%
      ),
      radial-gradient(
        circle at bottom right,
        rgba(78, 208, 255, 0.12),
        transparent 24%
      ),
      linear-gradient(180deg, var(--bg), #04101f 70%, #02070f);
  }

  .card {
    width: min(100%, 920px);
    border: 1px solid var(--line);
    border-radius: 18px;
    background: var(--panel);
    backdrop-filter: blur(10px);
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.45);
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr;
  }

  @media (min-width: 920px) {
    .card {
      grid-template-columns: 1fr 1fr;
    }
  }

  .panel {
    padding: clamp(1.5rem, 4vw, 3rem);
  }

  .panel + .panel {
    border-left: 1px solid rgba(255, 255, 255, 0.04);
  }

  .eyebrow {
    color: #d7dcff;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  h1,
  h2 {
    color: #fff;
    margin: 0;
    line-height: 1.05;
  }

  h1 {
    font-size: clamp(2rem, 4vw, 3.1rem);
    margin-bottom: 0.85rem;
  }

  h2 {
    font-size: clamp(1.5rem, 2.4vw, 2rem);
    margin-bottom: 0.7rem;
  }

  p {
    color: var(--muted);
    margin: 0 0 1.5rem;
    line-height: 1.6;
  }

  .field {
    margin-bottom: 1rem;
  }

  .input {
    width: 100%;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.03);
    color: #fff;
    border-radius: 12px;
    padding: 0.95rem 1rem;
    font-size: 1rem;
    outline: none;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .input:focus {
    border-color: rgba(124, 92, 252, 0.7);
    box-shadow: 0 0 0 4px rgba(124, 92, 252, 0.15);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    border: none;
    border-radius: 12px;
    padding: 0.95rem 1.3rem;
    font-weight: 700;
    color: #fff;
    cursor: pointer;
    background: linear-gradient(90deg, var(--accent-start), var(--accent-end));
    box-shadow: 0 14px 30px rgba(124, 92, 252, 0.28);
    transition:
      transform 0.18s ease,
      filter 0.18s ease;
    text-decoration: none;
  }

  .reset-btn {
    margin-top: 0.85rem;
  }

  .btn:hover {
    transform: translateY(-1px);
    filter: brightness(1.04);
  }

  .btn:disabled {
    opacity: 0.7;
    cursor: wait;
    transform: none;
  }

  .backlink {
    display: inline-block;
    margin-top: 1rem;
    color: #9fb0ff;
    text-decoration: none;
  }

  .status {
    margin-top: 1rem;
    min-height: 1.2rem;
    color: #7df3a3;
  }

  .helper {
    margin-top: 0.75rem;
    font-size: 0.92rem;
    color: var(--muted);
  }
</style>

<MainLayout page="login" title="Reset Password">
  <div class="page">
    <div class="card">
      <section class="panel">
        <div class="eyebrow">Reset Password</div>
        <h1>Set a new password</h1>
        <p>Enter your email, the code you received, and your new password.</p>

        <div class="field">
          <input
            id="email"
            class="input"
            type="email"
            placeholder="you@example.com"
          />
        </div>
        <div class="field">
          <input
            id="token"
            class="input"
            type="text"
            placeholder="Reset code"
          />
        </div>
        <div class="field">
          <input
            id="newPassword"
            class="input"
            type="password"
            placeholder="New password"
          />
        </div>
        <div class="field">
          <input
            id="confirmPassword"
            class="input"
            type="password"
            placeholder="Confirm password"
          />
        </div>

        <button id="resetBtn" class="btn reset-btn" type="button"
          >Reset Password</button
        >
        <a href="/login" class="backlink">Back to login</a>
        <div id="msg" class="status"></div>
      </section>

      <section class="panel">
        <div class="eyebrow">Tip</div>
        <h2>Use the code from your email</h2>
        <p>
          The code expires after a short time. If it expires, go back and
          request a new reset link.
        </p>
        <div class="helper">
          If you arrived here from the forgot password page, your email should
          already be filled in.
        </div>
      </section>
    </div>
  </div>

  <script>
    const apiBase = "http://localhost:5001/api";
    const params = new URLSearchParams(window.location.search);
    const emailFromQuery = params.get("email");
    const emailEl = document.getElementById("email");

    if (emailEl instanceof HTMLInputElement && emailFromQuery) {
      emailEl.value = emailFromQuery;
    }

    document.getElementById("resetBtn")?.addEventListener("click", async () => {
      const currentEmailEl = document.getElementById(
        "email",
      ) as HTMLInputElement | null;
      const tokenEl = document.getElementById(
        "token",
      ) as HTMLInputElement | null;
      const newPasswordEl = document.getElementById(
        "newPassword",
      ) as HTMLInputElement | null;
      const confirmPasswordEl = document.getElementById(
        "confirmPassword",
      ) as HTMLInputElement | null;

      if (!currentEmailEl || !tokenEl || !newPasswordEl || !confirmPasswordEl)
        return;

      const email = currentEmailEl.value.trim();
      const token = tokenEl.value.trim();
      const newPassword = newPasswordEl.value;
      const confirmPassword = confirmPasswordEl.value;

      if (!email || !token || !newPassword || !confirmPassword) {
        alert("All fields are required");
        return;
      }

      if (newPassword !== confirmPassword) {
        alert("Passwords do not match");
        return;
      }

      const button = document.getElementById("resetBtn");
      if (button instanceof HTMLButtonElement) {
        button.disabled = true;
        button.textContent = "Resetting…";
      }

      try {
        const res = await fetch(`${apiBase}/reset-password`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email, token, newPassword }),
        });

        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
          throw new Error(data.message || `Request failed (${res.status})`);
        }

        const msgEl = document.getElementById("msg");
        if (msgEl) msgEl.textContent = data.message || "Password updated";

        setTimeout(() => {
          window.location.href = "/login";
        }, 1200);
      } catch (error) {
        console.error("Reset password error:", error);
        alert(
          error instanceof Error ? error.message : "Could not reset password",
        );
      } finally {
        if (button instanceof HTMLButtonElement) {
          button.disabled = false;
          button.textContent = "Reset Password";
        }
      }
    });
  </script>
</MainLayout>
