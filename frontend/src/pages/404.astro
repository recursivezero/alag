---
const pageTitle = "404 | Recursive Auth";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>

    <script is:inline>
      (() => {
        const k = "recursive-theme";
        const s = localStorage.getItem(k);
        const t = s || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
        document.documentElement.setAttribute("data-theme", t);
      })();
    </script>

    <style>
      html[data-theme="dark"] {
        --bg:      #0d1021;
        --text:    #ffffff;
        --muted:   rgba(255,255,255,0.52);
        --ntop:    #c4b5fd;
        --nbot:    #6d28d9;
        --ha:      #111328;
        --hb:      #0e1022;
        --pa:      #3d2870;
        --pb:      #180c38;
        --ring:    rgba(80,55,160,0.8);
        --sc:      rgba(100,75,200,0.55);
        --tbg:     rgba(255,255,255,0.05);
        --tbd:     rgba(255,255,255,0.14);
        --b2bg:    rgba(10,8,24,0.8);
        --b2bd:    rgba(255,255,255,0.18);
        --b2tx:    #ffffff;
        --fbd:     rgba(255,255,255,0.08);
      }
      html[data-theme="light"] {
        --bg:      #f5f3ff;
        --text:    #111827;
        --muted:   #6b7280;
        --ntop:    #a78bfa;
        --nbot:    #5b21b6;
        --ha:      rgba(196,181,253,0.5);
        --hb:      rgba(214,204,255,0.6);
        --pa:      #c4b5fd;
        --pb:      #7c3aed;
        --ring:    rgba(124,58,237,0.6);
        --sc:      rgba(109,40,217,0.38);
        --tbg:     rgba(255,255,255,0.92);
        --tbd:     rgba(17,24,39,0.1);
        --b2bg:    rgba(255,255,255,0.9);
        --b2bd:    rgba(17,24,39,0.12);
        --b2tx:    #111827;
        --fbd:     rgba(17,24,39,0.08);
      }

      *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
      html, body { width:100%; min-height:100%; font-family:Inter,system-ui,-apple-system,sans-serif; overflow-x:hidden; }
      html[data-theme="dark"]  body { background:#0d1021; }
      html[data-theme="light"] body { background:linear-gradient(160deg,#f8f6ff,#ede9fe); }

      .page { min-height:100vh; display:flex; flex-direction:column; overflow:hidden; color:var(--text); }
      .wrap { display:flex; flex-direction:column; min-height:100vh; padding:1.8rem 2.6rem; position:relative; z-index:10; }

      /* HEADER */
      .hdr { display:flex; align-items:center; justify-content:space-between; flex-shrink:0; }
      .logo { display:flex; align-items:center; gap:.6rem; text-decoration:none; color:var(--text); }
      .lsvg { width:40px; height:40px; }
      .lname { font-size:1.45rem; font-weight:800; letter-spacing:-.04em; }
      .lname b { color:#7c3aed; font-weight:800; }
      .tog {
        display:flex; align-items:center; gap:.55rem;
        height:46px; padding:0 1.15rem; border-radius:13px;
        border:1px solid var(--tbd); background:var(--tbg);
        backdrop-filter:blur(14px); color:var(--text);
        font-size:.9rem; font-weight:600; cursor:pointer;
        transition:transform .2s; white-space:nowrap;
      }
      html[data-theme="light"] .tog { box-shadow:0 1px 4px rgba(0,0,0,.07); }
      .tog:hover { transform:translateY(-1px); }
      .tico { width:17px; height:17px; flex-shrink:0; }

      /* HERO */
      .hero {
        flex:1; position:relative;
        display:flex; align-items:center; justify-content:center;
        padding-top:1.5rem; padding-bottom:8rem;
      }

      .dome-wrap {
        position: absolute;
        left: 50%;
        top: 2%;
        transform: translateX(-50%);
       
        width: min(620px, 48vw);
      
        height: calc(min(620px, 48vw) * 0.65);
        overflow: hidden;
        pointer-events: none;
        z-index: 1;
      }
      .dome-wrap svg {
        width: 100%;
       
        height: calc(100% / 0.65);
        display: block;
      }

     
      .scat { position:absolute; inset:0; pointer-events:none; z-index:2; }
      .xm { position:absolute; width:10px; height:10px; }
      .xm::before,.xm::after { content:""; position:absolute; width:100%; height:1.6px; background:var(--sc); top:50%; left:0; border-radius:1px; }
      .xm::before { transform:translateY(-50%) rotate(45deg); }
      .xm::after  { transform:translateY(-50%) rotate(-45deg); }
      .dm { position:absolute; border-radius:50%; background:var(--sc); }
      .rm { position:absolute; border-radius:50%; border:1.6px solid var(--sc); }

      /* PLANET */
      .planet { position:absolute; left:8%; top:38%; transform:translateY(-50%); width:clamp(75px,8vw,108px); pointer-events:none; z-index:3; }
         
        
      .scope { position:absolute; right:3.5%; bottom:4%; width:clamp(130px,13vw,185px); pointer-events:none; z-index:3; }

      /* HILLS */
      .hills { position:absolute; bottom:0; left:0; right:0; width:100%; pointer-events:none; z-index:2; }

      /* CENTER */
      .ctr { position:relative; z-index:5; text-align:center; }
      .num {
        font-size:clamp(7rem,12vw,12rem);
        line-height:1; font-weight:900; letter-spacing:-.06em;
        background:linear-gradient(180deg, var(--ntop) 0%, var(--nbot) 100%);
        -webkit-background-clip:text; background-clip:text; color:transparent;
      }
      .ttl { margin-top:.25rem; font-size:clamp(2rem,3.4vw,3.6rem); font-weight:800; letter-spacing:-.04em; line-height:1.1; color:var(--text); }
      .ttl span { color:#7c3aed; }
      .sub { margin:1rem auto 0; max-width:450px; font-size:.95rem; line-height:1.72; color:var(--muted); }
      .acts { margin-top:1.8rem; display:flex; flex-direction:column; align-items:center; gap:.8rem; }
      .b1 {
        width:min(360px,88vw); height:58px; border-radius:13px;
        display:flex; align-items:center; justify-content:center; gap:.65rem;
        text-decoration:none; color:#fff; font-size:1.02rem; font-weight:700;
        background:#7c3aed; border:none;
        box-shadow:0 8px 26px rgba(109,40,217,.4);
        transition:.2s ease; cursor:pointer;
      }
      .b1:hover { filter:brightness(1.12); transform:translateY(-2px); }
      .bi { width:18px; height:18px; }
      .b2 {
        width:min(260px,78vw); height:50px; border-radius:11px;
        display:flex; align-items:center; justify-content:center; gap:.55rem;
        color:var(--b2tx); font-size:.95rem; font-weight:500;
        background:var(--b2bg); border:1.5px solid var(--b2bd);
        backdrop-filter:blur(10px); cursor:pointer; transition:.2s ease;
      }
      .b2:hover { transform:translateY(-2px); }

      /* FOOTER */
      .ftr { padding-top:1.4rem; border-top:1px solid var(--fbd); display:flex; align-items:center; justify-content:space-between; gap:1rem; color:var(--muted); font-size:.84rem; flex-shrink:0; }
      .fl { display:flex; align-items:center; gap:.6rem; }
      .fsvg { width:34px; height:34px; }
      .fn { font-size:1rem; font-weight:700; letter-spacing:-.03em; color:var(--text); }
      .fn b { color:#7c3aed; font-weight:700; }
      .fs { font-size:.78rem; margin-top:.1rem; }

      @media (max-width:768px) {
        .wrap { padding:1.1rem .9rem; }
        .lname { font-size:1.15rem; }
        .tlbl { display:none; }
        .tog { padding:0 .85rem; }
        .planet { left:0; width:68px; }
        .scope { right:0; width:100px; }
        .dome-wrap { width:90vw; }
        .acts { width:100%; padding:0 .5rem; }
        .b1,.b2 { width:100%; }
        .ftr { flex-direction:column; align-items:flex-start; }
      }
    </style>
  </head>

  <body>
    <div class="page">
      <div class="wrap">

        <!-- HEADER -->
        <header class="hdr">
          <a href="/" class="logo">
            <svg class="lsvg" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="1.8">
              <path d="M12 2L20 6V12C20 17 16.6 21.4 12 22C7.4 21.4 4 17 4 12V6L12 2Z"/>
              <rect x="9" y="10" width="6" height="5" rx="1.2"/>
              <path d="M10 10V8.8C10 7.3 10.9 6.3 12 6.3C13.1 6.3 14 7.3 14 8.8V10"/>
            </svg>
            <span class="lname">Recursive <b>Auth</b></span>
          </a>
          <button id="tog" class="tog">
            <svg id="iMoon" class="tico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 12.8A9 9 0 1111.2 3 7 7 0 0021 12.8z"/>
            </svg>
            <svg id="iSun" class="tico" style="display:none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="5"/>
              <line x1="12" y1="2" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="22"/>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
              <line x1="2" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22" y2="12"/>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
            <span id="tlbl" class="tlbl">Dark Mode</span>
          </button>
        </header>

        <!-- HERO -->
        <main class="hero">

        
          <div class="dome-wrap">
            <svg viewBox="0 0 620 620" fill="none" xmlns="http://www.w3.org/2000/svg">
              <defs>
               
                <radialGradient id="dkG" cx="50%" cy="50%" r="50%">
                  <stop offset="0%"   stop-color="#13162c" stop-opacity="1"/>
                  <stop offset="55%"  stop-color="#151838" stop-opacity="1"/>
                  <stop offset="78%"  stop-color="#1e1d52" stop-opacity="1"/>
                  <stop offset="90%"  stop-color="#2d2878" stop-opacity="0.95"/>
                  <stop offset="100%" stop-color="#3d33a0" stop-opacity="0.5"/>
                </radialGradient>
              
                <radialGradient id="dkGlow" cx="50%" cy="50%" r="50%">
                  <stop offset="0%"   stop-color="rgba(0,0,0,0)"/>
                  <stop offset="75%"  stop-color="rgba(0,0,0,0)"/>
                  <stop offset="88%"  stop-color="rgba(100,70,220,0.15)"/>
                  <stop offset="95%"  stop-color="rgba(120,90,240,0.28)"/>
                  <stop offset="100%" stop-color="rgba(100,70,220,0.08)"/>
                </radialGradient>

                <radialGradient id="ltG" cx="50%" cy="50%" r="50%">
                  <stop offset="0%"   stop-color="#ece6ff" stop-opacity="0.55"/>
                  <stop offset="80%"  stop-color="#d8ceff" stop-opacity="0.42"/>
                  <stop offset="100%" stop-color="#c4b5fd" stop-opacity="0.28"/>
                </radialGradient>
              </defs>

             
              <circle id="cDk"    cx="310" cy="310" r="306" fill="url(#dkG)"/>
            
              <circle id="cDkGlw" cx="310" cy="310" r="306" fill="url(#dkGlow)"/>
             
              <circle id="cLt"    cx="310" cy="310" r="306" fill="url(#ltG)" style="display:none"/>
            </svg>
          </div>

         
          <div class="scat">
            <div class="xm" style="top:15%;left:21%"></div>
            <div class="xm" style="top:44%;left:13%"></div>
            <div class="xm" style="top:52%;left:22%"></div>
            <div class="dm" style="width:6px;height:6px;top:27%;left:16%"></div>
            <div class="dm" style="width:5px;height:5px;top:12%;right:27%"></div>
            <div class="xm" style="top:18%;right:17%"></div>
            <div class="xm" style="top:34%;right:21%"></div>
            <div class="rm" style="width:10px;height:10px;top:41%;right:10%"></div>
            <div class="rm" style="width:9px;height:9px;top:57%;right:17%"></div>
          </div>

          <!-- PLANET -->
          <div class="planet">
            <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <radialGradient id="pg" cx="38%" cy="34%" r="58%">
                  <stop offset="0%" stop-color="var(--pa)"/>
                  <stop offset="100%" stop-color="var(--pb)"/>
                </radialGradient>
                <clipPath id="pc"><circle cx="60" cy="60" r="38"/></clipPath>
              </defs>
              <ellipse cx="60" cy="60" rx="57" ry="14" transform="rotate(-18 60 60)" fill="none" stroke="var(--ring)" stroke-width="5"/>
              <circle cx="60" cy="60" r="38" fill="url(#pg)"/>
              <ellipse cx="60" cy="60" rx="57" ry="14" transform="rotate(-18 60 60)" fill="none" stroke="var(--ring)" stroke-width="5" clip-path="url(#pc)"/>
              <circle cx="48" cy="48" r="10" fill="rgba(255,255,255,0.07)"/>
            </svg>
          </div>

          <div class="scope">
            <!-- DARK MODE -->
            <svg id="sDk" viewBox="0 0 200 300" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <linearGradient id="barDk" x1="0%" y1="0%" x2="100%" y2="0%">
                  <stop offset="0%" stop-color="#2e2480"/>
                  <stop offset="100%" stop-color="#1a1258"/>
                </linearGradient>
                <linearGradient id="barDkV" x1="0%" y1="0%" x2="0%" y2="100%">
                  <stop offset="0%" stop-color="#322888"/>
                  <stop offset="100%" stop-color="#181050"/>
                </linearGradient>
              </defs>

              
              <g transform="rotate(-38 100 150)">
               
                <rect x="28" y="133" width="130" height="34" rx="17" fill="url(#barDk)"/>
               
                <rect x="28" y="133" width="130" height="10" rx="9" fill="rgba(255,255,255,0.05)"/>
                
                <rect x="146" y="127" width="22" height="46" rx="10" fill="#180e50"/>
               
                <rect x="20" y="128" width="22" height="46" rx="4" fill="#251c6a"/>
              </g>

            
              <circle cx="42" cy="108" r="23" fill="#1e1660"/>
              
              <circle cx="42" cy="108" r="23" fill="none" stroke="#7060d8" stroke-width="5"/>
            
              <circle cx="42" cy="108" r="16" fill="#171050"/>
              <circle cx="42" cy="108" r="9"  fill="#120c40"/>
              <circle cx="42" cy="108" r="4"  fill="#0c0830"/>
           
              <path d="M 26,102 A 16,16 0 0 1 58,102" fill="none" stroke="rgba(160,140,255,0.4)" stroke-width="3" stroke-linecap="round"/>

             
              <circle cx="100" cy="150" r="9" fill="#221a68"/>
              
              <rect x="88" y="158" width="24" height="8" rx="3" fill="#1e1660"/>

              
              <line x1="100" y1="165" x2="38"  y2="272" stroke="#1a1460" stroke-width="7" stroke-linecap="round"/>
            
              <line x1="100" y1="165" x2="100" y2="278" stroke="#1a1460" stroke-width="7" stroke-linecap="round"/>
             
              <line x1="100" y1="165" x2="158" y2="272" stroke="#1a1460" stroke-width="7" stroke-linecap="round"/>
            
              <circle cx="38"  cy="272" r="5" fill="#161058"/>
              <circle cx="100" cy="278" r="5" fill="#161058"/>
              <circle cx="158" cy="272" r="5" fill="#161058"/>

              
            
              <ellipse cx="144" cy="262" rx="10" ry="16" fill="#141050" transform="rotate(-25 144 262)"/>
             
              <ellipse cx="162" cy="258" rx="9"  ry="18" fill="#120e48" transform="rotate(15 162 258)"/>
             
              <ellipse cx="100" cy="282" rx="55" ry="12" fill="#111028"/>
            </svg>

            <!-- LIGHT MODE -->
            <svg id="sLt" viewBox="0 0 200 300" xmlns="http://www.w3.org/2000/svg" style="display:none">
              <defs>
                <linearGradient id="barLt" x1="0%" y1="0%" x2="100%" y2="0%">
                  <stop offset="0%" stop-color="#ffffff"/>
                  <stop offset="100%" stop-color="#ede9fe"/>
                </linearGradient>
              </defs>
              <g transform="rotate(-38 100 150)">
                <rect x="28" y="133" width="130" height="34" rx="17" fill="url(#barLt)"/>
                <rect x="120" y="133" width="18" height="34" rx="4" fill="#ddd6fe"/>
                <rect x="146" y="127" width="22" height="46" rx="10" fill="#e8e2ff"/>
                <rect x="20" y="128" width="22" height="46" rx="4" fill="#ddd6fe"/>
              </g>
              <circle cx="42" cy="108" r="23" fill="#e8e2ff"/>
              <circle cx="42" cy="108" r="23" fill="none" stroke="#7c3aed" stroke-width="5"/>
              <circle cx="42" cy="108" r="16" fill="#d4c8ff"/>
              <circle cx="42" cy="108" r="9"  fill="#a78bfa"/>
              <circle cx="42" cy="108" r="4"  fill="#7c3aed"/>
              <circle cx="100" cy="150" r="9" fill="#c4b5fd"/>
              <rect x="88" y="158" width="24" height="8" rx="3" fill="#c4b5fd"/>
              <line x1="100" y1="165" x2="38"  y2="272" stroke="#c4b5fd" stroke-width="6" stroke-linecap="round"/>
              <line x1="100" y1="165" x2="100" y2="278" stroke="#c4b5fd" stroke-width="6" stroke-linecap="round"/>
              <line x1="100" y1="165" x2="158" y2="272" stroke="#c4b5fd" stroke-width="6" stroke-linecap="round"/>
              <ellipse cx="144" cy="262" rx="10" ry="16" fill="#c4b5fd" transform="rotate(-25 144 262)"/>
              <ellipse cx="162" cy="258" rx="9"  ry="18" fill="#a78bfa" transform="rotate(15 162 258)"/>
              <ellipse cx="100" cy="282" rx="55" ry="12" fill="rgba(196,181,253,0.3)"/>
            </svg>
          </div>

          <!-- HILLS -->
          <svg class="hills" viewBox="0 0 1440 190" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
           
            <path d="M-10,148 C80,96 210,162 390,126 C560,90 660,84 820,126
                     C990,170 1120,94 1260,110 C1360,122 1410,136 1450,128
                     L1450,190 L-10,190 Z"
              fill="var(--ha)"/>
            
            <path d="M-10,160 C100,120 240,172 430,146 C610,118 710,112 870,152
                     C1040,194 1180,128 1320,142 C1400,150 1430,162 1450,156
                     L1450,190 L-10,190 Z"
              fill="var(--hb)"/>
          </svg>

          <!-- CENTER CONTENT -->
          <section class="ctr">
            <div class="num">404</div>
            <h1 class="ttl">Page Not <span>Found</span></h1>
            <p class="sub">Oops! The page you're looking for doesn't exist<br>or has been moved.</p>
            <div class="acts">
              <a href="/" class="b1">
                <svg class="bi" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                  <path d="M3 10.5L12 3L21 10.5"/><path d="M5 9.8V20H19V9.8"/>
                </svg>
                Return to Home
              </a>
              <button id="goBack" class="b2">
                <svg class="bi" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M19 12H5"/><path d="M12 19L5 12L12 5"/>
                </svg>
                Go Back
              </button>
            </div>
          </section>
        </main>

        <!-- FOOTER -->
        <footer class="ftr">
          <div class="fl">
            <svg class="fsvg" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="1.8">
              <path d="M12 2L20 6V12C20 17 16.6 21.4 12 22C7.4 21.4 4 17 4 12V6L12 2Z"/>
              <rect x="9" y="10" width="6" height="5" rx="1.2"/>
              <path d="M10 10V8.8C10 7.3 10.9 6.3 12 6.3C13.1 6.3 14 7.3 14 8.8V10"/>
            </svg>
            <div>
              <div class="fn">Recursive <b>Auth</b></div>
              <div class="fs">Secure. Simple. Recursive.</div>
            </div>
          </div>
          <div>© 2026 Recursive Auth. All rights reserved.</div>
        </footer>
      </div>
    </div>

    <script>
      const SK   = "recursive-theme";
      const root = document.documentElement;
      const tog  = document.getElementById("tog");
      const tlbl = document.getElementById("tlbl");
      const iM   = document.getElementById("iMoon");
      const iS   = document.getElementById("iSun");
      const sDk  = document.getElementById("sDk");
      const sLt  = document.getElementById("sLt");
      const cDk  = document.getElementById("cDk");
      const cDkGlw = document.getElementById("cDkGlw");
      const cLt  = document.getElementById("cLt");

      function set(t) {
        root.setAttribute("data-theme", t);
        const dk = t === "dark";
        iM.style.display     = dk ? "" : "none";
        iS.style.display     = dk ? "none" : "";
        tlbl.textContent     = dk ? "Dark Mode" : "Light Mode";
        sDk.style.display    = dk ? "" : "none";
        sLt.style.display    = dk ? "none" : "";
        cDk.style.display    = dk ? "" : "none";
        cDkGlw.style.display = dk ? "" : "none";
        cLt.style.display    = dk ? "none" : "";
      }

      set(root.getAttribute("data-theme") || "dark");

      tog.addEventListener("click", () => {
        const n = root.getAttribute("data-theme") === "dark" ? "light" : "dark";
        localStorage.setItem(SK, n);
        set(n);
      });

      document.getElementById("goBack").addEventListener("click", () => {
        window.history.length > 1 ? window.history.back() : (window.location.href = "/");
      });
    </script>
  </body>
</html>