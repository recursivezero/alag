---
import MainLayout from "../layouts/MainLayout.astro";
---

<style>
  :root {
    --bg: #071026;
    --panel: rgba(15, 27, 42, 0.72);
    --muted: #9aa6bf;
    --line: rgba(255, 255, 255, 0.06);
    --accent-start: #7c5cfc;
    --accent-end: #8e5ef8;
  }

  .page {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 2rem;
    background:
      radial-gradient(
        circle at top left,
        rgba(124, 92, 252, 0.22),
        transparent 28%
      ),
      radial-gradient(
        circle at bottom right,
        rgba(78, 208, 255, 0.12),
        transparent 24%
      ),
      linear-gradient(180deg, var(--bg), #04101f 70%, #02070f);
  }

  .card {
    width: min(100%, 1080px);
    min-height: 520px;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: var(--panel);
    backdrop-filter: blur(10px);
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.45);
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr;
  }

  @media (min-width: 920px) {
    .card {
      grid-template-columns: 1fr 1fr;
    }
  }

  .left,
  .right {
    padding: clamp(1.5rem, 4vw, 3rem);
  }

  .left {
  }

  .eyebrow {
    color: #d7dcff;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  h1,
  h2 {
    color: #fff;
    margin: 0;
    line-height: 1.05;
  }

  h1 {
    font-size: clamp(2rem, 4vw, 3.1rem);
    margin-bottom: 0.85rem;
  }

  h2 {
    font-size: clamp(1.5rem, 2.4vw, 2rem);
    margin-bottom: 0.7rem;
  }

  p {
    color: var(--muted);
    margin: 0 0 1.5rem;
    line-height: 1.6;
  }

  .field {
    margin-bottom: 1rem;
  }

  .input {
    width: 100%;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.03);
    color: #fff;
    border-radius: 12px;
    padding: 0.95rem 1rem;
    font-size: 1rem;
    outline: none;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .input:focus {
    border-color: rgba(124, 92, 252, 0.7);
    box-shadow: 0 0 0 4px rgba(124, 92, 252, 0.15);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    border: none;
    border-radius: 12px;
    padding: 0.95rem 1.3rem;
    font-weight: 700;
    color: #fff;
    cursor: pointer;
    background: linear-gradient(90deg, var(--accent-start), var(--accent-end));
    box-shadow: 0 14px 30px rgba(124, 92, 252, 0.28);
    transition:
      transform 0.18s ease,
      filter 0.18s ease;
  }

  .btn:hover {
    transform: translateY(-1px);
    filter: brightness(1.04);
  }

  .btn:disabled {
    opacity: 0.7;
    cursor: wait;
    transform: none;
  }

  .backlink {
    display: inline-block;
    margin-top: 1rem;
    color: #9fb0ff;
    text-decoration: none;
  }

  .status {
    margin-top: 1rem;
    min-height: 1.2rem;
    color: #7df3a3;
  }

  .helper {
    margin-top: 0.75rem;
    font-size: 0.92rem;
    color: var(--muted);
  }
</style>

<MainLayout page="login" title="Forgot Password">
  <div class="page">
    <div class="card">
      <section class="left">
        <div class="eyebrow">Recursive Auth</div>
        <h1>Forgot Password</h1>
        <p>
          Enter your email and we will send a reset code. After that, you will
          be redirected to the reset password page.
        </p>

        <div class="field">
          <input
            id="email"
            class="input"
            type="email"
            placeholder="you@example.com"
          />
        </div>

        <button id="sendBtn" class="btn" type="button">Send Reset Code</button>
        <div class="helper">
          If mail is not configured, the code is shown in the backend console.
        </div>
        <a href="/login" class="backlink">Back to login</a>
        <div id="msg" class="status"></div>
      </section>
    </div>
  </div>

  <script>
    const apiBase = "http://localhost:5001/api";

    document.getElementById("sendBtn")?.addEventListener("click", async () => {
      const emailEl = document.getElementById(
        "email",
      ) as HTMLInputElement | null;
      if (!emailEl) return;
      const email = emailEl.value.trim();
      if (!email) return alert("Email required");

      const button = document.getElementById("sendBtn");
      if (button instanceof HTMLButtonElement) {
        button.disabled = true;
        button.textContent = "Sending…";
      }

      try {
        const res = await fetch(`${apiBase}/forgot-password`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email }),
        });

        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
          throw new Error(data.message || `Request failed (${res.status})`);
        }

        const msgEl = document.getElementById("msg");
        if (msgEl) msgEl.textContent = data.message || "Reset code sent";

        window.location.href = `/reset-password?email=${encodeURIComponent(email)}`;
      } catch (error) {
        console.error("Forgot password error:", error);
        alert(
          error instanceof Error ? error.message : "Could not send request",
        );
      } finally {
        if (button instanceof HTMLButtonElement) {
          button.disabled = false;
          button.textContent = "Send Reset Code";
        }
      }
    });
  </script>
</MainLayout>
