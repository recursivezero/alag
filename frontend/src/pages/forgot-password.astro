---
import MainLayout from "../layouts/MainLayout.astro";
---

<style>
  :root {
    --bg: #06101f;
    --card: rgba(13, 22, 39, 0.78);
    --card-border: rgba(255, 255, 255, 0.08);
    --text: #f4f7ff;
    --muted: #9ca9c7;
    --line: rgba(255, 255, 255, 0.08);
    --accent-start: #7c5cfc;
    --accent-end: #8f5cff;
    --accent-glow: rgba(124, 92, 252, 0.24);
    --success: #76e3a8;
    --error: #ff8fa3;
  }

  .page {
    min-height: calc(100vh - 72px);
    display: grid;
    place-items: center;
    padding: 2rem 1.25rem 3rem;
    background:
      radial-gradient(
        circle at top left,
        rgba(124, 92, 252, 0.24),
        transparent 28%
      ),
      radial-gradient(
        circle at bottom right,
        rgba(79, 214, 255, 0.1),
        transparent 26%
      ),
      linear-gradient(180deg, #06101f 0%, #050b15 64%, #02060d 100%);
  }

  .card {
    width: min(100%, 620px);
    border: 1px solid var(--card-border);
    border-radius: 24px;
    background: var(--card);
    backdrop-filter: blur(14px);
    box-shadow:
      0 28px 80px rgba(0, 0, 0, 0.48),
      0 0 0 1px rgba(124, 92, 252, 0.04);
    padding: clamp(1.6rem, 4vw, 3rem);
    position: relative;
    overflow: hidden;
    animation: floatIn 0.5s ease both;
    transition:
      transform 0.28s ease,
      box-shadow 0.28s ease,
      border-color 0.28s ease;
  }

  .card:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.12);
    box-shadow:
      0 34px 92px rgba(0, 0, 0, 0.54),
      0 0 0 1px rgba(124, 92, 252, 0.08);
  }

  .card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.06),
      transparent 35%
    );
    pointer-events: none;
  }

  .header {
    text-align: center;
    margin-bottom: 2rem;
    position: relative;
    z-index: 1;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    margin-bottom: 1.05rem;
    border-radius: 20px;
    background: rgba(124, 92, 252, 0.16);
    color: #bba9ff;
    box-shadow: 0 0 0 10px rgba(124, 92, 252, 0.05);
  }

  .eyebrow {
    color: #d8deff;
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  h1 {
    margin: 0;
    color: var(--text);
    font-size: clamp(2rem, 4vw, 3.1rem);
    line-height: 1.04;
  }

  .description {
    margin: 0.9rem auto 0;
    max-width: 32rem;
    color: var(--muted);
    line-height: 1.7;
    font-size: 1.02rem;
  }

  .form {
    position: relative;
    z-index: 1;
  }

  .field-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.85rem;
    align-items: center;
  }

  .input {
    width: 100%;
    min-width: 0;
    border: 1px solid var(--line);
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.05),
        rgba(255, 255, 255, 0.02)
      ),
      rgba(255, 255, 255, 0.03);
    color: var(--text);
    border-radius: 16px;
    min-height: 56px;
    padding: 1rem 1.05rem;
    font-size: 1rem;
    outline: none;
    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, 0.03),
      inset 0 -10px 24px rgba(0, 0, 0, 0.12);
    transition:
      border-color 0.18s ease,
      box-shadow 0.18s ease,
      transform 0.18s ease,
      background-color 0.18s ease;
  }

  .input::placeholder {
    color: #7f8aa6;
  }

  .input:focus {
    border-color: rgba(124, 92, 252, 0.78);
    box-shadow:
      0 0 0 4px rgba(124, 92, 252, 0.18),
      0 0 26px rgba(124, 92, 252, 0.16),
      inset 0 1px 1px rgba(255, 255, 255, 0.04),
      inset 0 -10px 24px rgba(0, 0, 0, 0.12);
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    border: none;
    border-radius: 16px;
    min-height: 56px;
    padding: 1rem 1.35rem;
    min-width: 170px;
    font-weight: 700;
    color: #fff;
    cursor: pointer;
    background: linear-gradient(90deg, var(--accent-start), var(--accent-end));
    box-shadow: 0 16px 32px var(--accent-glow);
    transition:
      transform 0.18s ease,
      filter 0.18s ease,
      box-shadow 0.18s ease,
      opacity 0.18s ease;
    white-space: nowrap;
  }

  .button:hover {
    transform: translateY(-1px);
    filter: brightness(1.08);
    box-shadow:
      0 20px 42px rgba(124, 92, 252, 0.38),
      0 0 0 1px rgba(255, 255, 255, 0.08),
      0 0 32px rgba(124, 92, 252, 0.18);
  }

  .button:disabled {
    cursor: wait;
    opacity: 0.78;
    transform: none;
  }

  .button-spinner {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.35);
    border-top-color: #fff;
    animation: spin 0.7s linear infinite;
    flex: 0 0 auto;
  }

  .divider {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 0.9rem;
    margin: 1.9rem 0 1.15rem;
    color: #8792ae;
    font-size: 0.88rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }

  .divider::before,
  .divider::after {
    content: "";
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.1),
      transparent
    );
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    color: #aebcff;
    text-decoration: none;
    font-weight: 600;
    transition:
      color 0.18s ease,
      opacity 0.18s ease,
      transform 0.18s ease;
  }

  .back-link:hover {
    color: #d5dcff;
    transform: translateX(2px);
  }

  .back-link .arrow {
    display: inline-flex;
    transition: transform 0.18s ease;
  }

  .back-link:hover .arrow {
    transform: translateX(-2px);
  }

  .toast {
    position: fixed;
    left: 50%;
    bottom: 1.5rem;
    transform: translateX(-50%) translateY(18px) scale(0.985);
    min-width: min(92vw, 460px);
    max-width: 92vw;
    padding: 1rem 1.1rem;
    border-radius: 18px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: linear-gradient(
      180deg,
      rgba(11, 18, 34, 0.98),
      rgba(7, 14, 28, 0.96)
    );
    color: var(--text);
    box-shadow: 0 22px 48px rgba(0, 0, 0, 0.35);
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 5s ease,
      transform 5s ease,
      border-color 5s ease,
      box-shadow 5s ease;
    z-index: 30;
  }

  .toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0) scale(1);
  }

  .toast.success {
    border-color: rgba(118, 227, 168, 0.24);
    box-shadow:
      0 0 0 1px rgba(118, 227, 168, 0.1),
      0 22px 48px rgba(0, 0, 0, 0.35);
  }

  .toast.error {
    border-color: rgba(255, 143, 163, 0.24);
  }

  .toast-title {
    font-size: 0.98rem;
    margin: 0;
    color: var(--text);
  }

  .toast-text {
    margin: 0.2rem 0 0;
    color: var(--muted);
    font-size: 0.94rem;
    line-height: 1.5;
  }

  .toast-content {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
  }

  .toast-icon {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 12px;
    background: rgba(118, 227, 168, 0.12);
    color: var(--success);
    box-shadow: 0 0 0 1px rgba(118, 227, 168, 0.1);
  }

  .toast-body {
    min-width: 0;
  }

  @keyframes floatIn {
    from {
      opacity: 0;
      transform: translateY(16px) scale(0.985);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  @media (max-width: 640px) {
    .card {
      padding: 1.4rem;
    }

    .field-row {
      grid-template-columns: 1fr;
    }

    .button {
      width: 100%;
      min-width: 0;
    }
  }
</style>

<MainLayout page="login" title="Forgot Password">
  <div class="page">
    <section class="card" aria-labelledby="forgot-heading">
      <div class="header">
        <div class="badge" aria-hidden="true">
          <svg
            viewBox="0 0 24 24"
            width="28"
            height="28"
            fill="none"
            stroke="currentColor"
            stroke-width="1.9"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M12 2a5 5 0 0 0-5 5v3H6a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-7a2 2 0 0 0-2-2h-1V7a5 5 0 0 0-5-5Z"
            ></path>
            <path d="M9 10V7a3 3 0 0 1 6 0v3"></path>
          </svg>
        </div>
        <div class="eyebrow">Recursive Auth</div>
        <h1 id="forgot-heading">Forgot Password</h1>
        <p class="description">
          Enter your email and we’ll send you a secure reset link.
        </p>
      </div>

      <form id="forgotForm" class="form" novalidate>
        <div class="field-row">
          <input
            id="email"
            class="input"
            type="email"
            placeholder="you@example.com"
            autocomplete="email"
            required
          />
          <button id="sendBtn" class="button" type="submit">
            <span class="button-label">Send Reset Link</span>
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M5 12h13"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg>
          </button>
        </div>

        <div class="divider">or</div>

        <a href="/login" class="back-link">
         
          <span class="arrow" aria-hidden="true">
            ↩
          </span>
           Back to login 
        </a>
      </form>
    </section>
  </div>

  <div
    id="toast"
    class="toast"
    role="status"
    aria-live="polite"
    aria-atomic="true"
  >
    <div class="toast-content">
      <div id="toastIcon" class="toast-icon" aria-hidden="true">
        <svg
          viewBox="0 0 24 24"
          width="18"
          height="18"
          fill="none"
          stroke="currentColor"
          stroke-width="2.4"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M20 6 9 17l-5-5"></path>
        </svg>
      </div>
      <div class="toast-body">
        <p id="toastTitle" class="toast-title"></p>
        <p id="toastText" class="toast-text"></p>
      </div>
    </div>
  </div>

  <script>
    const apiBase = (
      import.meta.env.PUBLIC_API_BASE_URL?.trim() || "http://localhost:5001/api"
    ).replace(/\/$/, "");
    const form = document.getElementById("forgotForm");
    const emailInput = document.getElementById("email");
    const sendBtn = document.getElementById("sendBtn");
    const sendBtnLabel = document.querySelector("#sendBtn .button-label");
    const toast = document.getElementById("toast");
    const toastTitle = document.getElementById("toastTitle");
    const toastText = document.getElementById("toastText");
    const toastIcon = document.getElementById("toastIcon");
    let toastTimer;

    const showToast = (title, text, type = "success") => {
      if (!toast || !toastTitle || !toastText) return;
      toast.classList.remove("success", "error", "show");
      toast.classList.add(type);
      toastTitle.textContent = title;
      toastText.textContent = text;
      if (toastIcon instanceof HTMLElement) {
        toastIcon.style.color =
          type === "success" ? "var(--success)" : "var(--error)";
        toastIcon.style.background =
          type === "success"
            ? "rgba(118, 227, 168, 0.12)"
            : "rgba(255, 143, 163, 0.12)";
        toastIcon.style.boxShadow =
          type === "success"
            ? "0 0 0 1px rgba(118, 227, 168, 0.1)"
            : "0 0 0 1px rgba(255, 143, 163, 0.1)";
      }
      requestAnimationFrame(() => toast.classList.add("show"));
      window.clearTimeout(toastTimer);
      toastTimer = window.setTimeout(() => {
        toast.classList.remove("show");
      }, 3800);
    };

    const setLoading = (loading) => {
      if (!(sendBtn instanceof HTMLButtonElement)) return;
      sendBtn.disabled = loading;
      if (sendBtnLabel instanceof HTMLElement) {
        sendBtnLabel.textContent = loading ? "Sending..." : "Send Reset Link";
      }

      sendBtn.innerHTML = loading
        ? '<span class="button-label">Sending...</span><span class="button-spinner" aria-hidden="true"></span>'
        : '<span class="button-label">Send Reset Link</span><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h13"></path><path d="m12 5 7 7-7 7"></path></svg>';
    };

    const validateEmail = (value) => {
      const email = value.trim();
      return Boolean(email) && /.+@.+\..+/.test(email);
    };

    if (form) {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (!(emailInput instanceof HTMLInputElement)) return;

        const email = emailInput.value.trim();
        if (!validateEmail(email)) {
          showToast(
            "Enter a valid email address",
            "Use the format you@example.com.",
            "error",
          );
          emailInput.focus();
          return;
        }

        setLoading(true);

        try {
          const response = await fetch(`${apiBase}/forgot-password`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email }),
          });

          const data = await response.json().catch(() => ({}));
          if (!response.ok) {
            throw new Error(
              data.message || `Request failed (${response.status})`,
            );
          }

          showToast(
            "Check your inbox",
            "If an account exists, a secure reset link has been sent.",
            "success",
          );
          emailInput.value = "";
        } catch (error) {
          showToast(
            "Could not send reset link",
            error instanceof Error ? error.message : "Please try again.",
            "error",
          );
        } finally {
          setLoading(false);
        }
      });
    }
  </script>
</MainLayout>
