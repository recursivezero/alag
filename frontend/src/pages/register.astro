---
import MainLayout from "../layouts/MainLayout.astro";
import PublicRegisterForm from "../components/auth/PublicRegisterForm.astro";
---

<MainLayout page="register">
  <div class="register-page-shell">
    <div class="register-hero">
      <h2 class="register-title">Join Us</h2>
      <div class="register-divider" aria-hidden="true"></div>
    </div>
    <div class="card register-card">
      <PublicRegisterForm />
      <div class="card-footer">
        Already have an account? <a href="/login">Sign in</a>
        <div>
          <a href="/" class="back-link">
            <svg
              width="13"
              height="13"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M19 12H5M12 5l-7 7 7 7"></path></svg
            >
            Back to home
          </a>
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<style>
  .register-page-shell {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    gap: 1.45rem;
  }

  .register-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    margin-top: -0.35rem;
  }

  .register-title {
    font-size: 2.55rem;
    line-height: 1;
    font-weight: 700;
    letter-spacing: -0.05em;
    color: var(--text);
    text-align: center;
  }

  .register-divider {
    position: relative;
    width: min(260px, 100%);
    height: 2px;
    margin-top: 0.95rem;
    border-radius: 999px;
    background: linear-gradient(
      90deg,
      rgba(124, 92, 252, 0),
      rgba(124, 92, 252, 0.9),
      rgba(189, 157, 255, 0.9),
      rgba(124, 92, 252, 0)
    );
    box-shadow: 0 0 18px rgba(124, 92, 252, 0.42);
  }

  .register-divider::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    width: 9px;
    height: 9px;
    transform: translate(-50%, -50%);
    border-radius: 999px;
    background: var(--purple-light);
    box-shadow: 0 0 16px rgba(157, 130, 253, 0.95);
  }

  .register-card {
    margin-top: 0;
  }

  :global(#registerBtn) {
    appearance: none;
    -webkit-appearance: none;
    display: flex !important;
    align-items: center;
    justify-content: center;
    width: 100% !important;
    min-height: 56px;
    padding: 0 1rem !important;
    margin-top: 0.35rem;
    border: 1px solid rgba(124, 92, 252, 0.24) !important;
    border-radius: 15px !important;
    background: linear-gradient(
      90deg,
      #6f49ff 0%,
      #7c5cfc 52%,
      #6b47ff 100%
    ) !important;
    color: #fff !important;
    font-size: 0.96rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.01em;
    text-align: center;
    box-shadow:
      0 10px 26px rgba(124, 92, 252, 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.09) !important;
    cursor: pointer;
    transition:
      transform 0.18s ease,
      box-shadow 0.18s ease,
      filter 0.18s ease;
  }

  :global(#registerBtn:hover:not(:disabled)) {
    transform: translateY(-1px);
    filter: brightness(1.03);
    box-shadow:
      0 14px 30px rgba(124, 92, 252, 0.34),
      0 0 22px rgba(124, 92, 252, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.09) !important;
  }

  :global(#registerBtn:active:not(:disabled)) {
    transform: translateY(0);
  }

  :global(#registerBtn:focus-visible) {
    outline: none;
    box-shadow:
      0 0 0 3px rgba(124, 92, 252, 0.28),
      0 10px 26px rgba(124, 92, 252, 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.09) !important;
  }

  :global(#googleRegisterBtn) {
    width: 100%;
    margin-bottom: 1.5rem;
    padding: 0 !important;
    background: transparent !important;
    border: none !important;
    display: block !important;
  }

  :global(#googleRegisterBtn > div) {
    width: 100% !important;
    min-height: 56px !important;
  }

  :global(#googleRegisterBtn [role="button"]) {
    width: 100% !important;
    height: 56px !important;
    min-height: 56px !important;
    max-width: none !important;
    padding: 0 1rem !important;
    box-sizing: border-box !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 0.6rem !important;
    border: 1px solid rgba(255, 255, 255, 0.14) !important;
    border-radius: 15px !important;
    background: #fff !important;
    color: #121225 !important;
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.75) inset !important;
    overflow: hidden !important;
  }

  :global(#googleRegisterBtn [role="button"] > div) {
    border: 0 !important;
    box-shadow: none !important;
  }

  :global(#googleRegisterBtn [role="button"] > div:nth-child(2)) {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 0.6rem !important;
    width: auto !important;
    height: auto !important;
    padding: 0 !important;
  }

  :global(#googleRegisterBtn [role="button"] svg) {
    width: 18px !important;
    height: 18px !important;
    flex-shrink: 0;
  }

  :global(#googleRegisterBtn),
  :global(#googleRegisterBtn > div) {
    overflow: hidden;
    border-radius: 15px !important;
  }
</style>
