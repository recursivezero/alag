---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout page="welcome">
  <div class="page">
    <div class="card">
      <div style="text-align: center; margin-bottom: 2rem;">
        <svg
          width="48"
          height="48"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          style="margin: 0 auto 1rem; color: #7c5cfc;"
        >
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        <h2 class="card-title">Welcome, <span id="userName">User</span>!</h2>
        <p class="card-sub">You have successfully logged in to recursivezero</p>
      </div>

      <div
        id="userDashboard"
        style="margin: 2rem 0; padding: 1.5rem; background: linear-gradient(135deg, #7c5cfc15 0%, #7c5cfc08 100%); border-radius: 8px; border-left: 4px solid #7c5cfc;"
      >
        <div
          style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;"
        >
          <div>
            <p style="font-size: 0.85rem; color: #999; margin-bottom: 0.25rem;">
              Name
            </p>
            <p
              style="font-size: 1.2rem; font-weight: 600; color: #333;"
              id="dashName"
            >
              Loading...
            </p>
          </div>
          <div>
            <p style="font-size: 0.85rem; color: #999; margin-bottom: 0.25rem;">
              Email
            </p>
            <p
              style="font-size: 1.2rem; font-weight: 600; color: #333;"
              id="dashEmail"
            >
              Loading...
            </p>
          </div>
        </div>
        <div
          style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid #ddd;"
        >
          <p style="font-size: 0.9rem; color: #666;">
            Status: <span style="color: #4CAF50; font-weight: 600;"
              >✓ Verified</span
            >
          </p>
        </div>
      </div>

      <button
        class="btn-primary"
        id="logoutBtn"
        style="width: 100%; margin-top: 2rem; background: #ef4444;"
      >
        Logout
      </button>

      <div class="card-footer">
        <a href="/" class="back-link">
          <svg
            width="13"
            height="13"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M19 12H5M12 5l-7 7 7 7"></path></svg
          >
          Back to home
        </a>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  import {
    clearUserSessionToken,
    validateUserSession,
    watchUserSession,
  } from "../services/session";

  const loginPath = "/login";

  const redirectToLogin = () => {
    clearUserSessionToken();
    window.location.replace(loginPath);
  };

  const ensureSession = async () => {
    const isValid = await validateUserSession();
    if (!isValid) {
      redirectToLogin();
    }
  };

  void ensureSession();

  const stopWatchingSession = watchUserSession(
    () => window.location.replace("/dashboard"),
    redirectToLogin,
  );

  window.addEventListener("beforeunload", () => {
    stopWatchingSession();
  });

  async function fetchUserData() {
    try {
      const res = await fetch("http://localhost:5001/api/user", {
        method: "GET",
        credentials: "include",
      });
      const data = await res.json();
      if (res.ok && data.user) {
        const userNameEl = document.getElementById("userName");
        if (userNameEl) userNameEl.textContent = data.user.name;

        const dashNameEl = document.getElementById("dashName");
        if (dashNameEl) dashNameEl.textContent = data.user.name;

        const dashEmailEl = document.getElementById("dashEmail");
        if (dashEmailEl) dashEmailEl.textContent = data.user.email;
      }
    } catch (error) {
      console.error("Failed to fetch user data:", error);
    }
  }

  const logoutBtn = document.getElementById("logoutBtn");
  if (logoutBtn) {
    logoutBtn.addEventListener("click", () => {
      clearUserSessionToken();
      window.location.replace("/");
    });
  }

  fetchUserData();
</script>

<style>
  .page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 1rem;
  }

  .card {
    background: white;
    border-radius: 12px;
    padding: 2rem;
    max-width: 500px;
    width: 100%;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .card-title {
    font-size: 1.75rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: #333;
  }

  .card-sub {
    color: #666;
    margin-bottom: 1.5rem;
  }

  .btn-primary {
    background: #7c5cfc;
    color: white;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    font-size: 1rem;
    cursor: pointer;
    transition: background 0.2s;
  }

  .btn-primary:hover:not(:disabled) {
    background: #6b4ce3;
  }

  .btn-primary:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .card-footer {
    text-align: center;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid #eee;
  }

  .back-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    color: #7c5cfc;
    text-decoration: none;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: #6b4ce3;
  }
</style>
