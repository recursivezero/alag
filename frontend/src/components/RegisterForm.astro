---

---

<div id="alert" class="alert"></div>

<div class="field">
  <label for="name">Full Name</label>
  <div class="input-wrap">
    <svg
      class="ico"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      ><circle cx="12" cy="8" r="4"></circle><path
        d="M4 20c0-4 3.6-7 8-7s8 3 8 7"></path></svg
    >
    <input
      type="text"
      id="name"
      placeholder="Your full name"
      autocomplete="name"
    />
  </div>
</div>

<div class="field">
  <label for="email">Email Address</label>
  <div class="input-wrap">
    <svg
      class="ico"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      ><rect x="2" y="4" width="20" height="16" rx="2"></rect><path
        d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
    >
    <input
      type="email"
      id="email"
      placeholder="you@example.com"
      autocomplete="email"
    />
  </div>
</div>

<div class="field">
  <label for="password">Password</label>
  <div class="input-wrap">
    <svg
      class="ico"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      ><rect x="3" y="11" width="18" height="11" rx="2"></rect><path
        d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg
    >
    <input
      type="password"
      id="password"
      placeholder="Create a password"
      autocomplete="new-password"
    />
    <button class="toggle-pw" id="togglePw" type="button">
      <svg
        id="eyeIcon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle
          cx="12"
          cy="12"
          r="3"></circle></svg
      >
    </button>
  </div>
</div>

<div class="field">
  <label for="confirm">Confirm Password</label>
  <div class="input-wrap">
    <svg
      class="ico"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      ><path d="M9 12l2 2 4-4"></path><rect
        x="3"
        y="11"
        width="18"
        height="11"
        rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg
    >
    <input
      type="password"
      id="confirm"
      placeholder="Confirm your password"
      autocomplete="new-password"
    />
  </div>
</div>

<button class="btn-primary" id="registerBtn" type="button"
  >Create Account</button
>

<div class="divider">OR</div>

<div
  class="google-auth-slot btn-google google-button-shell"
  id="googleRegisterBtn"
>
</div>

<div class="card-footer">You can also create an account with Google.</div>

<script>
  const googleClientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID;
  import { mountGoogleIdentityButton } from "../services/google-auth";
  const alertEl = document.getElementById("alert");

  function showAlert(msg, type = "error") {
    if (!alertEl) return;
    alertEl.textContent = msg;
    alertEl.className = `alert ${type} show`;
    setTimeout(() => alertEl.classList.remove("show"), 4000);
  }

  const togglePw = document.getElementById("togglePw");
  if (togglePw) {
    togglePw.addEventListener("click", () => {
      const pw = document.getElementById("password");
      if (!(pw instanceof HTMLInputElement)) return;
      const isText = pw.type === "text";
      pw.type = isText ? "password" : "text";
      const eyeIcon = document.getElementById("eyeIcon");
      if (!eyeIcon) return;
      eyeIcon.innerHTML = isText
        ? '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>'
        : '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>';
    });
  }

  const registerBtn = document.getElementById("registerBtn");
  if (registerBtn) {
    registerBtn.addEventListener("click", async () => {
      const nameEl = document.getElementById("name");
      const emailEl = document.getElementById("email");
      const passwordEl = document.getElementById("password");
      const confirmEl = document.getElementById("confirm");

      if (
        !(nameEl instanceof HTMLInputElement) ||
        !(emailEl instanceof HTMLInputElement) ||
        !(passwordEl instanceof HTMLInputElement) ||
        !(confirmEl instanceof HTMLInputElement)
      ) {
        showAlert("Form elements not found on the page.");
        return;
      }

      const name = nameEl.value.trim();
      const email = emailEl.value.trim();
      const password = passwordEl.value;
      const confirm = confirmEl.value;

      if (!name) {
        showAlert("Please enter your full name.");
        return;
      }
      if (!email || !email.includes("@")) {
        showAlert("Please enter a valid email address.");
        return;
      }
      if (password.length < 6) {
        showAlert("Password must be at least 6 characters.");
        return;
      }
      if (password !== confirm) {
        showAlert("Passwords do not match.");
        return;
      }

      if (!(registerBtn instanceof HTMLButtonElement)) return;
      const btn = registerBtn;
      btn.disabled = true;
      btn.textContent = "Creating account…";

      try {
        const res = await fetch("http://localhost:5001/api/register", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ name, email, password }),
        });
        const data = await res.json();
        if (!res.ok) {
          showAlert(data?.message || "Registration failed.");
          btn.disabled = false;
          btn.textContent = "Create Account";
          return;
        }

        showAlert(
          "Account created! Redirecting to OTP verification…",
          "success",
        );
        setTimeout(
          () =>
            (window.location.href = `/verify-otp?email=${encodeURIComponent(email)}`),
          1200,
        );
      } catch (err) {
        console.error(err);
        showAlert("Could not connect to server.");
        btn.disabled = false;
        btn.textContent = "Create Account";
      }
    });
  }

  const googleButton = document.getElementById("googleRegisterBtn");
  if (googleButton) {
    mountGoogleIdentityButton({
      clientId: googleClientId,
      buttonId: "googleRegisterBtn",
      text: "signup_with",
      fallbackLabel: "Sign up with Google",
      onCredential: async (credential: string) => {
        try {
          const res = await fetch("http://localhost:5001/api/google-login", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ credential }),
          });
          const data = await res.json();
          if (!res.ok) {
            showAlert(data.message || "Google sign-up failed.");
            return;
          }

          if (data.token) localStorage.setItem("token", data.token);
          showAlert("Google account created! Redirecting…", "success");
          setTimeout(() => (window.location.href = "/dashboard"), 1200);
        } catch {
          showAlert("Could not complete Google sign-up.");
        }
      },
    }).catch(() => {
      showAlert("Google sign-up could not be started.");
    });
  }

  if (googleButton) {
    mountGoogleIdentityButton({
      clientId: googleClientId,
      buttonId: "googleRegisterBtn",
      text: "signup_with",
      fallbackLabel: "Sign up with Google",
      onCredential: async (credential: string) => {
        try {
          const res = await fetch("http://localhost:5001/api/google-login", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ credential }),
          });
          const data = await res.json();
          if (!res.ok) {
            showAlert(data.message || "Google sign-up failed.");
            return;
          }

          if (data.token) localStorage.setItem("token", data.token);
          showAlert("Google account created! Redirecting…", "success");
          setTimeout(() => (window.location.href = "/dashboard"), 1200);
        } catch {
          showAlert("Could not complete Google sign-up.");
        }
      },
      onUnavailable: () =>
        showAlert(
          "Google sign-in is not configured. Set PUBLIC_GOOGLE_CLIENT_ID in frontend/.env.",
        ),
    }).catch(() => {
      showAlert("Google sign-up could not be started.");
    });
  }
</script>
