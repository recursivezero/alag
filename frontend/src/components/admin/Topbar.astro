---
interface Props {
  title: string;
  eyebrow?: string;
  description?: string;
  searchPlaceholder?: string;
  searchId?: string;
  showSearch?: boolean;
  showNotifications?: boolean;
  showThemeToggle?: boolean;
  showAddUserAction?: boolean;
}
const {
  title,
  eyebrow = "",
  description = "",
  searchPlaceholder = "Search users...",
  searchId = "topSearch",
  showSearch = true,
  showNotifications = true,
  showThemeToggle = true,
  showAddUserAction = false,
} = Astro.props as Props;
---

<header data-admin-surface="topbar" class="mb-6 border-b border-white/6  p-5 pb-6 rounded-[10px]">
  <div
    class="flex flex-col gap-5 xl:flex-row xl:items-start xl:justify-between"
  >
    <!-- LEFT -->
    <div class="min-w-0">
      <h1
        class="text-[42px] font-black leading-none tracking-[-0.06em] text-white"
      >
        {title}
      </h1>

      {
        eyebrow ? (
          <p class="mt-3 text-[18px] font-medium text-slate-400">{eyebrow}</p>
        ) : null
      }

      {
        description ? (
          <p class="mt-2 max-w-2xl text-[14px] leading-7 text-slate-400/80">
            {description}
          </p>
        ) : null
      }
    </div>

    <!-- RIGHT -->
    <div class="flex w-full items-center justify-end gap-3 xl:w-auto">
      <!-- SEARCH -->
      {
        showSearch ? (
          <div class="relative w-full xl:w-[320px]">
            <input
              id={searchId}
              type="text"
              placeholder={searchPlaceholder}
              class="h-[54px] w-full rounded-[50px] border border-white/10 bg-[#060B1B]/90 pl-14 pr-5 text-[14px] font-medium text-white outline-none transition-all duration-200 placeholder:text-slate-500 focus:border-violet-400/50 focus:shadow-[0_0_0_1px_rgba(124,92,252,0.22),0_0_25px_rgba(124,92,252,0.18)]"
            />

            <span class="pointer-events-none absolute left-5 top-1/2 -translate-y-1/2 text-slate-500">
              <svg
                viewBox="0 0 24 24"
                class="h-5 w-5"
                fill="none"
                stroke="currentColor"
                stroke-width="1.9"
              >
                <circle cx="11" cy="11" r="7" />
                <path d="M20 20l-3.5-3.5" />
              </svg>
            </span>
          </div>
        ) : null
      }

      <!-- NOTIFICATION -->
      {
        showNotifications ? (
          <button
            type="button"
            class="relative grid h-[54px] w-[54px] place-items-center rounded-[10px] border border-white/10 bg-[#060B1B]/90 text-slate-200 transition-all duration-200 hover:border-violet-400/40 hover:bg-violet-500/10 hover:text-white"
            aria-label="Notifications"
          >
            <span class="absolute right-[-3px] top-[-3px] grid h-6 min-w-6 place-items-center rounded-full border border-rose-300/30 bg-rose-500 px-1 text-[11px] font-bold text-white shadow-[0_0_18px_rgba(244,63,94,0.45)]">
              3
            </span>

            <svg
              viewBox="0 0 24 24"
              class="h-5 w-5"
              fill="none"
              stroke="currentColor"
              stroke-width="1.9"
            >
              <path d="M18 8a6 6 0 10-12 0c0 7-3 8-3 8h18s-3-1-3-8" />
              <path d="M13.73 21a2 2 0 01-3.46 0" />
            </svg>
          </button>
        ) : null
      }

      <!-- THEME -->
      {
        showThemeToggle ? (
          <button
            id="topThemeToggle"
            type="button"
            aria-label="Theme Toggle"
            data-theme-toggle
            class="grid h-[54px] w-[54px] place-items-center rounded-[10px] border border-white/10 bg-[#060B1B]/90 text-slate-200 transition-all duration-200 hover:border-violet-400/40 hover:bg-violet-500/10 hover:text-white"
          >
            <svg
              viewBox="0 0 24 24"
              class="h-5 w-5"
              fill="none"
              stroke="currentColor"
              stroke-width="1.9"
            >
              <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
            </svg>
          </button>
        ) : null
      }

      <!-- ADD USER -->
      <!-- {
        showAddUserAction ? (
          <button
            id="addUserBtn"
            type="button"
            class="inline-flex h-[54px] items-center gap-2 rounded-[10px] border border-violet-400/30 bg-[linear-gradient(135deg,#7c5cfc,#6246ea)] px-6 text-[14px] font-semibold text-white shadow-[0_0_30px_rgba(124,92,252,0.25)] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_0_40px_rgba(124,92,252,0.4)]"
          >
            <svg
              viewBox="0 0 24 24"
              class="h-4 w-4"
              fill="none"
              stroke="currentColor"
              stroke-width="2.4"
            >
              <path d="M12 5v14" />
              <path d="M5 12h14" />
            </svg>
            Add User <i class="fa-solid fa-trash" aria-hidden="true" />
          </button>
        ) : null
      } -->
    </div>
  </div>
</header>
