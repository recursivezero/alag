---
interface Props {
  bodyId?: string;
  paginationId?: string;
  metaId?: string;
  variant?: "dashboard" | "users";
}

const {
  bodyId = "usersTableBody",
  paginationId = "pagination",
  metaId = "tableMeta",
  variant = "users",
} = Astro.props as Props;

const headers =
  variant === "dashboard"
    ? [
        { label: "", icon: "hash" },
        { label: "Full Name", icon: "user" },
        { label: "Email", icon: "mail" },
        { label: "Role", icon: "shield" },
        { label: "Status", icon: "status" },
        { label: "Joined On", icon: "calendar" },
      ]
    : [
        { label: "", icon: "hash" },
        { label: "Full Name", icon: "user" },
        { label: "Email", icon: "mail" },
        { label: "Date Joined", icon: "calendar" },
        { label: "Status", icon: "status" },
        { label: "Actions", icon: "setting" },
      ];

const iconSvg = {
  hash: '<path d="M5 9h14M4 15h14M10 4 8 20M16 4l-2 16"/>',
  user: '<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/>',
  shield:
    '<path d="M12 3 5 6v6c0 4.5 3 7.7 7 9 4-1.3 7-4.5 7-9V6l-7-3Z"/><path d="m9.5 12 1.8 1.8 3.2-3.2"/>',
  status: '<circle cx="12" cy="12" r="8"/><path d="m9.5 12 1.7 1.7 3.3-3.4"/>',
  calendar:
    '<rect x="3" y="5" width="18" height="16" rx="2"/><path d="M16 3v4M8 3v4M3 10h18"/>',
  setting:
    '<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.7 1.7 0 0 0 .34 1.87l.03.03a2 2 0 1 1-2.83 2.83l-.03-.03A1.7 1.7 0 0 0 15 19.4a1.7 1.7 0 0 0-1 .6 1.7 1.7 0 0 1-3 0 1.7 1.7 0 0 0-1-.6 1.7 1.7 0 0 0-1.87.34l-.03.03a2 2 0 1 1-2.83-2.83l.03-.03A1.7 1.7 0 0 0 4.6 15a1.7 1.7 0 0 0-.6-1 1.7 1.7 0 0 1 0-3 1.7 1.7 0 0 0 .6-1 1.7 1.7 0 0 0-.34-1.87l-.03-.03a2 2 0 1 1 2.83-2.83l.03.03A1.7 1.7 0 0 0 9 4.6a1.7 1.7 0 0 0 1-.6 1.7 1.7 0 0 1 3 0 1.7 1.7 0 0 0 1 .6 1.7 1.7 0 0 0 1.87-.34l.03-.03a2 2 0 1 1 2.83 2.83l-.03.03A1.7 1.7 0 0 0 19.4 9c.24.32.44.67.6 1a1.7 1.7 0 0 1 0 3c-.16.33-.36.68-.6 1Z"/>',
  actions:
    '<circle cx="6" cy="12" r="1.4"/><circle cx="12" cy="12" r="1.4"/><circle cx="18" cy="12" r="1.4"/>',
} as const;

const getHeaderCellClass = (label: string) => {
  const base =
    "px-4 py-4 text-[14px] font-medium text-[#d7deed] whitespace-nowrap align-middle";

  if (label === "#") {
    return `${base} w-[72px] text-center`;
  }

  if (label === "Actions") {
    return `${base} w-[260px] text-center`;
  }

  return `${base} text-left`;
};

const getHeaderInnerClass = (label: string) => {
  if (label === "#" || label === "Actions") {
    return "inline-flex items-center justify-center gap-2";
  }

  return "inline-flex items-center gap-2";
};
---

<section data-admin-surface="table" class="w-full">
  <div
    data-admin-surface="table"
    class="admin-premium-table overflow-hidden
      rounded-[10px]
      border
      border-[#1b2b45]
      bg-[linear-gradient(180deg,#0b1320_0%,#08111d_100%)]"
  >
    <!-- TABLE -->
    <div class="">
      <table
        class:list={[
          "w-full border-collapse text-left  ",
          variant === "dashboard" ? "min-w-[980px]" : "min-w-[1060px]",
        ]}
      >
        <!-- HEADER -->
        <thead>
          <tr
            class="border-b
              border-white/6
              bg-[linear-gradient(180deg,rgba(70,98,201,0.16),rgba(20,30,63,0.16))]"
          >
            {
              headers.map((header) => (
                <th class={getHeaderCellClass(header.label)}>
                  <span class={getHeaderInnerClass(header.label)}>
                    <span class="inline-flex h-8 w-8 items-center justify-center rounded-[10px] border border-[#6f7ee5]/35 bg-[linear-gradient(180deg,rgba(58,74,162,0.42),rgba(33,43,103,0.35))] text-slate-100">
                      <svg
                        viewBox="0 0 24 24"
                        class="h-4 w-4"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.8"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        set:html={iconSvg[header.icon]}
                      />
                    </span>
                    <span>{header.label}</span>
                  </span>
                </th>
              ))
            }
          </tr>
        </thead>

        <!-- BODY -->
        <tbody id={bodyId} class="admin-table-body"></tbody>
      </table>
    </div>

    <!-- FOOTER -->
    <div
      class="flex
        items-center
        justify-between
        gap-4
        border-t
        border-white/5
        px-5
        py-5"
    >
      <p id={metaId} class="text-[14px]
          text-slate-400">
        Showing 0 users
      </p>

      <div id={paginationId} class="flex
          items-center
          gap-4">
      </div>
    </div>
  </div>
</section>

<style is:global>
  .admin-premium-table {
    --table-shell-border: rgba(148, 163, 184, 0.16);
    --table-shell-bg: rgba(255, 255, 255, 0.94);
    --table-row-odd: #ffffff;
    --table-row-even: #f4f7fc;
    --table-row-hover: #e9eefb;
    --table-row-divider: rgba(148, 163, 184, 0.12);
    --table-head-bg: rgba(248, 250, 252, 0.94);
    --table-head-border: rgba(148, 163, 184, 0.18);
    --table-text: #0f172a;
    --table-muted: #475569;
    --table-head-text: #334155;
    border-color: var(--table-shell-border) !important;
    background: var(--table-shell-bg) !important;
    box-shadow:
      0 18px 50px rgba(15, 23, 42, 0.08),
      0 0 0 1px rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(18px) saturate(140%);
    -webkit-backdrop-filter: blur(18px) saturate(140%);
  }

  html[data-admin-theme="dark"] .admin-premium-table {
    --table-shell-border: rgba(124, 92, 252, 0.14);
    --table-shell-bg: linear-gradient(
      180deg,
      rgba(7, 11, 22, 0.841),
      rgba(4, 8, 18, 0.548)
    );
    --table-row-odd: rgba(255, 255, 255, 0.02);
    --table-row-even: rgba(255, 255, 255, 0.05);
    --table-row-hover: rgba(124, 92, 255, 0.12);
    --table-row-divider: rgba(255, 255, 255, 0.04);
    --table-head-bg: rgba(10, 14, 28, 0.9);
    --table-head-border: rgba(124, 92, 252, 0.14);
    --table-text: #e5edf9;
    --table-muted: rgba(226, 232, 240, 0.76);
    --table-head-text: #dbe3f0;
    box-shadow:
      0 20px 60px rgba(0, 0, 0, 0.34),
      0 0 0 1px rgba(124, 92, 252, 0.08),
      0 0 30px rgba(124, 92, 252, 0.08);
  }

  .admin-premium-table thead th {
    position: sticky;
    top: 0;
    z-index: 20;
    background: var(--table-head-bg) !important;
    color: var(--table-head-text) !important;
    border-bottom: 1px solid var(--table-head-border) !important;
    backdrop-filter: blur(18px) saturate(145%);
    -webkit-backdrop-filter: blur(18px) saturate(145%);
  }

  .admin-premium-table tbody tr {
    transition:
      background-color 0.25s ease,
      transform 0.2s ease,
      box-shadow 0.25s ease;
  }

  .admin-premium-table tbody tr td {
    background: transparent !important;
    color: var(--table-text) !important;
    border-bottom: 1px solid var(--table-row-divider);
    transition:
      background-color 0.25s ease,
      color 0.2s ease,
      border-color 0.25s ease;
  }

  .admin-premium-table tbody tr:nth-child(odd) td {
    background: var(--table-row-odd) !important;
  }

  .admin-premium-table tbody tr:nth-child(even) td {
    background: var(--table-row-even) !important;
  }

  .admin-premium-table tbody tr:hover td {
    background: var(--table-row-hover) !important;
  }

  .admin-premium-table tbody tr:hover {
    transform: translateY(-1px);
  }

  .admin-premium-table tbody tr td:first-child {
    border-top-left-radius: 12px;
    border-bottom-left-radius: 12px;
  }

  .admin-premium-table tbody tr td:last-child {
    border-top-right-radius: 12px;
    border-bottom-right-radius: 12px;
  }

  .admin-premium-table tbody tr:last-child td {
    border-bottom-color: transparent;
  }

  .admin-premium-table tbody td,
  .admin-premium-table tbody th {
    position: relative;
  }

  .admin-premium-table tbody tr td p,
  .admin-premium-table tbody tr td span,
  .admin-premium-table tbody tr td div {
    position: relative;
    z-index: 1;
  }
</style>
