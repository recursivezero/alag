---
import Avatar from "../ui/Avatar.astro";
import ProfileDropdown from "./ProfileDropdown.astro";
import type { UserProfile } from "../../types/user";

const { user, sidebarOffset = true } = Astro.props as {
  user: UserProfile;
  sidebarOffset?: boolean;
};
---

<header
  class="sticky top-0 z-30 border-b border-[color:var(--dashboard-border)] bg-[color:var(--dashboard-surface-strong)]/95 backdrop-blur-2xl"
>
  <div
    class:list={[
      "mx-auto flex w-full max-w-7xl items-center gap-4 px-4 py-4 lg:px-8",
      sidebarOffset ? "lg:pl-[18rem]" : "",
    ]}
  >
    <label class="relative flex-1">
      <span class="sr-only">Search images, users or descriptions</span>
      <svg
        class="pointer-events-none absolute left-4 top-1/2 h-4 w-4 -translate-y-1/2 text-[color:var(--dashboard-muted)]"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
      >
        <circle cx="11" cy="11" r="7"></circle>
        <path d="m20 20-3.5-3.5"></path>
      </svg>
      <input
        type="search"
        placeholder="Search images, users or descriptions..."
        class="w-full rounded-full border border-[color:var(--dashboard-border)] bg-[color:var(--dashboard-surface)] py-3 pl-11 pr-4 text-sm text-[color:var(--dashboard-text)] outline-none transition placeholder:text-[color:var(--dashboard-muted)] focus:border-[color:var(--dashboard-accent)]"
      />
    </label>

    <button
      type="button"
      data-upload-trigger
      class="inline-flex items-center gap-2 rounded-full bg-[color:var(--dashboard-accent)] px-5 py-3 text-sm font-semibold text-white shadow-[0_16px_36px_rgba(124,58,237,0.28)] transition hover:bg-[color:var(--dashboard-accent-strong)]"
    >
      <svg
        class="h-4 w-4"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
      >
        <path d="M12 16V4"></path>
        <path d="m7 9 5-5 5 5"></path>
        <path d="M4 20h16"></path>
      </svg>
      Upload
    </button>

    <button
      type="button"
      class="relative flex h-11 w-11 items-center justify-center rounded-full border border-[color:var(--dashboard-border)] bg-[color:var(--dashboard-surface)] text-[color:var(--dashboard-text)] transition hover:bg-[color:var(--dashboard-accent-soft)]"
    >
      <svg
        class="h-5 w-5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
      >
        <path
          d="M15 17h5l-1.4-1.4A2 2 0 0 1 18 14.2V11a6 6 0 1 0-12 0v3.2c0 .5-.2 1-.6 1.4L4 17h5"
        ></path>
        <path d="M9 17a3 3 0 0 0 6 0"></path>
      </svg>
      <span
        class="absolute right-0 top-0 flex h-5 min-w-5 items-center justify-center rounded-full bg-violet-500 px-1 text-[10px] font-bold text-white"
        >1</span
      >
    </button>

    <ProfileDropdown user={user} />
  </div>
</header>
