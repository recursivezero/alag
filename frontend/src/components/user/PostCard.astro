---
import Avatar from "../ui/Avatar.astro";
import Modal from "../ui/Modal.astro";
import postCardScriptUrl from "../../scripts/post-card.ts?url";

import type { PostItem } from "../../types/post";

import {
  formatCounter,
  formatRelativeTime,
} from "../../services/interactionService";

const { post } = Astro.props as {
  post: PostItem;
};
---

<article
  data-post-card
  data-post-slug={post.slug}
  data-post-author-id={post.author.id}
  data-post-author-username={post.author.username || ""}
  data-post-author-email={post.author.email || ""}
  class="group relative overflow-visible rounded-[28px] border border-white/5 bg-white/[0.03] shadow-[0_18px_50px_rgba(0,0,0,0.22)] transition-[transform,box-shadow,border-color,background-color] duration-300 hover:-translate-y-1 hover:border-white/10 hover:shadow-[0_26px_70px_rgba(0,0,0,0.3)]"
>
  <div class="main-card flex items-center justify-between px-5 pt-5">
    <div class="flex min-w-0 items-center gap-3">
      <Avatar
        src={post.author.picture || "/icon.png"}
        alt={post.author.name}
        size="md"
      />

      <div class="min-w-0">
        <div class="flex items-center gap-2">
          <span
            class="truncate text-[13px] font-semibold text-[color:var(--dashboard-text)] transition hover:text-violet-300"
          >
            {post.author.name}
          </span>

          <span
            class="inline-flex items-center rounded-full border border-violet-500/18 bg-violet-500/10 px-2 py-0.5 text-[10px] font-bold uppercase tracking-[0.16em] text-violet-300"
          >
            New
          </span>
        </div>

        <p
          class="mt-0.5 truncate text-[11px] text-[color:var(--dashboard-muted)]"
        >
          {formatRelativeTime(post.createdAt)}
          ·
          {post.location || "Worldwide"}
        </p>
      </div>
    </div>

    <div class="absolute right-5 top-5 z-30">
      <button
        type="button"
        data-post-menu-btn
        aria-haspopup="true"
        aria-expanded="false"
        class="grid h-10 w-10 place-items-center rounded-full bg-transparent text-[color:var(--dashboard-muted)] transition hover:text-[color:var(--dashboard-text)]"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
          <circle cx="12" cy="5" r="1.75"></circle>

          <circle cx="12" cy="12" r="1.75"></circle>

          <circle cx="12" cy="19" r="1.75"></circle>
        </svg>
      </button>

      <div
        data-post-menu
        role="menu"
        aria-hidden="true"
        class="delete-postcard absolute right-0 mt-2 w-44 origin-top-right rounded-lg border border-[color:var(--dashboard-border)] bg-[color:var(--dashboard-surface)] p-2 shadow-[0_18px_40px_rgba(0,0,0,0.2)] z-40 invisible opacity-0 translate-y-1 transition-[opacity,transform] duration-150"
      >
        <button
          type="button"
          data-post-menu-delete
          class="delete-postcard-btn flex w-full items-center gap-2 rounded-md px-3 py-2 text-left text-sm font-medium text-rose-500 hover:bg-[color:var(--dashboard-accent-soft)]"
          role="menuitem">Delete Post</button
        >
        <button
          type="button"
          data-post-menu-cancel
          class="cancel-postcard-btn mt-1 flex w-full items-center gap-2 rounded-md px-3 py-2 text-left text-sm font-medium text-[color:var(--dashboard-muted)] hover:bg-[color:var(--dashboard-accent-soft)]"
          role="menuitem">Cancel</button
        >
      </div>
    </div>
  </div>

  <div class="main-card2">
    <div class="relative mt-3 block px-4">
      <div class="overflow-hidden rounded-[18px]">
        <img
          src={post.imageUrl}
          alt={post.title}
          loading="lazy"
          class="aspect-[16/7] w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]"
        />
      </div>

      <div
        class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 transition duration-300 group-hover:opacity-100"
      >
      </div>
    </div>

    <div class="px-5 py-5">
      <div class="post-title">
        <div
          class="text-[24px] font-black tracking-[-0.04em] text-[color:var(--dashboard-text)] transition"
        >
          {post.title}
        </div>

        <p
          class="mt-2 line-clamp-2 text-[14px] leading-6 text-[color:var(--dashboard-muted)]"
        >
          {post.caption}
        </p>
      </div>

      <div
        class="mt-5 flex items-center justify-between border-t border-white/5 pt-4"
      >
        <div class="flex items-center gap-2">
          <button
            type="button"
            class="like-btn"
            aria-pressed={post.userState?.liked ? "true" : "false"}
            class:list={[
              "inline-flex items-center gap-2 rounded-[14px] px-3 py-2.5 text-[13px] font-medium transition-[transform,background-color,box-shadow,color]",
              post.userState?.liked
                ? "bg-rose-500/10 text-rose-300"
                : "text-[color:var(--dashboard-muted)] hover:bg-white/[0.04] hover:text-[color:var(--dashboard-muted)] hover:shadow-[0_8px_20px_rgba(0,0,0,0.08)]",
            ]}
          >

    
            <svg
              class="h-5 w-5"
              viewBox="0 0 24 24"
              class="like-icon"
              fill={post.userState?.liked ? "currentColor" : "none"}
              stroke="currentColor"
              stroke-width="1.8"
            >
              <path
                d="M12 20s-7-4.4-7-10a4 4 0 0 1 7-2.6A4 4 0 0 1 19 10c0 5.6-7 10-7 10Z"
              ></path>
            </svg>

            {formatCounter(post.counts.likes)}
          </button>

          <button
            type="button"
            class="comment-btn inline-flex items-center gap-2 rounded-[14px] px-3 py-2.5 text-[13px] font-medium text-[color:var(--dashboard-muted)] transition hover:bg-white/[0.04] hover:text-white"
          >
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
            >
              <path
                d="M7.9 20.5a.8.8 0 0 1-1.3-.6V17a8 8 0 1 1 5.9 1.8 8 8 0 0 1-4.6 1.7Z"
              ></path>
            </svg>

            {formatCounter(post.counts.comments)}
          </button>
        </div>

        <div class="flex items-center gap-2">
          <button
            type="button"
            aria-pressed={post.userState?.saved ? "true" : "false"}
            class="saved-btn"
            class:list={[
              "inline-flex items-center gap-2 rounded-[14px] px-3 py-2.5 text-[13px] font-medium transition-[transform,background-color,box-shadow,color]",
              post.userState?.saved
  ? "bg-violet-500/10 text-violet-300"
  : "text-[color:var(--dashboard-muted)] hover:bg-white/[0.04] hover:text-[color:var(--dashboard-muted)] hover:shadow-[0_8px_20px_rgba(0,0,0,0.08)]"
            ]}
          >
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill={post.userState?.saved ? "currentColor" : "none"}
              stroke="currentColor"
              stroke-width="1.8"
            >
              <path d="M7 4h10a1 1 0 0 1 1 1v16l-6-3-6 3V5a1 1 0 0 1 1-1Z"
              ></path>
            </svg>

            Save
          </button>

          <button
            type="button"
            class="share-btn inline-flex items-center gap-2 rounded-[14px] px-3 py-2.5 text-[13px] font-medium text-[color:var(--dashboard-muted)] transition hover:bg-white/[0.04] hover:text-white"
          >
           <svg
  class="h-4 w-4"
  viewBox="0 0 16 16"
  fill="currentColor"
  xmlns="http://www.w3.org/2000/svg"
>
  <path
    d="M11 2.5a2.5 2.5 0 1 1 .603 1.628l-6.718 3.12a2.5 2.5 0 0 1 0 1.504l6.718 3.12a2.5 2.5 0 1 1-.488.876l-6.718-3.12a2.5 2.5 0 1 1 0-3.256l6.718-3.12A2.5 2.5 0 0 1 11 2.5"
  />
</svg>

            Share
          </button>
        </div>
      </div>
    </div>
  </div>

  <Modal
    id={`delete-modal-${post.slug}`}
    role="dialog"
    ariaModal={true}
    ariaLabelledby={`delete-modal-${post.slug}-title`}
    ariaDescribedby={`delete-modal-${post.slug}-desc`}
    class="bg-slate-950/40 backdrop-blur-md"
    panelClass="w-[min(94vw,520px)] rounded-[18px] p-5"
  >

    <div class="delete-modal-content">
  <!-- Warning Icon -->
  <div class="delete-icon-wrap">
    <svg
      class="delete-icon"
      viewBox="0 0 64 64"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <circle
        cx="32"
        cy="32"
        r="22"
        stroke="currentColor"
        stroke-width="3"
      />
      <path
        d="M32 22V34"
        stroke="currentColor"
        stroke-width="3"
        stroke-linecap="round"
      />
      <circle cx="32" cy="42" r="2.5" fill="currentColor" />
    </svg>
  </div>

  <!-- Title -->
  <h3
    id={`delete-modal-${post.slug}-title`}
    class="delete-title"
  >
    Delete this post?
  </h3>

  <!-- Description -->
  <p
    id={`delete-modal-${post.slug}-desc`}
    class="delete-description"
  >
    This action cannot be undone.
  </p>

  <!-- Actions -->
  <div class="delete-actions">
    <button
      type="button"
      data-delete-cancel
      class="delete-btn-cancel"
    >
      Cancel
    </button>

    <button
      type="button"
      data-delete-confirm
      class="delete-btn-danger"
    >
      Delete Post
    </button>
  </div>
</div>

  </Modal>

  <script type="module" src={postCardScriptUrl}></script>
</article>

<style>
  .main-card {
    padding: 15px;
  }
  .post-title {
    padding: 10px;
  }
  .main-card2 {
    padding: 20px;
  }
  .delete-postcard {
    background-color: white;
    padding: 14px;
  }
  .delete-postcard-btn {
    height: 40px;
    padding: 15px;
    margin-bottom: 10px;
  }
  .cancel-postcard-btn {
    height: 40px;
    padding: 15px;
  }


  /* ===== Delete Modal ===== */

.delete-modal-content {
  text-align: center;
  width: 100%;
  max-width: 360px;
  margin-inline: auto;
  background-color: white;
  border-radius: 15px;
  padding: 25px;
}

.delete-icon-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
}

.delete-icon {
  width: 64px;
  height: 64px;
  color: #dc2626;
}

.delete-title {
  margin-top: 18px;
  font-size: 1.5rem;
  line-height: 1.2;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: -0.02em;
}

.dark .delete-title {
  color: #ffffff;
}

.delete-description {
  margin-top: 10px;
  font-size: 1rem;
  line-height: 1.6;
  color: #64748b;
  max-width: 220px;
  margin-inline: auto;
}

.dark .delete-description {
  color: #94a3b8;
}

.delete-actions {
  margin-top: 28px;
  display: flex;
  gap: 14px;
  justify-content: center;
}

.delete-btn-cancel {
  min-width: 130px;
  height: 50px;
  border-radius: 14px;
  border: 1.5px solid #d9dde5;
  background: #ffffff;
  color: #0f172a;
  font-size: 15px;
  font-weight: 600;
  transition: all 0.2s ease;
}

.delete-btn-cancel:hover {
  background: #f8fafc;
  transform: translateY(-1px);
}

.dark .delete-btn-cancel {
  background: #1e293b;
  border-color: #334155;
  color: #ffffff;
}

.delete-btn-danger {
  min-width: 150px;
  height: 50px;
  border: none;
  border-radius: 14px;
  background: #e53935;
  color: #ffffff;
  font-size: 15px;
  font-weight: 700;
  box-shadow:
    0 8px 18px rgba(229, 57, 53, 0.28),
    0 2px 6px rgba(229, 57, 53, 0.18);
  transition: all 0.2s ease;
}

.delete-btn-danger:hover {
  background: #dc2626;
  transform: translateY(-1px);
}

.delete-btn-danger:active {
  transform: translateY(0);
}


.like-btn{
  background-color:transparent;
  color:red;
  padding: 10px;
}
.like-btn:hover {
  transform: translateY(-1px);
}
.like-icon:hover{
  color: black;
}
.saved-btn{
  background-color: transparent;
  padding: 10px;
  color:black;
}
.share-btn{
  color: black;
}
.comment-btn{
  color: black;
}

</style>

