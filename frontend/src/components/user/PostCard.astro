---
import Avatar from "../ui/Avatar.astro";

import type { PostItem } from "../../types/post";

import {
  formatCounter,
  formatRelativeTime,
} from "../../services/interactionService";

const { post } = Astro.props as {
  post: PostItem;
};
---

<article
  class="group overflow-hidden rounded-[28px] border border-white/5 bg-white/[0.03] shadow-[0_18px_50px_rgba(0,0,0,0.22)] transition-[transform,box-shadow,border-color,background-color] duration-300 hover:-translate-y-1 hover:border-white/10 hover:shadow-[0_26px_70px_rgba(0,0,0,0.3)]"
>
  <!-- HEADER -->
  <div class="main-card flex items-center justify-between px-5 pt-5">
    <!-- USER -->
    <div class="flex min-w-0 items-center gap-3">
      <Avatar
        src={post.author.picture || "/icon.png"}
        alt={post.author.name}
        size="md"
      />

      <div class="min-w-0">
        <div class="flex items-center gap-2">
          <a
            href={`/posts/${post.slug}`}
            class="truncate text-[13px] font-semibold text-[color:var(--dashboard-text)] transition hover:text-violet-300"
          >
            {post.author.name}
          </a>

          <span
            class="inline-flex items-center rounded-full border border-violet-500/18 bg-violet-500/10 px-2 py-0.5 text-[10px] font-bold uppercase tracking-[0.16em] text-violet-300"
          >
            New
          </span>
        </div>

        <p
          class="mt-0.5 truncate text-[11px] text-[color:var(--dashboard-muted)]"
        >
          {formatRelativeTime(post.createdAt)}
          ·
          {post.location || "Worldwide"}
        </p>
      </div>
    </div>

    <!-- MENU -->
    <button
      type="button"
      class="grid h-10 w-10 place-items-center rounded-xl text-[color:var(--dashboard-muted)] transition hover:bg-white/[0.05] hover:text-white"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
        <circle cx="12" cy="5" r="1.75"></circle>

        <circle cx="12" cy="12" r="1.75"></circle>

        <circle cx="12" cy="19" r="1.75"></circle>
      </svg>
    </button>
  </div>

  <div class="main-card2">
    <!-- IMAGE — px-4 padding so image never touches card border; inner div clips corners -->
    <a href={`/posts/${post.slug}`} class="relative mt-3 block px-4">
      <div class="overflow-hidden rounded-[18px]">
        <img
          src={post.imageUrl}
          alt={post.title}
          loading="lazy"
          class="aspect-[16/7] w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]"
        />
      </div>

      <!-- OVERLAY -->
      <div
        class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 transition duration-300 group-hover:opacity-100"
      >
      </div>
    </a>

    <!-- CONTENT -->
    <div class="px-5 py-5">
      <!-- TITLE -->
      <div class="post-title">
        <a
          href={`/posts/${post.slug}`}
          class="text-[24px] font-black tracking-[-0.04em] text-[color:var(--dashboard-text)] transition hover:text-violet-300"
        >
          {post.title}
        </a>

        <p
          class="mt-2 line-clamp-2 text-[14px] leading-6 text-[color:var(--dashboard-muted)]"
        >
          {post.caption}
        </p>
      </div>

      <!-- ACTION BAR -->
      <div
        class="mt-5 flex items-center justify-between border-t border-white/5 pt-4"
      >
        <!-- LEFT -->
        <div class="flex items-center gap-2">
          <!-- LIKE -->
          <button
            type="button"
            aria-pressed={post.userState?.liked ? "true" : "false"}
            class:list={[
              "inline-flex items-center gap-2 rounded-[14px] px-3 py-2.5 text-[13px] font-medium transition-[transform,background-color,box-shadow,color]",
              post.userState?.liked
                ? "bg-rose-500/10 text-rose-300"
                : "text-[color:var(--dashboard-muted)] hover:bg-white/[0.04] hover:text-white hover:shadow-[0_8px_20px_rgba(0,0,0,0.08)]",
            ]}
          >
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill={post.userState?.liked ? "currentColor" : "none"}
              stroke="currentColor"
              stroke-width="1.8"
            >
              <path
                d="M12 20s-7-4.4-7-10a4 4 0 0 1 7-2.6A4 4 0 0 1 19 10c0 5.6-7 10-7 10Z"
              ></path>
            </svg>

            {formatCounter(post.counts.likes)}
          </button>

          <!-- COMMENT -->
          <button
            type="button"
            class="inline-flex items-center gap-2 rounded-[14px] px-3 py-2.5 text-[13px] font-medium text-[color:var(--dashboard-muted)] transition hover:bg-white/[0.04] hover:text-white"
          >
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
            >
              <path
                d="M7.9 20.5a.8.8 0 0 1-1.3-.6V17a8 8 0 1 1 5.9 1.8 8 8 0 0 1-4.6 1.7Z"
              ></path>
            </svg>

            {formatCounter(post.counts.comments)}
          </button>
        </div>

        <!-- RIGHT -->
        <div class="flex items-center gap-2">
          <!-- SAVE -->
          <button
            type="button"
            aria-pressed={post.userState?.saved ? "true" : "false"}
            class:list={[
              "inline-flex items-center gap-2 rounded-[14px] px-3 py-2.5 text-[13px] font-medium transition-[transform,background-color,box-shadow,color]",
              post.userState?.saved
                ? "bg-violet-500/10 text-violet-300"
                : "text-[color:var(--dashboard-muted)] hover:bg-white/[0.04] hover:text-white hover:shadow-[0_8px_20px_rgba(0,0,0,0.08)]",
            ]}
          >
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill={post.userState?.saved ? "currentColor" : "none"}
              stroke="currentColor"
              stroke-width="1.8"
            >
              <path d="M7 4h10a1 1 0 0 1 1 1v16l-6-3-6 3V5a1 1 0 0 1 1-1Z"
              ></path>
            </svg>

            Save
          </button>

          <!-- SHARE -->
          <button
            type="button"
            class="inline-flex items-center gap-2 rounded-[14px] px-3 py-2.5 text-[13px] font-medium text-[color:var(--dashboard-muted)] transition hover:bg-white/[0.04] hover:text-white"
          >
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
            >
              <path
                d="M18 8a3 3 0 1 0-2.8-4h-.2a3 3 0 0 0 0 6h.2A3 3 0 1 0 18 8ZM6 14a3 3 0 1 0 2.8 4H9a3 3 0 0 0 0-6h-.2A3 3 0 1 0 6 14Zm6-2.8 3.7-1.9m0 4.6L12 17.2"
              ></path>
            </svg>

            Share
          </button>
        </div>
      </div>
    </div>
  </div>
</article>

<style>
  .main-card {
    padding: 15px;
  }
  .post-title {
    padding: 10px;
  }
  .main-card2 {
    padding: 20px;
  }
</style>
