---
---

<button
  type="button"
  data-theme-toggle
  class="flex min-h-[58px] w-full items-center gap-3 rounded-[10px] border border-[color:var(--dashboard-border)] bg-[color:var(--dashboard-surface)] px-3 py-3 text-left text-sm font-medium text-[color:var(--dashboard-text)] transition-all hover:border-violet-400/25 hover:bg-[color:var(--dashboard-accent-soft)]"
>
  <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-[10px] border border-violet-400/20 bg-violet-500/10 text-[color:var(--dashboard-accent)] shadow-[0_0_18px_rgba(124,58,237,0.12)]">
    <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8">
      <path d="M12 3a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0V4a1 1 0 0 1 1-1Z" />
      <path d="M12 19a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0v-1a1 1 0 0 1 1-1Z" />
      <path d="M4.22 4.22a1 1 0 0 1 1.41 0l.7.7a1 1 0 1 1-1.41 1.41l-.7-.7a1 1 0 0 1 0-1.41Zm12.74 12.74a1 1 0 0 1 1.41 0l.7.7a1 1 0 0 1-1.41 1.41l-.7-.7a1 1 0 0 1 0-1.41Z" />
      <path d="M3 12a1 1 0 0 1 1-1h1a1 1 0 1 1 0 2H4a1 1 0 0 1-1-1Zm15 0a1 1 0 0 1 1-1h1a1 1 0 1 1 0 2h-1a1 1 0 0 1-1-1Z" />
      <path d="M6.34 17.66a1 1 0 0 1 0 1.41l-.7.7a1 1 0 0 1-1.41-1.41l.7-.7a1 1 0 0 1 1.41 0Zm12.74-12.74a1 1 0 0 1 0 1.41l-.7.7a1 1 0 1 1-1.41-1.41l.7-.7a1 1 0 0 1 1.41 0Z" />
      <circle cx="12" cy="12" r="4" />
    </svg>
  </span>
  <span class="min-w-0 flex-1">
    <span class="block text-sm font-semibold text-[color:var(--dashboard-text)]">Theme</span>
    <span class="block text-xs text-[color:var(--dashboard-muted)]">Light / Dark</span>
  </span>
  <span class="pointer-events-none ml-auto inline-flex h-6 w-11 items-center rounded-full border border-[color:var(--dashboard-border)] bg-[color:var(--dashboard-accent-soft)] p-0.5 transition-colors">
    <span class="theme-toggle-knob h-5 w-5 rounded-full bg-[color:var(--dashboard-accent)] shadow-[0_0_12px_rgba(124,58,237,0.34)] transition-transform duration-300"></span>
  </span>
</button>

<style>
  [data-theme-toggle] .theme-toggle-knob {
    transform: translateX(0);
  }

  html.dark [data-theme-toggle] .theme-toggle-knob {
    transform: translateX(1.25rem);
  }
</style>

<script type="module">
  import { toggleTheme } from "../../stores/themeStore";

  const button = document.querySelector("[data-theme-toggle]");

  button?.addEventListener("click", () => {
    toggleTheme();
  });
</script>