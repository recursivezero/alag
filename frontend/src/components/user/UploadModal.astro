---
import Modal from "../ui/Modal.astro";
import uploadModalScriptUrl from "../../scripts/upload-modal.ts?url";
---

<Modal
  id="upload-modal"
  role="dialog"
  ariaModal={true}
  ariaLabelledby="upload-modal-title"
  ariaDescribedby="upload-modal-desc"
  class="bg-slate-950/60 backdrop-blur-md"
  panelClass="upload-dialog w-[min(95vw,680px)] max-h-[calc(100vh-2rem)] overflow-hidden rounded-[24px] bg-[color:var(--upload-modal-bg)] shadow-[0_24px_80px_rgba(15,23,42,0.22)]"
>
  <div
    data-upload-toast-region
    class="upload-toast-region"
    aria-live="assertive"
    aria-atomic="true"
  >
  </div>

  <div class="flex max-h-[calc(100vh-2rem)] flex-col">
    <div
      class="upload-image-head flex items-center justify-between px-8 pt-7 pb-6"
    >
      <h2
        id="upload-modal-title"
        class="text-[22px] font-bold leading-tight tracking-[-0.02em] text-[color:var(--dashboard-text)]"
      >
        Upload Image
      </h2>
      <p id="upload-modal-desc" class="sr-only">Upload modal.</p>
      <button
        type="button"
        data-upload-close
        aria-label="Close upload modal"
        class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full text-[color:var(--dashboard-muted)] transition duration-200 hover:bg-red-500 hover:text-white"
      >
        <svg
          class="h-5 w-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
        >
          <path d="m18 6-12 12"></path>
          <path d="m6 6 12 12"></path>
        </svg>
      </button>
    </div>

    <form
      data-upload-form
      class="upload-form flex flex-col flex-1 min-h-[680px] overflow-y-auto dashboard-scrollbar px-8 pb-8 gap-0"
    >
      <input
        data-upload-input
        type="file"
        class="hidden"
        accept="image/jpeg,image/png,image/webp"
      />

      <button
        type="button"
        data-upload-dropzone
        class="upload-dropzone-btn flex w-full flex-col overflow-hidden rounded-[16px] border-2 border-dashed border-[color:rgba(100,70,230,0.28)] bg-[color:var(--upload-dropzone-bg)] text-center transition hover:border-[color:var(--dashboard-accent)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color:var(--dashboard-accent)]/35"
      >
        <div
          data-upload-preview-placeholder
          class="flex h-[200px] w-full flex-col items-center justify-center gap-4 px-6 py-8"
        >
          <div class="text-[color:var(--dashboard-accent)]">
            <svg
              class="h-12 w-12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242"
              ></path>
              <path d="M12 12v9"></path>
              <path d="m16 16-4-4-4 4"></path>
            </svg>
          </div>
          <div>
            <p
              class="text-[15px] font-semibold text-[color:var(--dashboard-text)]"
            >
              Drag &amp; drop an image here
            </p>
            <p class="mt-1 text-[13px] text-[color:var(--dashboard-muted)]">
              or click to choose a file
            </p>
          </div>
        </div>
        <img
          data-upload-preview-image
          alt="Selected image preview"
          class="hidden h-[200px] w-full object-cover"
        />
      </button>

      <div class="replace-remove-btn mt-5 grid grid-cols-2 gap-3">
        <button
          type="button"
          data-upload-replace
          class="inline-flex h-11 w-full items-center justify-center gap-2 rounded-[10px] border border-[color:var(--dashboard-border)] bg-[color:var(--upload-field-bg)] px-4 text-[13px] font-medium text-[color:var(--dashboard-accent)] transition hover:bg-[color:var(--dashboard-accent-soft)]"
        >
          <svg
            class="h-[15px] w-[15px] shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <rect width="18" height="18" x="3" y="3" rx="2" ry="2"></rect>
            <circle cx="9" cy="9" r="2"></circle>
            <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path>
          </svg>
          Replace Image
        </button>
        <button
          type="button"
          data-upload-remove
          class="inline-flex h-11 w-full items-center justify-center gap-2 rounded-[10px] border border-[color:var(--dashboard-border)] bg-[color:var(--upload-field-bg)] px-4 text-[13px] font-medium text-red-500 transition hover:bg-red-50 dark:hover:bg-red-500/10"
        >
          <svg
            class="h-[15px] w-[15px] shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M3 6h18"></path>
            <path d="M8 6V4h8v2"></path>
            <path d="M6 6l1 14h10l1-14"></path>
            <path d="M10 11v5"></path>
            <path d="M14 11v5"></path>
          </svg>
          Remove Image
        </button>
      </div>

      <div class="mt-6 grid gap-2">
        <span
          class="text-[14px] font-semibold text-[color:var(--dashboard-text)]"
          >Caption</span
        >
        <textarea
          data-upload-caption
          maxlength="500"
          placeholder="Write a caption for this post"
          rows="4"
          class="caption-textarea w-full rounded-[12px] border border-[color:var(--dashboard-border)] bg-[color:var(--upload-field-bg)] px-4 py-3.5 text-[14px] outline-none transition resize-none placeholder:text-[color:var(--dashboard-muted)] focus:border-[color:var(--dashboard-accent)] focus:ring-2 focus:ring-[color:var(--dashboard-accent)]/20"
        ></textarea>
        <div class="flex justify-end">
          <span
            data-upload-caption-count
            class="text-[12px] text-[color:var(--dashboard-muted)]"
            >0 / 500</span
          >
        </div>
      </div>

      <div class="mt-5 grid gap-3">
        <span
          class="text-[14px] font-semibold text-[color:var(--dashboard-text)]"
          >Feed Type</span
        >
        <div class="grid grid-cols-2 gap-3">
          <label class="feed-type-card cursor-pointer">
            <input
              data-upload-feed-type
              type="radio"
              name="feedType"
              value="public"
              checked
              class="peer sr-only"
            />
            <div
              class="flex h-[68px] items-center gap-3 rounded-[12px] border-2 border-[color:var(--dashboard-border)] bg-[color:var(--upload-field-bg)] px-4 transition peer-checked:border-[color:var(--dashboard-accent)] peer-checked:bg-[color:var(--dashboard-accent-soft)]"
            >
              <span
                class="upload-radio-indicator grid h-[18px] w-[18px] shrink-0 place-items-center rounded-full border-2 border-[color:rgba(15,23,42,0.2)] bg-white transition dark:border-[color:var(--dashboard-border)] dark:bg-[color:var(--dashboard-surface)]"
              >
                <span
                  class="upload-radio-dot h-[9px] w-[9px] rounded-full bg-[color:var(--dashboard-accent)] opacity-0 transition"
                ></span>
              </span>
              <svg
                class="feed-icon-globe h-5 w-5 shrink-0"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M2 12h20"></path>
                <path
                  d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
                ></path>
              </svg>
              <div>
                <span
                  class="block text-[13px] font-semibold text-[color:var(--dashboard-text)]"
                  >Public Feed</span
                >
                <span
                  class="block text-[11px] text-[color:var(--dashboard-muted)]"
                  >Visible to everyone</span
                >
              </div>
            </div>
          </label>

          <label class="feed-type-card cursor-pointer">
            <input
              data-upload-feed-type
              type="radio"
              name="feedType"
              value="personal"
              class="peer sr-only"
            />
            <div
              class="flex h-[68px] items-center gap-3 rounded-[12px] border-2 border-[color:var(--dashboard-border)] bg-[color:var(--upload-field-bg)] px-4 transition peer-checked:border-[color:var(--dashboard-accent)] peer-checked:bg-[color:var(--dashboard-accent-soft)]"
            >
              <span
                class="upload-radio-indicator grid h-[18px] w-[18px] shrink-0 place-items-center rounded-full border-2 border-[color:rgba(15,23,42,0.2)] bg-white transition dark:border-[color:var(--dashboard-border)] dark:bg-[color:var(--dashboard-surface)]"
              >
                <span
                  class="upload-radio-dot h-[9px] w-[9px] rounded-full bg-[color:var(--dashboard-accent)] opacity-0 transition"
                ></span>
              </span>
              <svg
                class="feed-icon-lock h-5 w-5 shrink-0"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <rect width="18" height="11" x="3" y="11" rx="2" ry="2"></rect>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
              </svg>
              <div>
                <span
                  class="block text-[13px] font-semibold text-[color:var(--dashboard-text)]"
                  >Personal Feed</span
                >
                <span
                  class="block text-[11px] text-[color:var(--dashboard-muted)]"
                  >Visible only on your profile</span
                >
              </div>
            </div>
          </label>
        </div>
      </div>

      <div class="mt-5 grid gap-2">
        <span
          class="text-[14px] font-semibold text-[color:var(--dashboard-text)]"
          >Category</span
        >
        <div
          class="category-wrapper relative flex items-center rounded-[12px] border border-[color:var(--dashboard-border)] bg-[color:var(--upload-field-bg)] transition focus-within:border-[color:var(--dashboard-accent)]"
        >
          <!-- <span
            class="pointer-events-none flex shrink-0 items-center pl-4 pr-2 text-[color:var(--dashboard-muted)]"
          >
            <svg
              class="h-[15px] w-[15px]"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M4 9h16"></path>
              <path d="M4 15h16"></path>
              <path d="M10 3 8 21"></path>
              <path d="M16 3l-2 18"></path>
            </svg>
          </span> -->
          <select
            data-upload-category
            class="category-select min-w-0 flex-1 appearance-none bg-transparent px-4 py-3.5 pr-10 text-[14px] outline-none"
          >
            <option value="nature">Nature</option>
            <option value="travel">Travel</option>
            <option value="city">City</option>
            <option value="food">Food</option>
            <option value="lifestyle">Lifestyle</option>
          </select>
          <span
            class="pointer-events-none flex shrink-0 items-center pr-4 pl-2 text-[color:var(--dashboard-muted)]"
          >
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="m6 9 6 6 6-6"></path>
            </svg>
          </span>
        </div>
      </div>

      <div class="cancel-btn mt-7 flex items-center justify-end gap-3">
        <button
          type="button"
          data-upload-cancel
          class="inline-flex h-[48px] w-[140px] items-center justify-center rounded-[12px] border border-[color:var(--dashboard-border)] bg-[color:var(--upload-field-bg)] px-6 text-[14px] font-semibold text-[color:var(--dashboard-text)] transition hover:bg-[color:var(--dashboard-accent-soft)]"
        >
          Cancel
        </button>
        <button
          type="submit"
          data-upload-submit
          disabled
          class="publish-btn inline-flex h-[48px] w-[180px] items-center justify-center gap-2 rounded-[12px] px-6 text-[14px] font-bold text-white transition disabled:cursor-not-allowed disabled:opacity-50"
        >
          <svg
            class="h-4 w-4 shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.2"
          >
            <path d="M22 2 11 13"></path>
            <path d="m22 2-7 20-4-9-9-4Z"></path>
          </svg>
          Publish Post
        </button>
      </div>
    </form>

    <div data-upload-state="uploading" class="hidden flex-1 min-h-0 px-8 py-10">
      <div
        class="mx-auto flex max-w-sm flex-col items-center rounded-[20px] border border-[color:var(--dashboard-border)] bg-[color:var(--dashboard-surface)] px-6 py-8 text-center shadow-[0_18px_60px_rgba(15,23,42,0.12)]"
      >
        <div
          class="grid h-14 w-14 place-items-center rounded-full border border-[color:var(--dashboard-border)] bg-[color:var(--dashboard-accent-soft)] text-[color:var(--dashboard-accent)]"
        >
          <svg
            class="h-7 w-7 animate-spin"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M21 12a9 9 0 1 1-3.2-6.9"></path>
          </svg>
        </div>
        <h3
          class="mt-4 text-xl font-semibold text-[color:var(--dashboard-text)]"
        >
          Uploading your image
        </h3>
        <p class="mt-2 text-sm leading-6 text-[color:var(--dashboard-muted)]">
          Please wait while we upload your image.
        </p>
        <div
          class="mt-5 w-full rounded-full bg-[color:var(--dashboard-accent-soft)] p-1"
        >
          <div
            data-upload-progress
            class="h-2 w-0 rounded-full bg-[color:var(--dashboard-accent)] transition-[width] duration-200"
          >
          </div>
        </div>
        <p
          data-upload-progress-label
          class="mt-2.5 text-sm font-medium text-[color:var(--dashboard-text)]"
        >
          0%
        </p>
        <button
          type="button"
          data-upload-abort
          class="mt-5 inline-flex items-center justify-center rounded-full border border-[color:var(--dashboard-border)] px-5 py-2.5 text-sm font-medium text-[color:var(--dashboard-text)] transition hover:bg-[color:var(--dashboard-accent-soft)]"
        >
          Cancel
        </button>
      </div>
    </div>

    <div
      data-upload-state="success"
      class="image-upload hidden flex-1 items-center justify-center"
    >
      <div
        class="w-full max-w-[420px] flex flex-col items-center rounded-[20px] border border-[color:var(--dashboard-border)] bg-[color:var(--dashboard-surface)] px-10 py-10 text-center shadow-[0_18px_60px_rgba(15,23,42,0.12)]"
      >
        <div
          class="grid h-14 w-14 place-items-center rounded-full bg-emerald-500/10 text-emerald-500"
        >
          <svg
            class="h-9 w-9"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.2"
          >
            <path d="M20 6 9 17l-5-5"></path>
          </svg>
        </div>
        <h3
          class="mt-4 text-[24px] font-bold text-[color:var(--dashboard-text)]"
        >
          Image Uploaded Successfully!
        </h3>
        <p
          class="mt-2 text-[14px] leading-6 text-[color:var(--dashboard-muted)]"
        >
          Your image has been published.
        </p>
        <div class="mt-5 flex flex-wrap justify-center gap-3">
          <!-- <a data-upload-success-link href="#" class="view-btn inline-flex items-center justify-center rounded-[12px] px-5 py-2.5 text-sm font-semibold text-white transition">
            View Post
          </a> -->
          <button
            type="button"
            data-upload-success-close
            class="inline-flex h-[46px] min-w-[140px] items-center justify-center rounded-[12px] bg-[color:var(--dashboard-accent)] px-6 text-sm font-semibold text-white transition hover:opacity-90"
          >
            Done
          </button>
        </div>
      </div>
    </div>
  </div>
</Modal>

<script type="module" src={uploadModalScriptUrl}></script>

<style>
  :root {
    --upload-modal-bg: #ffffff;
    --upload-dropzone-bg: #f4f3fc;
    --upload-field-bg: #ffffff;
    --upload-text: #0f172a;
  }

  html.dark {
    --upload-modal-bg: var(--dashboard-surface-strong);
    --upload-dropzone-bg: var(--dashboard-background-soft);
    --upload-field-bg: var(--dashboard-surface-strong);
    --upload-text: #f1f5f9;
  }

  .upload-dialog {
    animation: upload-pop 200ms cubic-bezier(0.16, 1, 0.3, 1);
    padding: 20px;
  }
  .upload-form {
    padding: 10px;
  }
  .upload-image-head {
    padding: 5px;
  }
  .replace-remove-btn {
    padding: 8px;
  }

  .caption-textarea {
    color: var(--upload-text) !important;
    background-color: var(--upload-field-bg);
    min-height: 90px;
  }
  .caption-textarea::placeholder {
    color: var(--dashboard-muted);
    opacity: 1;
  }

  /* ── Category select ── */
  /* .category-select {
    color: var(--upload-text) !important;
    background: transparent;
    padding:10px;
    padding-left: 5px;
    
  } */
  .category-select {
    color: var(--upload-text) !important;
    background: transparent;
    padding: 10px;
    border: 0;
    appearance: none;
    -webkit-appearance: none;
  }
  .category-select option {
  background: #ffffff;
  color: #0f172a;
}

html.dark .category-select option {
  background: #1e293b;
  color: #f8fafc;
}

  .category-select,
  .category-select:focus,
  .category-select:focus-visible {
    outline: none !important;
    box-shadow: none !important;
    border: none !important;
  }

  .feed-icon-globe {
    color: var(--dashboard-text);
    opacity: 0.55;
  }
  label:has(input[type="radio"]:checked) .feed-icon-globe {
    color: var(--dashboard-accent);
    opacity: 1;
  }

  .feed-icon-lock {
    color: var(--dashboard-text);
    opacity: 0.55;
  }
  label:has(input[type="radio"]:checked) .feed-icon-lock {
    opacity: 0.6;
  }

  label:has(input[type="radio"]:checked) .upload-radio-indicator {
    border-color: var(--dashboard-accent);
    background: color-mix(in srgb, var(--dashboard-accent-soft) 50%, white);
  }
  html.dark label:has(input[type="radio"]:checked) .upload-radio-indicator {
    background: color-mix(
      in srgb,
      var(--dashboard-accent-soft) 30%,
      var(--dashboard-surface)
    );
  }
  label:has(input[type="radio"]:checked) .upload-radio-dot {
    opacity: 1;
  }
  .cancel-btn {
    padding: 18px;
  }

  .publish-btn {
    background: linear-gradient(90deg, #4530c8 0%, #6d50f5 100%);
    box-shadow: 0 4px 16px -3px rgba(90, 60, 220, 0.45);
  }
  .publish-btn:not(:disabled):hover {
    background: linear-gradient(90deg, #3c28b8 0%, #6244e8 100%);
  }
  .publish-btn:disabled {
    background: linear-gradient(90deg, #4530c8 0%, #6d50f5 100%);
  }

  /* ── View post button ── */
  /* .view-btn {
    background: linear-gradient(90deg, #4c35d4 0%, #8474fe 100%);
    box-shadow: 0 0.7em 1.5em -0.5em hsla(249, 62%, 51%, 0.7);
  } */

  .is-dragging {
    border-color: var(--dashboard-accent) !important;
    background: var(--dashboard-accent-soft) !important;
  }

  .upload-toast-region {
    position: absolute;
    inset: 0 auto auto 0;
    pointer-events: none;
    z-index: 20;
  }
  .image-upload {
    padding:14px;
  }

  @keyframes upload-pop {
    from {
      opacity: 0;
      transform: translateY(10px) scale(0.985);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (max-width: 480px) {
    .upload-dialog {
      width: min(100vw - 1rem, 500px);
      border-radius: 18px;
    }
    .grid-cols-2 {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .upload-dialog {
      animation: none;
    }
  }
</style>
