---
import Modal from "../ui/Modal.astro";
import uploadModalScriptUrl from "../../scripts/upload-modal.ts?url";
---

<Modal
  id="upload-modal"
  role="dialog"
  ariaModal={true}
  ariaLabelledby="upload-modal-title"
  ariaDescribedby="upload-modal-desc"
  class="bg-slate-950/60 backdrop-blur-md"
  panelClass="upload-dialog w-[min(95vw,680px)] max-h-[calc(100vh-2rem)] overflow-hidden rounded-[20px] bg-[color:var(--upload-modal-bg)] shadow-[0_24px_80px_rgba(15,23,42,0.22)]"
>
  <div
    data-upload-toast-region
    class="upload-toast-region"
    aria-live="assertive"
    aria-atomic="true"
  >
  </div>

  <div
    data-upload-confirm-overlay
    class="upload-confirm-overlay hidden"
    role="alertdialog"
    aria-modal="true"
    aria-labelledby="confirm-title"
  >
    <div class="upload-confirm-box">
      <!-- <div class="upload-confirm-icon">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
          <path d="M12 17h.01"></path>
        </svg>
      </div> -->
      <div class="upload-confirm-icon">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 16 16"
          fill="currentColor"
        >
          <path
            fill-rule="evenodd"
            d="M4.475 5.458c-.284 0-.514-.237-.47-.517C4.28 3.24 5.576 2 7.825 2c2.25 0 3.767 1.36 3.767 3.215 0 1.344-.665 2.288-1.79 2.973-1.1.659-1.414 1.118-1.414 2.01v.03a.5.5 0 0 1-.5.5h-.77a.5.5 0 0 1-.5-.495l-.003-.2c-.043-1.221.477-2.001 1.645-2.712 1.03-.632 1.397-1.135 1.397-2.028 0-.979-.758-1.698-1.926-1.698-1.009 0-1.71.529-1.938 1.402-.066.254-.278.461-.54.461h-.777ZM7.496 14c.622 0 1.095-.474 1.095-1.09 0-.618-.473-1.092-1.095-1.092-.606 0-1.087.474-1.087 1.091S6.89 14 7.496 14"
          ></path>
        </svg>
      </div>
      <h3 id="confirm-title" data-confirm-title class="upload-confirm-title">
      </h3>
      <p data-confirm-message class="upload-confirm-message"></p>
      <div data-confirm-actions class="upload-confirm-actions"></div>
    </div>
  </div>

  <div class="flex max-h-[calc(100vh-2rem)] flex-col">
    <div
      class="upload-image-head relative flex items-center justify-center px-6 pt-6 pb-5"
    >
      <h2
        id="upload-modal-title"
        class="text-[20px] font-bold leading-tight tracking-[-0.02em] text-[color:var(--dashboard-text)]"
      >
        Upload Image
      </h2>
      <p id="upload-modal-desc" class="sr-only">Upload image modal.</p>
      <button
        type="button"
        data-upload-close
        aria-label="Close upload modal"
        class="absolute right-5 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-[color:var(--dashboard-muted)] transition duration-200 hover:bg-[color:var(--dashboard-border)] hover:text-[color:var(--dashboard-text)]"
      >
        <svg
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
        >
          <path d="m18 6-12 12"></path>
          <path d="m6 6 12 12"></path>
        </svg>
      </button>
    </div>

    <div class="h-px bg-[color:var(--dashboard-border)] mx-0"></div>

    <form
      data-upload-form
      class="upload-form flex flex-col overflow-y-auto dashboard-scrollbar px-8 pb-8 pt-6 gap-6"
    >
      <input
        data-upload-input
        type="file"
        class="hidden"
        accept="image/jpeg,image/png,image/webp"
      />

      <button
        type="button"
        data-upload-dropzone
        class="upload-dropzone-btn flex w-full flex-col overflow-hidden rounded-[14px] border-2 border-dashed border-[color:rgba(100,70,230,0.28)] bg-[color:var(--upload-dropzone-bg)] text-center transition hover:border-[color:var(--dashboard-accent)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color:var(--dashboard-accent)]/35"
      >
        <div
          data-upload-preview-placeholder
          class="flex h-[220px] w-full flex-col items-center justify-center gap-3 px-6 py-6"
        >
          <div class="text-[color:var(--dashboard-accent)]">
            <svg
              class="h-10 w-10"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242"
              ></path>
              <path d="M12 12v9"></path>
              <path d="m16 16-4-4-4 4"></path>
            </svg>
          </div>
          <div>
            <p
              class="text-[14px] font-semibold text-[color:var(--dashboard-text)]"
            >
              Drag &amp; drop an image here
            </p>
            <p class="mt-0.5 text-[12px] text-[color:var(--dashboard-muted)]">
              or click to choose a file
            </p>
          </div>
        </div>
        <img
          data-upload-preview-image
          alt="Selected image preview"
          class="hidden h-[220px] w-full object-cover rounded-[14px]"
        />
      </button>

      <div class="grid grid-cols-2 gap-3">
        <button
          type="button"
          data-upload-replace
          disabled
          class="replace-remove-action inline-flex h-10 w-full items-center justify-center gap-2 rounded-[10px] border border-[color:var(--dashboard-border)] bg-[color:var(--upload-field-bg)] px-4 text-[13px] font-medium text-[color:var(--dashboard-accent)] transition disabled:cursor-not-allowed disabled:opacity-40"
        >
          <svg
            class="h-[14px] w-[14px] shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <rect width="18" height="18" x="3" y="3" rx="2" ry="2"></rect>
            <circle cx="9" cy="9" r="2"></circle>
            <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path>
          </svg>
          Replace Image
        </button>
        <button
          type="button"
          data-upload-remove
          disabled
          class="replace-remove-action inline-flex h-10 w-full items-center justify-center gap-2 rounded-[10px] border border-[color:var(--dashboard-border)] bg-[color:var(--upload-field-bg)] px-4 text-[13px] font-medium text-red-500 transition disabled:cursor-not-allowed disabled:opacity-45 hover:bg-red-50 dark:hover:bg-red-500/10"
        >
          <svg
            class="h-[14px] w-[14px] shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M3 6h18"></path>
            <path d="M8 6V4h8v2"></path>
            <path d="M6 6l1 14h10l1-14"></path>
            <path d="M10 11v5"></path>
            <path d="M14 11v5"></path>
          </svg>
          Remove Image
        </button>
      </div>

      <div class="grid gap-2">
        <label
          for="upload-caption-field"
          class="text-[13px] font-semibold text-[color:var(--dashboard-text)]"
          >Caption</label
        >
        <div class="caption-field-wrap">
          <textarea
            id="upload-caption-field"
            data-upload-caption
            maxlength="500"
            placeholder="Write a caption for this post..."
            rows="3"
            class="caption-textarea"></textarea>
        </div>

        <div class="caption-counter-row">
          <span data-upload-caption-count class="caption-counter">
            0 / 500
          </span>
        </div>
      </div>

      <div class="grid gap-2">
        <!-- <span
          class="text-[13px] font-semibold text-[color:var(--dashboard-text)]"
          >Feed Type</span
        > -->
        <div class="grid grid-cols-2 gap-3">
          <label class="feed-type-card cursor-pointer">
            <input
              data-upload-feed-type
              type="radio"
              name="feedType"
              value="public"
              checked
              class="peer sr-only"
            />
            <div
              class="feed-type-inner flex h-[55px] px-3 items-center gap-3 rounded-[12px] border-2 border-[color:var(--dashboard-border)] bg-[color:var(--upload-field-bg)] px-4 transition peer-checked:border-[color:var(--dashboard-accent)] peer-checked:bg-[color:var(--dashboard-accent-soft)]"
            >
              <span
                class="upload-radio-indicator grid h-[17px] w-[17px] shrink-0 place-items-center rounded-full border-2 border-[color:rgba(15,23,42,0.2)] bg-white transition dark:border-[color:var(--dashboard-border)] dark:bg-[color:var(--dashboard-surface)]"
              >
                <span
                  class="upload-radio-dot h-[8px] w-[8px] rounded-full bg-[color:var(--dashboard-accent)] opacity-0 transition"
                ></span>
              </span>
              <div>
                <span
                  class="block text-[13px] font-semibold text-[color:var(--dashboard-text)]"
                  >Public Feed</span
                >
                <span
                  class="block text-[11px] text-[color:var(--dashboard-muted)]"
                  >Visible to everyone</span
                >
              </div>
            </div>
          </label>

          <label class="feed-type-card cursor-pointer">
            <input
              data-upload-feed-type
              type="radio"
              name="feedType"
              value="personal"
              class="peer sr-only"
            />
            <div
              class="feed-type-inner flex h-[55px] px-3 items-center gap-3 rounded-[12px] border-2 border-[color:var(--dashboard-border)] bg-[color:var(--upload-field-bg)] px-4 transition peer-checked:border-[color:var(--dashboard-accent)] peer-checked:bg-[color:var(--dashboard-accent-soft)]"
            >
              <span
                class="upload-radio-indicator grid h-[17px] w-[17px] shrink-0 place-items-center rounded-full border-2 border-[color:rgba(15,23,42,0.2)] bg-white transition dark:border-[color:var(--dashboard-border)] dark:bg-[color:var(--dashboard-surface)]"
              >
                <span
                  class="upload-radio-dot h-[8px] w-[8px] rounded-full bg-[color:var(--dashboard-accent)] opacity-0 transition"
                ></span>
              </span>
              <div>
                <span
                  class="block text-[13px] font-semibold text-[color:var(--dashboard-text)]"
                  >Personal Feed</span
                >
                <span
                  class="block text-[11px] text-[color:var(--dashboard-muted)]"
                  >Visible only on your profile</span
                >
              </div>
            </div>
          </label>
        </div>
      </div>

      <div class="flex items-center justify-end gap-3 pt-1">
        <button
          type="button"
          data-upload-cancel
          class="inline-flex h-[44px] min-w-[110px] items-center justify-center rounded-[10px] border border-[color:var(--dashboard-border)] bg-[color:var(--upload-field-bg)] px-5 text-[13px] font-semibold text-[color:var(--dashboard-text)] transition hover:bg-[color:var(--dashboard-accent-soft)]"
        >
          Cancel
        </button>
        <button
          type="submit"
          data-upload-submit
          disabled
          class="publish-btn inline-flex h-[44px] min-w-[150px] items-center justify-center gap-2 rounded-[10px] px-5 text-[13px] font-bold text-white transition disabled:cursor-not-allowed disabled:opacity-50"
        >
          <svg
            class="h-[14px] w-[14px] shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.2"
          >
            <path d="M22 2 11 13"></path>
            <path d="m22 2-7 20-4-9-9-4Z"></path>
          </svg>
          Publish
        </button>
      </div>
    </form>

    <div data-upload-state="uploading" class="hidden flex-1 min-h-0 px-6 py-10">
      <div
        class="mx-auto flex max-w-sm flex-col items-center rounded-[16px] border border-[color:var(--dashboard-border)] bg-[color:var(--dashboard-surface)] px-6 py-8 text-center shadow-[0_18px_60px_rgba(15,23,42,0.12)]"
      >
        <div
          class="grid h-12 w-12 place-items-center rounded-full border border-[color:var(--dashboard-border)] bg-[color:var(--dashboard-accent-soft)] text-[color:var(--dashboard-accent)]"
        >
          <svg
            class="h-6 w-6 animate-spin"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M21 12a9 9 0 1 1-3.2-6.9"></path>
          </svg>
        </div>
        <h3
          class="mt-4 text-[18px] font-semibold text-[color:var(--dashboard-text)]"
        >
          Uploading your image
        </h3>
        <p
          class="mt-1.5 text-[13px] leading-6 text-[color:var(--dashboard-muted)]"
        >
          Please wait while we upload your image.
        </p>
        <div
          class="mt-5 w-full rounded-full bg-[color:var(--dashboard-accent-soft)] p-1"
        >
          <div
            data-upload-progress
            class="h-2 w-0 rounded-full bg-[color:var(--dashboard-accent)] transition-[width] duration-200"
          >
          </div>
        </div>
        <p
          data-upload-progress-label
          class="mt-2 text-[13px] font-medium text-[color:var(--dashboard-text)]"
        >
          0%
        </p>
        <button
          type="button"
          data-upload-abort
          class="mt-4 inline-flex items-center justify-center rounded-full border border-[color:var(--dashboard-border)] px-5 py-2 text-[13px] font-medium text-[color:var(--dashboard-text)] transition hover:bg-[color:var(--dashboard-accent-soft)]"
        >
          Cancel
        </button>
      </div>
    </div>
  </div>
</Modal>

<script type="module" src={uploadModalScriptUrl}></script>

<style>
  :root {
    --upload-modal-bg: #ffffff;
    --upload-dropzone-bg: #f4f3fc;
    --upload-field-bg: #ffffff;
    --upload-text: #0f172a;
  }

  html.dark {
    --upload-modal-bg: var(--dashboard-surface-strong);
    --upload-dropzone-bg: var(--dashboard-background-soft);
    --upload-field-bg: var(--dashboard-surface-strong);
    --upload-text: #f1f5f9;
  }

  .upload-dialog {
    animation: upload-pop 200ms cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
  }
  /* .upload-dropzone-btn {
  padding: 12px;
} */
  .upload-dialog {
    padding: 0;
  }
  .upload-form {
    padding: 16px;
  }
  .upload-image-head {
    padding: 14px;
  }

  .caption-field-wrap {
    border: 1.5px solid var(--dashboard-border);
    border-radius: 12px;
    background: var(--upload-field-bg);
    transition:
      border-color 0.15s,
      box-shadow 0.15s;
    overflow: hidden;
  }
  .caption-field-wrap:focus-within {
    border-color: var(--dashboard-accent);
    box-shadow: 0 0 0 3px
      color-mix(in srgb, var(--dashboard-accent) 12%, transparent);
  }

  .caption-textarea {
    display: block;
    width: 100%;
    background: transparent;
    border: none;
    outline: none;
    resize: none;
    padding: 14px 16px 8px;
    font-size: 14px;
    line-height: 1.55;
    min-height: 84px;
    color: var(--upload-text);
    font-family: inherit;
  }
  .caption-textarea::placeholder {
    color: var(--dashboard-muted);
    opacity: 1;
  }
  /* .caption-counter-row {
    display: flex;
    justify-content: flex-end;
    padding: 0 16px 10px;
  } */
  .caption-counter-row {
    display: flex;
    justify-content: flex-end;
    margin-top: 6px;
    padding-right: 4px;
  }

  .caption-counter {
    font-size: 11px;
    color: var(--dashboard-muted);
  }
  .caption-counter {
    font-size: 11px;
    color: var(--dashboard-muted);
  }
  .feed-type-inner {
    align-items: center;
    gap: 10px;
  }
  .feed-type-inner span:last-child {
    line-height: 1.3;
  }

  label:has(input[type="radio"]:checked) .upload-radio-indicator {
    border-color: var(--dashboard-accent);
    background: color-mix(in srgb, var(--dashboard-accent-soft) 50%, white);
  }
  html.dark label:has(input[type="radio"]:checked) .upload-radio-indicator {
    background: color-mix(
      in srgb,
      var(--dashboard-accent-soft) 30%,
      var(--dashboard-surface)
    );
  }
  label:has(input[type="radio"]:checked) .upload-radio-dot {
    opacity: 1;
  }

  .publish-btn {
    background: linear-gradient(90deg, #4530c8 0%, #6d50f5 100%);
    box-shadow: 0 4px 16px -3px rgba(90, 60, 220, 0.45);
  }
  .publish-btn:not(:disabled):hover {
    background: linear-gradient(90deg, #3c28b8 0%, #6244e8 100%);
  }
  .publish-btn:disabled {
    background: linear-gradient(90deg, #4530c8 0%, #6d50f5 100%);
  }

  .is-dragging {
    border-color: var(--dashboard-accent) !important;
    background: var(--dashboard-accent-soft) !important;
  }

  .upload-toast-region {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    pointer-events: none;
    z-index: 30;
  }

  .upload-confirm-overlay {
    position: absolute;
    inset: 0;
    z-index: 20;
    border-radius: 20px;
    background: rgba(0, 0, 0, 0.48);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    animation: upload-pop 150ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .upload-confirm-overlay.hidden {
    display: none;
  }

  /* .upload-confirm-box {
    background: var(--upload-modal-bg);
    border: 1px solid var(--dashboard-border);
    border-radius: 18px;
    padding: 32px 28px 28px;
    text-align: center;
    width: 100%;
    max-width: 360px;
    box-shadow: 0 24px 64px rgba(15, 23, 42, 0.22);
  } */

  .upload-confirm-box {
    background: var(--upload-modal-bg);

    border: 1px solid var(--dashboard-border);

    border-radius: 20px;

    padding: 28px;

    text-align: center;

    width: 100%;
    max-width: 380px;

    box-shadow: 0 24px 64px rgba(15, 23, 42, 0.18);
  }

  .upload-confirm-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: color-mix(in srgb, #f59e0b 14%, transparent);
    color: #f59e0b;
    margin-bottom: 16px;
  }
  .upload-confirm-icon svg {
    width: 30px;
    height: 30px;
  }

  .upload-confirm-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--dashboard-text);
    margin-bottom: 8px;
    letter-spacing: -0.015em;
    line-height: 1.25;
  }

  .upload-confirm-message {
    font-size: 13px;
    color: var(--dashboard-muted);
    line-height: 1.6;
    margin-bottom: 24px;
  }

  /* .upload-confirm-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
  } */

  .upload-confirm-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  @keyframes upload-pop {
    from {
      opacity: 0;
      transform: translateY(8px) scale(0.985);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (max-width: 480px) {
    .upload-dialog {
      border-radius: 16px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .upload-dialog,
    .upload-confirm-overlay {
      animation: none;
    }
  }
</style>

<style is:global>
  .confirm-row {
    display: grid;
    gap: 12px;
    grid-template-columns: 1fr;
  }
  .confirm-row-2 {
    grid-template-columns: 1fr 1fr;
  }

  .confirm-btn {
    width: 100%;
    height: 44px;

    display: inline-flex;
    align-items: center;
    justify-content: center;

    border-radius: 10px;

    font-size: 14px;
    font-weight: 600;

    cursor: pointer;

    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease,
      transform 0.15s ease;

    white-space: nowrap;
    appearance: none;
    -webkit-appearance: none;
  }
  .confirm-btn:hover {
    background: var(--dashboard-accent-soft);
  }

  .confirm-btn--primary {
    background: linear-gradient(90deg, #5b3df5 0%, #7448ff 100%);

    color: #fff;
    border: none;

    box-shadow: 0 6px 18px rgba(91, 61, 245, 0.28);
  }

  .confirm-btn--primary:hover {
    transform: translateY(-1px);

    background: linear-gradient(90deg, #5134ea 0%, #6c42fb 100%);
  }

  .confirm-btn--danger {
    background: #ef4444;
    color: #fff;
    border-color: transparent;
    box-shadow: 0 4px 14px -3px rgba(239, 68, 68, 0.35);
  }
  .confirm-btn--danger:hover {
    background: #dc2626;
  }

  .confirm-btn--ghost {
    background: #fff;

    color: #ef4444;

    border: 1px solid #e5e7eb;
  }

  .confirm-btn--ghost:hover {
    background: #fff5f5;

    border-color: #fca5a5;
  }

  .confirm-btn--default {
    background: #fff;

    color: #111827;

    border: 1px solid #e5e7eb;
  }

  .confirm-btn--default:hover {
    background: #f9fafb;
  }

  @media (max-width: 480px) {
    .confirm-row-2 {
      grid-template-columns: 1fr;
    }
  }
</style>
