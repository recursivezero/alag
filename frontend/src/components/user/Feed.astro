---
import PostCard from "./PostCard.astro";

import type { PostItem } from "../../types/post";

const { posts } = Astro.props as {
  posts: PostItem[];
};
---

<section
  class="relative"
  data-feed-container
>
  {
    posts.length ? (
      <!-- POSTS -->
      <div
        class="flex flex-col gap-5"
      >
        {
          posts.map((post, index) => (
            <div
              class="animate-feed-in"
              style={`animation-delay:${index * 40}ms`}
            >
              <PostCard post={post} />
            </div>
          ))
        }
      </div>
    ) : (
      <!-- EMPTY STATE -->
      <div
        class="overflow-hidden rounded-[28px] border border-white/5 bg-white/[0.03] p-9 shadow-[0_18px_50px_rgba(0,0,0,0.22)]"
      >
        <div
          class="empty-state-content"
        >
          <!-- ICON -->
          <div
            class="mb-5 grid h-20 w-20 place-items-center rounded-[24px] border border-violet-500/20 bg-violet-500/10 text-violet-300 shadow-[0_10px_40px_rgba(124,58,237,0.22)]"
          >
            <svg
              class="h-9 w-9"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
            >
              <path
                d="M4 19V5a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v14"
              ></path>

              <path
                d="m4 15 4-4a2 2 0 0 1 2.8 0l1.2 1.2a2 2 0 0 0 2.8 0L20 7"
              ></path>

              <circle
                cx="8.5"
                cy="8.5"
                r="1.5"
              ></circle>
            </svg>
          </div>

          <!-- TITLE -->
          <h2
            class="text-[30px] font-black tracking-[-0.04em] text-[color:var(--dashboard-text)]"
          >
            No posts yet
          </h2>

          
          <p
            class="mt-3 text-[14px] leading-6 text-[color:var(--dashboard-muted)]"
          >
            Your personalized social feed will appear
            here once users start uploading content.
          </p>

          <!-- BUTTON -->
          <button
            type="button"
            data-upload-trigger
            class="upload-post-btn"
          >
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M12 16V4"></path>

              <path d="m7 9 5-5 5 5"></path>

              <path d="M4 20h16"></path>
            </svg>

            Upload first post
          </button>
        </div>
      </div>
    )
  }
</section>

<style>
  @keyframes feedIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-feed-in {
    animation: feedIn 0.4s ease forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-feed-in {
      animation: none;
    }
  }
 

.empty-state-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;

  text-align: center;

  max-width: 520px;
  margin: 0 auto;

  min-height: 260px;
}

.empty-state-content h2 {
  margin-top: 4px;
  text-align: center;
}

.empty-state-content p {
  max-width: 420px;
  text-align: center;
}



.upload-post-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;

  margin-top: 24px;

  padding: 14px 24px;

  border-radius: 16px;

  background: linear-gradient(
    135deg,
    #7c3aed,
    #8b5cf6
  );

  color: white;
  font-size: 14px;
  font-weight: 700;

  box-shadow:
    0 12px 30px rgba(124, 58, 237, 0.25);

  transition:
    transform 0.2s ease,
    box-shadow 0.2s ease,
    opacity 0.2s ease;
}

.upload-post-btn:hover {
  transform: translateY(-2px);

  box-shadow:
    0 18px 40px rgba(124, 58, 237, 0.35);
}

.upload-post-btn:active {
  transform: translateY(0);
}
</style>
