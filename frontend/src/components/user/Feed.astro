---
import PostCard from "./PostCard.astro";

import type { PostItem } from "../../types/post";

const { posts } = Astro.props as {
  posts: PostItem[];
};
---

<section
  class="relative"
  data-feed-container
>
  {
    posts.length ? (
      <!-- POSTS -->
      <div
        class="flex flex-col gap-5"
      >
        {
          posts.map((post, index) => (
            <div
              class="animate-feed-in"
              style={`animation-delay:${index * 40}ms`}
            >
              <PostCard post={post} />
            </div>
          ))
        }
      </div>
    ) : (
      <!-- EMPTY STATE -->
      <div
        class="overflow-hidden rounded-[28px] border border-white/5 bg-white/[0.03] p-9 shadow-[0_18px_50px_rgba(0,0,0,0.22)]"
      >
        <div
          class="mx-auto flex max-w-md flex-col items-center text-center"
        >
          <!-- ICON -->
          <div
            class="mb-5 grid h-20 w-20 place-items-center rounded-[24px] border border-violet-500/20 bg-violet-500/10 text-violet-300 shadow-[0_10px_40px_rgba(124,58,237,0.22)]"
          >
            <svg
              class="h-9 w-9"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
            >
              <path
                d="M4 19V5a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v14"
              ></path>

              <path
                d="m4 15 4-4a2 2 0 0 1 2.8 0l1.2 1.2a2 2 0 0 0 2.8 0L20 7"
              ></path>

              <circle
                cx="8.5"
                cy="8.5"
                r="1.5"
              ></circle>
            </svg>
          </div>

          <!-- TITLE -->
          <h2
            class="text-[30px] font-black tracking-[-0.04em] text-[color:var(--dashboard-text)]"
          >
            No posts yet
          </h2>

          <!-- DESCRIPTION -->
          <p
            class="mt-3 text-[14px] leading-6 text-[color:var(--dashboard-muted)]"
          >
            Your personalized social feed will appear
            here once users start uploading content.
          </p>

          <!-- BUTTON -->
          <button
            type="button"
            data-upload-trigger
            class="mt-7 inline-flex items-center gap-2 rounded-[14px] bg-violet-600 px-5 py-3 text-sm font-semibold text-white shadow-[0_10px_30px_rgba(124,58,237,0.28)] transition hover:bg-violet-500"
          >
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M12 16V4"></path>

              <path d="m7 9 5-5 5 5"></path>

              <path d="M4 20h16"></path>
            </svg>

            Upload first post
          </button>
        </div>
      </div>
    )
  }
</section>

<style>
  @keyframes feedIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-feed-in {
    animation: feedIn 0.4s ease forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-feed-in {
      animation: none;
    }
  }
</style>
