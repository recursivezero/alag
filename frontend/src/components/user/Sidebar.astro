---
import Avatar from "../ui/Avatar.astro";
import ThemeToggle from "./ThemeToggle.astro";
import type { UserProfile } from "../../types/user";

const { currentPath = "/dashboard", user } = Astro.props as {
  currentPath?: string;
  user: UserProfile;
};

const navItems = [
  {
    label: "Home",
    href: "/dashboard",
    icon: '<path d="M4 10.5 12 4l8 6.5V20a1 1 0 0 1-1 1h-4.5a.5.5 0 0 1-.5-.5V15a2 2 0 0 0-4 0v5.5a.5.5 0 0 1-.5.5H5a1 1 0 0 1-1-1v-9.5Z"/>',
  },
  {
    label: "Explore",
    href: "/dashboard/explore",
    icon: '<path d="M12 21a9 9 0 1 0-9-9 9 9 0 0 0 9 9Zm3.7-12.7-2 5.2-5.2 2 2-5.2 5.2-2Z"/><path d="M12 12l1.7-1.7"/>',
  },
  {
    label: "My Images",
    href: "/dashboard/profile",
    icon: '<rect x="4" y="5" width="16" height="14" rx="3"/><path d="m8 13 2.2-2.2a1 1 0 0 1 1.4 0L15 14m-4-4 1.2-1.2a1 1 0 0 1 1.4 0L18 13.2"/><circle cx="9" cy="9" r="1.2"/>',
  },
  {
    label: "Saved",
    href: "/dashboard/saved",
    icon: '<path d="M7 4h10a1 1 0 0 1 1 1v16l-6-3-6 3V5a1 1 0 0 1 1-1Z"/>',
  },
  {
    label: "Liked",
    href: "/dashboard/liked",
    icon: '<path d="M12 20s-7-4.4-7-10a4 4 0 0 1 7-2.6A4 4 0 0 1 19 10c0 5.6-7 10-7 10Z"/>',
  },
  {
    label: "Profile",
    href: "/dashboard/profile",
    icon: '<circle cx="12" cy="8" r="4"/><path d="M4.5 20a7.5 7.5 0 0 1 15 0"/>',
  },
  {
    label: "Settings",
    href: "/dashboard/settings",
    icon: '<path d="M19.4 12.98a7.9 7.9 0 0 0 .05-.98 7.9 7.9 0 0 0-.05-.98l2.03-1.6a.5.5 0 0 0 .12-.64l-1.93-3.34a.5.5 0 0 0-.6-.22l-2.39.96a7.2 7.2 0 0 0-1.7-.98l-.36-2.54a.5.5 0 0 0-.5-.42h-3.86a.5.5 0 0 0-.5.42l-.36 2.54c-.6.22-1.17.54-1.7.98l-2.39-.96a.5.5 0 0 0-.6.22L2.41 8.78a.5.5 0 0 0 .12.64l2.03 1.6c-.03.33-.05.66-.05.98s.02.65.05.98l-2.03 1.6a.5.5 0 0 0-.12.64l1.93 3.34a.5.5 0 0 0 .6.22l2.39-.96c.52.43 1.1.77 1.7.98l.36 2.54a.5.5 0 0 0 .5.42h3.86a.5.5 0 0 0 .5-.42l.36-2.54c.6-.22 1.17-.54 1.7-.98l2.39.96a.5.5 0 0 0 .6-.22l1.93-3.34a.5.5 0 0 0-.12-.64l-2.03-1.6ZM12 15.2A3.2 3.2 0 1 1 12 8.8a3.2 3.2 0 0 1 0 6.4Z"/>',
  },
];
---

<aside
  class="fixed inset-y-0 left-0 z-40 hidden w-[250px] flex-col overflow-visible border-r border-[color:var(--dashboard-border)] bg-[color:var(--dashboard-surface-strong)] px-3 py-3 shadow-[0_25px_80px_rgba(0,0,0,0.45)] backdrop-blur-2xl lg:flex"
>
  <div
    class="flex items-center justify-between gap-3 rounded-[14px] border border-[color:var(--dashboard-border)] bg-[color:var(--dashboard-surface)] px-3 py-3 shadow-[0_10px_30px_rgba(0,0,0,0.12)]"
  >
    <div class="flex min-w-0 items-center gap-3">
      <div
        class="grid h-12 w-12 shrink-0 place-items-center rounded-[10px] border border-violet-400/30 bg-[linear-gradient(180deg,rgba(124,58,237,0.22),rgba(79,70,229,0.1))] text-violet-100 shadow-[0_0_20px_rgba(124,58,237,0.25)]"
      >
        <svg
          class="h-5 w-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
        >
          <path d="M12 2l8 4v6c0 5-3.4 9.4-8 10-4.6-.6-8-5-8-10V6l8-4z"></path>
          <path d="M9 12l2 2 4-4"></path>
        </svg>
      </div>
      <div class="min-w-0">
        <p
          class="truncate text-[1rem] font-bold tracking-[-0.05em] text-[color:var(--dashboard-text)]"
        >
          RecursiveAuth
        </p>
        <p class="truncate text-xs text-[color:var(--dashboard-muted)]">
          Public user dashboard
        </p>
      </div>
    </div>

    <button
      type="button"
      class="grid h-11 w-11 place-items-center rounded-[7px] border border-[color:var(--dashboard-border)] bg-[color:var(--dashboard-surface)] text-[color:var(--dashboard-text)] transition-all hover:border-violet-400/40 hover:bg-[color:var(--dashboard-accent-soft)] lg:hidden"
      aria-label="Toggle sidebar"
    >
      <svg
        viewBox="0 0 24 24"
        class="h-5 w-5"
        fill="none"
        stroke="currentColor"
        stroke-width="2.05"
      >
        <path d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <nav class="mt-4 flex flex-1 flex-col gap-2 overflow-visible">
    {
      navItems.map((item) => {
        const isActive =
          currentPath === item.href || currentPath.startsWith(`${item.href}/`);
        const iconMarkup = `<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">${item.icon}</svg>`;

        return (
          <a
            href={item.href}
            class:list={[
              "group flex items-center gap-3 rounded-[10px] px-3 py-3 text-sm font-medium transition-all duration-200",
              isActive
                ? "border border-violet-400/30 bg-[linear-gradient(180deg,rgba(124,58,237,0.24),rgba(79,70,229,0.14))] text-[color:var(--dashboard-text)] shadow-[0_14px_34px_rgba(124,58,237,0.2)]"
                : "border border-transparent text-[color:var(--dashboard-muted)] hover:border-[color:var(--dashboard-border)] hover:bg-[color:var(--dashboard-accent-soft)] hover:text-[color:var(--dashboard-text)]",
            ]}
            aria-current={isActive ? "page" : undefined}
          >
            <span
              class:list={[
                "grid h-11 w-11 shrink-0 place-items-center rounded-[10px] border transition-all",
                isActive
                  ? "border-violet-400/30 bg-violet-500/15 text-violet-100 shadow-[0_0_18px_rgba(124,58,237,0.22)]"
                  : "border-[color:var(--dashboard-border)] bg-[color:var(--dashboard-surface)] text-[color:var(--dashboard-muted)] group-hover:border-violet-400/20 group-hover:bg-[color:var(--dashboard-accent-soft)] group-hover:text-[color:var(--dashboard-text)]",
              ]}
              set:html={iconMarkup}
            />
            <span>{item.label}</span>
          </a>
        );
      })
    }
  </nav>

  <div class="mt-auto border-t border-[color:var(--dashboard-border)] pt-5">
    <div class="grid gap-3">
      <ThemeToggle />

      <button
        id="publicSidebarLogoutButton"
        type="button"
        data-logout-button
        class="flex h-[58px] w-full items-center gap-3 rounded-[10px] border border-rose-400/15 bg-rose-500/8 px-3 text-left transition-all hover:border-rose-400/30 hover:bg-rose-500/12"
      >
        <span
          class="grid h-11 w-11 shrink-0 place-items-center rounded-[10px] border border-rose-400/20 bg-rose-500/10 text-rose-100"
        >
          <svg
            viewBox="0 0 24 24"
            class="h-5 w-5"
            fill="none"
            stroke="currentColor"
            stroke-width="2.05"
          >
            <path d="M10 17l1.5-1.5M10 7l1.5 1.5M4 12h12m-3-7 4 7-4 7"></path>
          </svg>
        </span>
        <span class="text-[15px] font-medium text-rose-100">Logout</span>
      </button>

      <div
        class="flex items-center gap-3 rounded-[18px] border border-[color:var(--dashboard-border)] bg-[color:var(--dashboard-surface)] p-3 shadow-[0_10px_30px_rgba(0,0,0,0.12)]"
      >
        <Avatar src={user.picture || "/icon.png"} alt={user.name} size="md" />
        <div class="min-w-0 flex-1">
          <p
            class="truncate text-sm font-semibold text-[color:var(--dashboard-text)]"
          >
            {user.name}
          </p>
          <p class="truncate text-xs text-[color:var(--dashboard-muted)]">
            {user.email}
          </p>
        </div>
      </div>
    </div>
  </div>
</aside>

<script type="module">
  import { clearUserSessionToken } from "../../services/session";

  const win = window;

  if (!win.__publicDashboardLogoutBound) {
    win.__publicDashboardLogoutBound = true;

    document.addEventListener("click", async (event) => {
      const trigger =
        event.target instanceof Element
          ? event.target.closest("[data-logout-button]")
          : null;

      if (!trigger) return;

      event.preventDefault();

      try {
        await clearUserSessionToken();
      } finally {
        window.location.replace("/login");
      }
    });
  }
</script>
