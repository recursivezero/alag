---
import Avatar from "../ui/Avatar.astro";
import type { UserProfile } from "../../types/user";

const { user } = Astro.props as { user: UserProfile };
---

<details class="relative w-fit">
  <summary class="list-none cursor-pointer rounded-full outline-none ring-0 transition focus-visible:ring-2 focus-visible:ring-[color:var(--dashboard-accent)]">
    <span class="sr-only">Open profile menu</span>
    <Avatar src={user.picture || "/icon.png"} alt={user.name} size="md" />
  </summary>

  <div class="absolute right-0 top-[calc(100%+0.75rem)] z-[60] w-80 max-w-[calc(100vw-1.5rem)] overflow-hidden rounded-[24px] border border-[color:var(--dashboard-border)] bg-[color:var(--dashboard-surface-strong)] p-4 shadow-[0_24px_80px_rgba(0,0,0,0.28)] backdrop-blur-2xl">
    <div class="flex items-center gap-3 border-b border-[color:var(--dashboard-border)] pb-4">
      <Avatar src={user.picture || "/icon.png"} alt={user.name} size="lg" />
      <div class="min-w-0">
        <p class="truncate text-base font-semibold text-[color:var(--dashboard-text)]">{user.name}</p>
        <p class="truncate text-sm text-[color:var(--dashboard-muted)]">{user.email}</p>
        <p class="truncate text-sm text-[color:var(--dashboard-muted)]">{user.phoneNumber || "Phone not set"}</p>
      </div>
    </div>

    <div class="mt-3 grid gap-1 text-sm font-medium">
      <a href="/dashboard/profile" class="rounded-[14px] px-4 py-3 text-[color:var(--dashboard-text)] transition hover:bg-[color:var(--dashboard-accent-soft)] hover:text-[color:var(--dashboard-text)]">Profile</a>
      <a href="/dashboard/settings" class="rounded-[14px] px-4 py-3 text-[color:var(--dashboard-text)] transition hover:bg-[color:var(--dashboard-accent-soft)] hover:text-[color:var(--dashboard-text)]">Settings</a>
      <button id="profileDropdownLogoutButton" type="button" data-logout-button class="rounded-[14px] px-4 py-3 text-left text-rose-500 transition hover:bg-rose-500/10">Logout</button>
    </div>
  </div>
</details>