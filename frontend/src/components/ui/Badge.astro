---
interface Props {
  tone?: "success" | "danger" | "warning" | "info" | "neutral";
  class?: string;
}

const { tone = "neutral", class: className = "" } = Astro.props as Props;

const toneClasses = {
  success: "border-emerald-400/35 bg-emerald-500/15 text-emerald-300",
  danger: "border-rose-400/35 bg-rose-500/15 text-rose-300",
  warning: "border-amber-400/35 bg-amber-500/15 text-amber-200",
  info: "border-cyan-400/30 bg-cyan-500/15 text-cyan-200",
  neutral: "border-slate-500/30 bg-slate-500/12 text-slate-200",
} as const;
---

<span
  class:list={[
    "inline-flex items-center gap-1.5 rounded-xl border px-2.5 py-1 text-xs font-semibold",
    toneClasses[tone],
    className,
  ]}
>
  <slot />
</span>