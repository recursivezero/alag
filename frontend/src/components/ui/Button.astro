---
interface Props {
  id?: string;
  type?: "button" | "submit" | "reset";
  variant?: "primary" | "ghost" | "danger" | "outline";
  size?: "sm" | "md";
  class?: string;
}

const {
  type = "button",
  variant = "primary",
  size = "md",
  class: className = "",
} = Astro.props as Props;

const {
  class: _ignoredClass,
  type: _ignoredType,
  variant: _ignoredVariant,
  size: _ignoredSize,
  ...buttonProps
} = Astro.props as Props & Record<string, unknown>;

const variantClasses = {
  primary:
    "bg-gradient-to-r from-violet-500 to-indigo-500 text-white shadow-[0_0_24px_rgba(129,92,255,0.26)] hover:shadow-[0_0_28px_rgba(129,92,255,0.38)]",
  ghost:
    "border border-slate-700/70 bg-slate-900/55 text-slate-100 hover:border-slate-500/80 hover:bg-slate-800/60",
  danger:
    "border border-rose-400/25 bg-rose-500/10 text-rose-100 hover:border-rose-400/45 hover:bg-rose-500/15",
  outline:
    "border border-violet-400/25 bg-transparent text-violet-100 hover:border-violet-400/45 hover:bg-violet-500/10",
} as const;

const sizeClasses = {
  sm: "px-3 py-2 text-xs",
  md: "px-4 py-3 text-sm",
} as const;
---

<button
  type={type}
  {...buttonProps}
  class:list={[
    "inline-flex items-center justify-center gap-2 rounded-2xl font-semibold transition duration-200 disabled:cursor-not-allowed disabled:opacity-70",
    variantClasses[variant],
    sizeClasses[size],
    className,
  ]}
>
  <slot />
</button>
