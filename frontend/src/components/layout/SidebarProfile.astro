---
import Avatar from "../ui/Avatar.astro";

import type { UserProfile } from "../../types/user";

const { user } = Astro.props as {
  user: UserProfile;
};
---

<article
  data-sidebar-profile
  class="rounded-[22px] border border-white/5 bg-white/[0.025] p-3 shadow-[0_16px_42px_rgba(0,0,0,0.14)] transition-all duration-300"
>
  <div class="flex items-center gap-3">
    <Avatar src={user.picture || "/icon.png"} alt={user.name} size="md" />

    <div data-sidebar-profile-copy class="min-w-0">
      <p
        class="truncate text-[13px] font-semibold text-[color:var(--dashboard-text)]"
      >
        {user.name}
      </p>

      <p class="truncate text-[11px] text-[color:var(--dashboard-muted)]">
        {user.email}
      </p>

      {
        user.role && (
          <p class="mt-1 truncate text-[10px] font-semibold uppercase tracking-[0.18em] text-violet-300/80">
            {user.role}
          </p>
        )
      }
    </div>
  </div>
</article>
