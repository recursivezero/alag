# Development environment variables
NODE_ENV=development
FRONTEND_URL=http://localhost:4321
# For local dev, ensure cookies aren't forced secure
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax
# Optional: set domain for cookies (e.g. localhost or your dev domain)
# COOKIE_DOMAIN=localhost
# Optional: override cookie max age (in seconds)
# COOKIE_MAX_AGE=604800
JWT_SECRET=dev_secret
PORT=5001
