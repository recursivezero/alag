# Production environment variables
NODE_ENV=production
FRONTEND_URL=https://yourfrontend.example.com
# In production, cookies should be secure
COOKIE_SECURE=true
# SameSite may be 'Lax', 'Strict', or 'None' depending on cross-site needs
COOKIE_SAMESITE=Lax
# Set your domain (omit leading dot for single host)
# COOKIE_DOMAIN=example.com
# Optional: override cookie max age (in seconds)
# COOKIE_MAX_AGE=604800
JWT_SECRET=replace_with_strong_secret
PORT=5001
